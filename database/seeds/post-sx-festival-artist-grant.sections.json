82f4 elementor-widget elementor-widget-heading\" data-id=\"be082f4\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<span class=\"elementor-heading-title elementor-size-default\"><a href=\"https://sxtech.eu/#tickets\">TICKETS</a></span>\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t<div class=\"elementor-element elementor-element-7eb1d51 e-flex e-con-boxed e-con e-parent\" data-id=\"7eb1d51\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t<div class=\"elementor-element elementor-element-0ef5f57 e-con-full e-flex e-con e-child\" data-id=\"0ef5f57\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-fc61fae elementor-widget elementor-widget-heading\" data-id=\"fc61fae\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h1 class=\"elementor-heading-title elementor-size-default\">SX FESTIVAL ARTIST <br />\nGRANT FOR LINEUP CURATION</h1>\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t<div class=\"elementor-element elementor-element-c66ea46 e-flex e-con-boxed e-con e-parent\" data-id=\"c66ea46\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t\t\t<div class=\"elementor-element elementor-element-e3c9222 elementor-widget elementor-widget-text-editor\" data-id=\"e3c9222\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\t<p class=\"cvGsUA direction-ltr align-start para-style-body\"><strong><span class=\"a_GcMg font-feature-liga-off font-feature-clig-off font-feature-calt-off text-decoration-none text-strikethrough-none\">We are opening selected sales partnerships with collectives and communities to co-drive the art program at SX FESTIVAL &amp; SX EXPO 2026</span></strong></p>\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t<div class=\"elementor-element elementor-element-e48560f e-flex e-con-boxed e-con e-parent\" data-id=\"e48560f\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t<div class=\"elementor-element elementor-element-c4f8f55 e-con-full e-flex e-con e-child\" data-id=\"c4f8f55\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-6b4b170 elementor-widget elementor-widget-image\" data-id=\"6b4b170\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img fetchpriority=\"high\" decoding=\"async\" width=\"344\" height=\"344\" src=\"https://sx.zds.es/wp-content/uploads/2026/04/4w.png\" class=\"attachment-large size-large wp-image-1633\" alt=\"\" srcset=\"https://sx.zds.es/wp-content/uploads/2026/04/4w.png 344w, https://sx.zds.es/wp-content/uploads/2026/04/4w-300x300.png 300w, https://sx.zds.es/wp-content/uploads/2026/04/4w-150x150.png 150w\" sizes=\"(max-width: 344px) 100vw, 344px\" />\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t<div class=\"elementor-element elementor-element-b41e879 e-con-full e-flex e-con e-child\" data-id=\"b41e879\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-a042294 elementor-widget elementor-widget-image\" data-id=\"a042294\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img decoding=\"async\" width=\"344\" height=\"344\" src=\"https://sx.zds.es/wp-content/uploads/2026/04/5w.png\" class=\"attachment-large size-large wp-image-1635\" alt=\"\" srcset=\"https://sx.zds.es/wp-content/uploads/2026/04/5w.png 344w, https://sx.zds.es/wp-content/uploads/2026/04/5w-300x300.png 300w, https://sx.zds.es/wp-content/uploads/2026/04/5w-150x150.png 150w\" sizes=\"(max-width: 344px) 100vw, 344px\" />\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t<div class=\"elementor-element elementor-element-677f410 e-con-full e-flex e-con e-child\" data-id=\"677f410\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-a737a1c elementor-widget elementor-widget-image\" data-id=\"a737a1c\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img decoding=\"async\" width=\"344\" height=\"344\" src=\"https://sx.zds.es/wp-content/uploads/2026/04/6w.png\" class=\"attachment-large size-large wp-image-1634\" alt=\"\" srcset=\"https://sx.zds.es/wp-content/uploads/2026/04/6w.png 344w, https://sx.zds.es/wp-content/uploads/2026/04/6w-300x300.png 300w, https://sx.zds.es/wp-content/uploads/2026/04/6w-150x150.png 150w\" sizes=\"(max-width: 344px) 100vw, 344px\" />\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t<div class=\"elementor-element elementor-element-dda049d e-flex e-con-boxed e-con e-parent\" data-id=\"dda049d\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t\t\t<div class=\"elementor-element elementor-element-9020321 elementor-widget elementor-widget-text-editor\" data-id=\"9020321\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\t<p class=\"cvGsUA direction-ltr align-start para-style-body\"><span class=\"a_GcMg font-feature-liga-off font-feature-clig-off font-feature-calt-off text-decoration-none text-strikethrough-none\">SX Festival is announcing a final grant for unique, curated ideas for the SX Festival stage and curatorial vision. This is a guaranteed fee designed to support projects we truly believe in, coming from the local scene.</span></p><p class=\"cvGsUA direction-ltr align-start para-style-body\"><span class=\"a_GcMg font-feature-liga-off font-feature-clig-off font-feature-calt-off text-decoration-none text-strikethrough-none\">This opportunity is not open to everyone. We are inviting collectives with a strong identity, a clear voice, and a distinctive approach to programming that aligns with the spirit of our festival. What matters to us is originality, depth, and the ability to create a cohesive experience.</span></p><p class=\"cvGsUA direction-ltr align-start para-style-body\"><span class=\"a_GcMg font-feature-liga-off font-feature-clig-off font-feature-calt-off text-decoration-none text-strikethrough-none\">We are looking for multidisciplinary concepts that bring together music, performance, talks, and unexpected formats. Projects that feel intentional, immersive, and memorable from start to finish.</span></p><p class=\"cvGsUA direction-ltr align-start para-style-body\"><span class=\"a_GcMg font-feature-liga-off font-feature-clig-off font-feature-calt-off text-decoration-none text-strikethrough-none\">This is a chance to take full ownership of a curated artistic space, bring your community into it, and create something that stands out.</span></p><p class=\"cvGsUA direction-ltr align-start para-style-body\"><span class=\"a_GcMg font-feature-liga-off font-feature-clig-off font-feature-calt-off text-decoration-none text-strikethrough-none\">If this resonates with your work, we would love to hear from you.</span></p><p><span class=\"a_GcMg font-feature-liga-off font-feature-clig-off font-feature-calt-off text-decoration-none text-strikethrough-none\">Applications open from</span><span class=\"a_GcMg font-feature-liga-off font-feature-clig-off font-feature-calt-off text-decoration-none text-strikethrough-none\"> 15 April to 3 May 2026.</span> <span class=\"a_GcMg font-feature-liga-off font-feature-clig-off font-feature-calt-off text-decoration-none text-strikethrough-none\">APPLY HERE</span> <a class=\"a_GcMg font-feature-liga-off font-feature-clig-off font-feature-calt-off text-decoration-underline text-strikethrough-none\" draggable=\"false\" href=\"https://canva.link/90xb61icngrwqj8\" target=\"_blank\" rel=\"noopener\">MORE INFO</a></p>\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t<div class=\"elementor-element elementor-element-aebcbe8 e-con-full e-flex e-con e-child\" data-id=\"aebcbe8\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-1212773 elementor-mobile-align-justify elementor-widget-mobile__width-inherit elementor-widget elementor-widget-button\" data-id=\"1212773\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"button.default\">\n\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-button elementor-button-link elementor-size-sm\" href=\"https://sxtech.us20.list-manage.com/subscribe?u=3e8fe16cc99a204f2cded972c&#038;id=b03816ab1d\">\n\t\t\t\t\t\t<span class=\"elementor-button-content-wrapper\">\n\t\t\t\t\t\t\t\t\t<span class=\"elementor-button-text\">join our<br />newsletter</span>\n\t\t\t\t\t</span>\n\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t<div class=\"elementor-element elementor-element-f5ee0e6 elementor-mobile-align-justify elementor-widget-mobile__width-inherit elementor-widget elementor-widget-button\" data-id=\"f5ee0e6\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"button.default\">\n\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-button elementor-button-link elementor-size-sm\" href=\"https://sxtech.eu/#tickets\">\n\t\t\t\t\t\t<span class=\"elementor-button-content-wrapper\">\n\t\t\t\t\t\t\t\t\t<span class=\"elementor-button-text\">GET YOUR TICKET</span>\n\t\t\t\t\t</span>\n\t\t\t\t\t</a>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t</div>"
