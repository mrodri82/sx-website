---

<BaseLayout title="Module Showcase — Admin Only">
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <div class="min-h-screen pt-24 pb-24">
    <div class="max-w-7xl mx-auto px-6 mb-12">
      <h1 class="text-4xl font-display font-bold text-white mb-4">Module Showcase</h1>
      <p class="text-navy-400">Alle Modul-Typen mit Lorem-Ipsum-Daten. Nur für Admins sichtbar.</p>
      <p class="text-navy-600 text-sm mt-2">{modules.length} Module | {new Date().toLocaleDateString('de-DE')}</p>
    </div>

    {sectionData.map((section) => (
      <div class="mb-4">
        <div class="max-w-7xl mx-auto px-6 mb-2">
          <span class="text-xs font-mono text-brand-400 bg-navy-800/50 px-3 py-1 rounded-lg border border-navy-700/30">
            {section.component} — {section.title}
          </span>
        </div>
        <ModuleRenderer sections={[section]} locale="es" />
      </div>
    ))}
  </div>
</BaseLayout>
