---
export const prerender = false;

import { getTokenFromCookies, getSession } from '@/lib/auth';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import ModuleRenderer from '@/components/modules/ModuleRenderer.astro';
import { getPageSections } from '@/lib/wordpress';
import { MODULE_REGISTRY, ADVANCED_FIELDS } from '@/lib/editor/module-registry';
import { site } from '@/config/site';

// Auth check
const token = getTokenFromCookies(Astro.request.headers.get('cookie'));
const session = token ? getSession(token) : null;
if (!session) return Astro.redirect('/admin/login?return=' + encodeURIComponent(Astro.url.pathname));

// Get page slug
const slug = Astro.params.slug || 'homepage';

// Allow the editor to preview a non-default locale by passing
// ?nova_preview_lang=de (etc.). Falls back to the project default.
const reqLang = Astro.url.searchParams.get('nova_preview_lang') || '';
const previewLocale = (site.locales.includes(reqLang as any) ? reqLang : site.defaultLocale) as any;

// Fetch page data
let sections: any[] = [];
let pageId = 0;
let seoTitle = '';
let seoDescription = '';

const WP_URL = site.cmsUrl;
const WP_USER = import.meta.env.WP_CMS_USER || '';
const WP_PASS = import.meta.env.WP_CMS_APP_PASSWORD || '';
const wpAuth = WP_USER ? `Basic ${btoa(`${WP_USER}:${WP_PASS}`)}` : '';

try {
  const result = await getPageSections(slug);
  sections = result.sections;
  seoTitle = result.seoTitle || '';
  seoDescription = result.seoDescription || '';

  // Get page ID
  const wpH: Record<string, string> = { Host: site.cmsHost };
  if (wpAuth) wpH.Authorization = wpAuth;
  const pageRes = await fetch(`${WP_URL}/index.php/?rest_route=/wp/v2/pages&slug=${slug}&_fields=id,meta`, { headers: wpH });
  const pages = await pageRes.json();
  if (pages.length) {
    pageId = pages[0].id;
  }
} catch (err) {
  console.error('Live editor: failed to fetch page:', err);
}

// Serialize for client-side
const sectionsJSON = JSON.stringify(sections);
const registryJSON = JSON.stringify(MODULE_REGISTRY);
const advancedJSON = JSON.stringify(ADVANCED_FIELDS);

// i18n: only render the language bar when the project has more than
// one configured locale. SX defaults to English-only, so the bar
// stays hidden unless an admin opts in by setting LOCALES in .env.
const projectLocales = site.locales.length ? site.locales : [site.defaultLocale];
const showLangBar = projectLocales.length > 1;
const projectDefaultLocale = site.defaultLocale;
---

<BaseLayout title={`${seoTitle || slug} — Live Editor`}>
  <Navigation />
  <ModuleRenderer sections={sections} locale={previewLocale} />
  <Footer />

  <!-- ════════════ TOOLBAR ════════════ -->
  <div class="nova-toolbar">
    <!-- LEFT: Back to WP + Nova + Page Selector + Preview Devices -->
    <a class="nova-toolbar-btn" href="/wp-admin/" target="_top" title="Zurück zum WP Admin" style="font-size:13px">&larr; WP</a>
    <div class="nova-toolbar-sep"></div>
    <div class="nova-toolbar-logo">Nova</div>
    <div class="nova-toolbar-sep"></div>
    <div style="position:relative">
      <button class="nova-toolbar-btn" id="nova-page-tree-btn" style="font-family:'JetBrains Mono',monospace;font-size:12px;min-width:160px;text-align:left">
        <span id="nova-current-page-label">/ {slug === 'homepage' ? 'Homepage' : slug}</span> <span style="opacity:0.4;margin-left:4px">&darr;</span>
      </button>
      <div id="nova-page-tree-panel" style="display:none;position:absolute;top:calc(100% + 4px);left:0;width:320px;background:var(--nova-surface);border:1px solid var(--nova-border);border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,0.4);z-index:200;overflow:hidden">
        <div style="padding:8px">
          <input id="nova-page-search" type="text" placeholder="Seite suchen..." style="width:100%;font-size:12px;padding:6px 10px;background:var(--nova-bg);border:1px solid var(--nova-border);border-radius:8px;color:var(--nova-text);font-family:inherit;outline:none" />
        </div>
        <div id="nova-page-tree-list" style="max-height:400px;overflow-y:auto;padding:0 4px 8px"></div>
      </div>
    </div>
    <a class="nova-toolbar-btn" href={`/${slug === 'homepage' ? '' : slug}?preview=1`} target="_blank" title="Seite im Browser &ouml;ffnen" style="font-size:12px;gap:4px">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
      Preview
    </a>
    <div class="nova-toolbar-sep"></div>
    <!-- Responsive Preview Buttons -->
    <button class="nova-toolbar-btn nova-device-btn active" data-device="desktop" title="Desktop">&#x1F5A5;</button>
    <button class="nova-toolbar-btn nova-device-btn" data-device="tablet" title="Tablet (768px)" style="font-size:12px">&#x1F4F1;</button>
    <button class="nova-toolbar-btn nova-device-btn" data-device="mobile" title="Mobile (375px)" style="font-size:11px">&#x1F4F1;</button>
    <div class="nova-toolbar-spacer"></div>
    <!-- SEO Toolbar Dropdown -->
    <div style="position:relative" id="nova-seo-dropdown-wrap">
      <button class="nova-toolbar-btn" id="nova-seo-btn" title="SEO (Title, Description, Slug)">SEO</button>
      <div id="nova-seo-panel" style="display:none;position:absolute;top:calc(100% + 6px);right:0;width:420px;background:var(--nova-surface);border:1px solid var(--nova-border);border-radius:12px;box-shadow:0 12px 40px rgba(0,0,0,0.5);z-index:200;padding:16px;font-size:13px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
          <span style="font-weight:700;color:var(--nova-text);font-size:14px">SEO — Seiteneinstellungen</span>
          <button id="nova-seo-close" style="background:none;border:none;color:var(--nova-text-dim);cursor:pointer;font-size:16px">&times;</button>
        </div>
        <!-- SERP Preview -->
        <div id="nova-serp-preview" style="background:rgba(255,255,255,0.03);border:1px solid var(--nova-border);border-radius:8px;padding:12px;margin-bottom:14px;font-family:Arial,sans-serif">
          <div id="nova-serp-url" style="font-size:11px;color:#70757a;margin-bottom:2px"></div>
          <div id="nova-serp-title" style="font-size:16px;color:#8ab4f8;margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"></div>
          <div id="nova-serp-desc" style="font-size:12px;color:#bdc1c6;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden"></div>
        </div>
        <!-- Fields -->
        <div style="margin-bottom:10px">
          <label style="display:flex;justify-content:space-between;color:var(--nova-text-muted);font-size:11px;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:4px">
            <span>Meta Title</span><span id="nova-seo-title-count" style="color:var(--nova-text-dim)">0/60</span>
          </label>
          <input type="text" id="nova-seo-title" maxlength="70" style="width:100%;padding:8px 10px;background:var(--nova-bg);border:1px solid var(--nova-border);border-radius:8px;color:var(--nova-text);font-size:13px;font-family:inherit" placeholder="Meta Title (50-60 Zeichen ideal)">
        </div>
        <div style="margin-bottom:10px">
          <label style="display:flex;justify-content:space-between;color:var(--nova-text-muted);font-size:11px;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:4px">
            <span>Meta Description</span><span id="nova-seo-desc-count" style="color:var(--nova-text-dim)">0/160</span>
          </label>
          <textarea id="nova-seo-desc" maxlength="200" rows="3" style="width:100%;padding:8px 10px;background:var(--nova-bg);border:1px solid var(--nova-border);border-radius:8px;color:var(--nova-text);font-size:13px;font-family:inherit;resize:vertical;line-height:1.5" placeholder="Meta Description (140-155 Zeichen ideal)"></textarea>
        </div>
        <div style="margin-bottom:14px">
          <label style="display:block;color:var(--nova-text-muted);font-size:11px;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:4px">Slug</label>
          <div style="display:flex;align-items:center;gap:6px">
            <span style="color:var(--nova-text-dim);font-size:12px;white-space:nowrap">zds.es/</span>
            <input type="text" id="nova-seo-slug" style="flex:1;padding:8px 10px;background:var(--nova-bg);border:1px solid var(--nova-border);border-radius:8px;color:var(--nova-text);font-size:13px;font-family:'JetBrains Mono',monospace" placeholder="seiten-slug">
          </div>
        </div>
        <button id="nova-seo-save" style="width:100%;padding:10px;background:var(--nova-accent);color:#fff;border:none;border-radius:8px;font-weight:600;font-size:13px;cursor:pointer;font-family:inherit">SEO speichern</button>
      </div>
    </div>
    <a class="nova-toolbar-btn" href="/admin/validator" target="_blank">Validator</a>
    <div class="nova-toolbar-sep"></div>
    <button id="nova-versions-toolbar-btn" class="nova-toolbar-btn" title="Versionen">&#8634; Versions</button>
    <div class="nova-toolbar-sep"></div>
    <button id="nova-status-toggle" class="nova-toolbar-btn" title="Publish status" data-status="loading" style="font-size:11px;font-weight:600">&hellip;</button>
    <div class="nova-toolbar-sep"></div>
    <div class="nova-toolbar-user">
      <strong>{session.displayName}</strong>
      <span class="nova-toolbar-role">{session.role}</span>
    </div>
    <button class="nova-toolbar-btn" id="nova-logout-btn">Logout</button>
  </div>

  <!-- ════════════ BREADCRUMB ════════════ -->
  <div class="nova-breadcrumb">
    <span class="bc-page">Pagina</span> <span class="bc-sep">&#8250;</span>
    <span class="bc-page" id="bc-page-name">{slug === 'homepage' ? 'Homepage' : slug}</span>
    <span class="bc-sep" id="bc-sep-module" style="display:none">&#8250;</span>
    <span class="bc-page" id="bc-module-name" style="display:none"></span>
    <span class="bc-sep" id="bc-sep-field" style="display:none">&#8250;</span>
    <span class="bc-active" id="bc-field-name" style="display:none"></span>
  </div>

  <!-- ════════════ SIDEBAR ════════════ -->
  <!-- Sidebar collapse toggle — fixed overlay, always visible, wanders with the sidebar. -->
  <button id="nova-toggle-panel" class="nova-sidebar-toggle" title="Panel ein/ausblenden" aria-label="Panel ein/ausblenden">
    <span class="nova-sidebar-toggle-icon">&rsaquo;</span>
  </button>

  <!-- Module Picker Modal -->
  <div id="nova-module-picker-backdrop" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:99998;align-items:center;justify-content:center;">
    <div class="nova-module-picker">
      <div class="nova-module-picker-header">
        <span>Modul hinzuf&uuml;gen</span>
        <button id="nova-module-picker-close" class="nova-toolbar-btn" aria-label="Schlie&szlig;en">&times;</button>
      </div>
      <input id="nova-module-picker-search" placeholder="Modul suchen&hellip;" class="nova-module-picker-search" />
      <div id="nova-module-picker-grid" class="nova-module-picker-grid"></div>
    </div>
  </div>

  <div id="nova-live-panel" class="nova-sidebar">

    <!-- Module List / Page-Level AI (shows when no module is being edited) -->
    <div id="nova-module-list-wrap">
      <div class="nova-sidebar-header nova-sidebar-header-tabs">
        <button class="nova-sidebar-tab active" data-sidebar-tab="modules">Module</button>
        <button class="nova-sidebar-tab" data-sidebar-tab="page-ai">&#10024; AI</button>
      </div>
      <div class="nova-module-add-bar">
        <button id="nova-add-module-btn" class="nova-btn-save" style="width:100%">+ Modul hinzuf&uuml;gen</button>
      </div>
      <div id="nova-module-list" class="nova-module-list"></div>

      <!-- Page-Level AI Panel (hidden by default) -->
      <div id="nova-page-ai" class="nova-page-ai" style="display:none">
        <div class="nova-page-ai-intro">
          KI baut die ganze Seite. Beschreibe was du willst &mdash;
          z.B. &bdquo;Landingpage f&uuml;r SEO Audit mit Hero, 3 USPs, Pricing
          und Kontaktformular&ldquo;.
        </div>
        <div class="nova-page-ai-msgs" id="nova-page-ai-msgs"></div>
        <div class="nova-page-ai-input-bar">
          <textarea id="nova-page-ai-input" rows="4"
                    placeholder="Beschreibe die Seite die du bauen willst&hellip;"></textarea>
          <button id="nova-page-ai-send" class="nova-btn-save">KI baut Seite &rarr;</button>
        </div>
      </div>
    </div>

    <!-- Module Editor (shows when editing a module, hidden by default) -->
    <div id="nova-module-editor-wrap" style="display:none">

      <!-- Back bar -->
      <div class="nova-back-bar">
        <button id="nova-back-to-list" class="nova-back-btn">&larr; Zur&uuml;ck</button>
        <span id="nova-editing-label" class="nova-editing-label"></span>
      </div>

      <!-- Module Mode Bar (linked/detached) — hidden when not applicable -->
      <div id="nova-mode-bar" class="nova-mode-bar" style="display:none">
        <span class="nova-mode-label">Modus:</span>
        <button id="nova-mode-linked" class="nova-mode-btn" data-mode="linked" title="Gekoppelt an globales Modul &mdash; Edits wirken auf allen Seiten">&#128279; Gekoppelt</button>
        <button id="nova-mode-detached" class="nova-mode-btn" data-mode="detached" title="Eigenst&auml;ndige Kopie &mdash; Edits betreffen nur diese Seite">&#128203; Eigenst&auml;ndig</button>
      </div>

      {/* Language bar (global, NOT per field). Hidden in single-locale
          projects; sites that opt into multiple LOCALES see the picker. */}
      {showLangBar && (
        <div class="nova-lang-bar" id="nova-lang-bar-global">
          {projectLocales.map((lc) => {
            const flag = lc === 'es' ? '🇪🇸' : lc === 'en' ? '🇬🇧' : lc === 'de' ? '🇩🇪' : '🌐';
            return (
              <button
                class={`nova-lang-btn${lc === projectDefaultLocale ? ' active' : ''}`}
                data-lang={lc}
              >{flag} {lc.toUpperCase()}</button>
            );
          })}
        </div>
      )}
      <script is:inline define:vars={{ projectDefaultLocale, projectLocales }}>
        window.__novaProjectLocales = projectLocales;
        window.__novaProjectDefaultLocale = projectDefaultLocale;
      </script>

      <!-- Slot Map -->
      <div class="nova-slot-map" id="nova-slot-map">
        <div class="nova-slot-map-title" id="nova-slot-map-title">Slot Map</div>
        <div id="nova-slot-map-items"></div>
      </div>

      <!-- Tabs -->
      <div class="nova-tabs">
        <button class="nova-tab active" data-tab="content">Content</button>
        <button class="nova-tab" data-tab="style">Style</button>
        <button class="nova-tab" data-tab="ai">AI</button>
      </div>

      <!-- Content Tab -->
      <div class="nova-tab-panel" id="nova-tab-content">
        <div id="nova-content-fields"></div>
      </div>

      <!-- Style Tab -->
      <div class="nova-tab-panel" id="nova-tab-style" style="display:none">
        <div id="nova-style-fields"></div>
      </div>

      <!-- AI Tab -->
      <div class="nova-tab-panel nova-ai-panel" id="nova-tab-ai" style="display:none">
        <div class="nova-ai-quick" id="nova-ai-quick">
          <button class="nova-ai-quick-btn" data-action="K&uuml;rzer">K&uuml;rzer</button>
          <button class="nova-ai-quick-btn" data-action="Formaler">Formaler</button>
          <button class="nova-ai-quick-btn" data-action="&rarr; EN">&rarr; EN</button>
          <button class="nova-ai-quick-btn" data-action="&rarr; DE">&rarr; DE</button>
          <button class="nova-ai-quick-btn" data-action="SEO optimieren">SEO optimieren</button>
          <button class="nova-ai-quick-btn" data-action="Alle &uuml;bersetzen">Alle &uuml;bersetzen</button>
        </div>
        <div class="nova-ai-msgs" id="nova-ai-msgs">
          <div style="text-align:center;color:var(--nova-text-dim);font-size:12px;padding:40px 20px">
            W&auml;hle eine Aktion oben oder schreibe eine Anweisung.
          </div>
        </div>
        <div class="nova-ai-input-bar">
          <input type="text" id="nova-ai-input" placeholder="Was soll ich &auml;ndern?" />
          <button id="nova-ai-send">&rarr;</button>
        </div>
      </div>

      <!-- Save bar -->
      <div class="nova-save-bar">
        <button id="nova-versions-btn" class="nova-btn-ghost">&#8634; Versionen</button>
        <button id="nova-save" class="nova-btn-save">Speichern</button>
      </div>
    </div>

    <!-- Versions Panel -->
    <div id="nova-versions-panel" style="display:none" class="nova-versions"></div>
  </div>

  <!-- Tiptap Rich Text Editor CDN imports -->
  <script is:inline type="module">
    import { Editor } from 'https://esm.sh/@tiptap/core@2.11.5';
    import StarterKit from 'https://esm.sh/@tiptap/starter-kit@2.11.5';
    import Link from 'https://esm.sh/@tiptap/extension-link@2.11.5';
    import Image from 'https://esm.sh/@tiptap/extension-image@2.11.5';
    import TextStyle from 'https://esm.sh/@tiptap/extension-text-style@2.11.5';
    import Color from 'https://esm.sh/@tiptap/extension-color@2.11.5';
    import Highlight from 'https://esm.sh/@tiptap/extension-highlight@2.11.5';
    import Underline from 'https://esm.sh/@tiptap/extension-underline@2.11.5';
    window.__tiptap = { Editor, StarterKit, Link, Image, TextStyle, Color, Highlight, Underline };
    window.dispatchEvent(new Event('tiptap-ready'));
  </script>

  <style is:global>
    /* ═══════════════════════════════════════════════
       NOVA LIVE EDITOR — CSS (from prototype-merged)
       ═══════════════════════════════════════════════ */
    /* Editor CSS variables — namespaced with --nova- to avoid
       collisions with page design tokens (--bg, --accent, etc.) */
    :root {
      --nova-bg: #0d1117; --nova-surface: #161b22; --nova-surface2: #1c2128; --nova-surface3: #21262d;
      --nova-border: #30363d; --nova-text: #e6edf3; --nova-text-muted: #8b949e; --nova-text-dim: #484f58;
      --nova-accent: #2f81f7; --nova-accent-hover: #388bfd; --nova-accent-dim: rgba(47,129,247,0.15);
      --nova-green: #3fb950; --nova-green-dim: rgba(63,185,80,0.15);
      --nova-orange: #d29922; --nova-orange-dim: rgba(210,153,34,0.15);
      --nova-red: #f85149; --nova-teal: #39d2c0;
      --sidebar-w: 380px; --toolbar-h: 36px; --breadcrumb-h: 28px; --radius: 6px;
    }

    /* -- Disable GSAP in live editor — scoped to body.nova-editing so
       previewing the page WITHOUT editing keeps animations running -- */
    body.nova-editing [data-animate] { opacity: 1 !important; transform: none !important; clip-path: none !important; animation: none !important; }

    /* -- Module Hover/Select Outlines -- */
    [data-nova-module] { position: relative; cursor: pointer; transition: outline 0.15s; z-index: 1; }
    /* Inline-editing cursor hint on text elements */
    [data-nova-module] [data-nova-el] { cursor: text; }
    [data-nova-module] a[data-nova-el], [data-nova-module] button[data-nova-el] { cursor: pointer; }
    /* Active inline-editing element — subtle outline + don't show caret in wrong place */
    .nova-inline-editing {
      outline: 2px solid var(--nova-accent) !important;
      outline-offset: 4px !important;
      background: rgba(47,129,247,0.05);
      border-radius: 2px;
    }
    .nova-inline-editing:focus { outline: 2px solid var(--nova-accent) !important; }
    [data-nova-module]:hover { outline: 2px dashed rgba(47,129,247,0.5); outline-offset: -2px; z-index: 2; }
    [data-nova-module].nova-selected { outline: 2px solid var(--nova-accent); outline-offset: -2px; z-index: 2; }
    /* Ensure clicks reach the module even with absolute overlays inside */
    [data-nova-module] > .absolute, [data-nova-module] > div[class*="absolute"] { pointer-events: none; }
    [data-nova-module]::after {
      content: attr(data-nova-component);
      position: absolute; top: 4px; right: 4px; z-index: 100;
      background: var(--nova-accent); color: #fff; font: 600 11px/1 'DM Sans', sans-serif;
      padding: 3px 8px; border-radius: 4px; opacity: 0; transition: opacity 0.15s;
      pointer-events: none;
    }
    [data-nova-module]:hover::after, [data-nova-module].nova-selected::after { opacity: 1; }

    /* -- Nova element highlight on slot selection -- */
    [data-nova-el].nova-el-active { outline: 2px solid var(--nova-teal) !important; outline-offset: 2px; }
    [data-nova-el].nova-el-hover { outline: 2px dashed var(--nova-accent) !important; outline-offset: 2px; }

    /* ═══ TOOLBAR ═══ */
    .nova-toolbar {
      position: fixed; top: 0; left: 0; right: 0; height: var(--toolbar-h); z-index: 100000;
      background: var(--nova-surface); border-bottom: 1px solid var(--nova-border);
      display: flex; align-items: center; padding: 0 12px; gap: 8px;
      font-family: 'DM Sans', sans-serif;
    }
    .nova-toolbar-logo { font-size: 15px; font-weight: 700; color: var(--nova-accent); letter-spacing: -0.3px; }
    .nova-toolbar-sep { width: 1px; height: 18px; background: var(--nova-border); }
    .nova-toolbar-btn {
      background: none; border: 1px solid var(--nova-border); border-radius: var(--radius);
      color: var(--nova-text-muted); font-size: 12px; padding: 4px 10px; cursor: pointer;
      text-decoration: none; transition: all 0.15s; font-family: inherit;
      white-space: nowrap; display: flex; align-items: center; gap: 4px;
    }
    .nova-toolbar-btn:hover { border-color: var(--nova-accent); color: var(--nova-text); }
    .nova-device-btn { opacity: 0.4; padding: 4px 7px; }
    .nova-device-btn:hover { opacity: 0.7; }
    .nova-device-btn.active { opacity: 1; background: rgba(255,255,255,0.06); border-color: var(--nova-accent); }
    #nova-status-toggle[data-status="publish"] { background: rgba(63,185,80,0.15); border-color: rgba(63,185,80,0.4); color: var(--nova-green); }
    #nova-status-toggle[data-status="draft"]   { background: rgba(210,153,34,0.15); border-color: rgba(210,153,34,0.4); color: var(--nova-orange); }
    #nova-status-toggle[data-status="private"] { background: rgba(248,81,73,0.15);  border-color: rgba(248,81,73,0.4);  color: var(--nova-red); }
    .nova-toolbar-spacer { flex: 1; }
    .nova-toolbar-user {
      font-size: 12px; color: var(--nova-text-muted); display: flex; align-items: center; gap: 6px;
    }
    .nova-toolbar-user strong { color: var(--nova-text); }
    .nova-toolbar-role {
      font-size: 9px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.5px; padding: 2px 7px; border-radius: 4px;
      background: var(--nova-accent-dim); color: var(--nova-accent);
    }

    /* ═══ BREADCRUMB ═══ */
    .nova-breadcrumb {
      position: fixed; top: var(--toolbar-h); left: 0; right: var(--sidebar-w);
      height: var(--breadcrumb-h); background: var(--nova-surface2);
      border-bottom: 1px solid var(--nova-border);
      display: flex; align-items: center; padding: 0 16px;
      font-size: 11px; color: var(--nova-text-dim); z-index: 99;
    }
    .nova-breadcrumb .bc-sep { margin: 0 6px; }
    .nova-breadcrumb .bc-active { color: var(--nova-teal); font-weight: 600; }
    .nova-breadcrumb .bc-page { color: var(--nova-text-muted); }

    /* ═══ ADJUST PAGE LAYOUT ═══ */
    body { padding-top: calc(var(--toolbar-h) + var(--breadcrumb-h)); padding-right: var(--sidebar-w); }
    body.nova-collapsed { padding-right: 40px; }
    .glass-nav { top: calc(var(--toolbar-h) + var(--breadcrumb-h)) !important; }

    /* ═══ SIDEBAR ═══ */
    .nova-sidebar {
      position: fixed; top: var(--toolbar-h); right: 0; bottom: 0;
      width: var(--sidebar-w); background: var(--nova-surface);
      border-left: 1px solid var(--nova-border);
      display: flex; flex-direction: column; z-index: 99999;
      font-family: 'DM Sans', -apple-system, sans-serif; font-size: 13px;
      box-shadow: -4px 0 24px rgba(0,0,0,0.3); transition: transform 0.3s;
    }
    .nova-sidebar.collapsed { transform: translateX(calc(var(--sidebar-w) - 40px)); }

    /* Floating collapse toggle — sits at the left edge of the sidebar
       and wanders with it. Always visible regardless of collapse state. */
    .nova-sidebar-toggle {
      position: fixed;
      top: calc(var(--toolbar-h) + var(--breadcrumb-h) + 8px);
      right: calc(var(--sidebar-w) - 14px);
      z-index: 100000;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--nova-accent);
      color: #fff;
      border: 2px solid var(--nova-bg);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 2px 8px rgba(0,0,0,0.4);
      transition: right 0.3s, transform 0.3s;
      padding: 0;
    }
    .nova-sidebar-toggle:hover { background: var(--nova-accent-hover); transform: scale(1.1); }
    .nova-sidebar-toggle-icon {
      font-size: 18px; font-weight: 700; line-height: 1;
      transition: transform 0.3s;
      display: block;
    }
    /* Collapsed state: toggle button stays near right edge */
    body.nova-collapsed .nova-sidebar-toggle {
      right: 12px;
    }
    body.nova-collapsed .nova-sidebar-toggle-icon {
      transform: rotate(180deg);
    }
    .nova-sidebar-header {
      display: flex; justify-content: space-between; align-items: center;
      padding: 8px 14px; border-bottom: 1px solid var(--nova-border);
    }
    .nova-sidebar-title { color: var(--nova-accent); font-weight: 700; font-size: 14px; }
    .nova-sidebar-header-tabs { padding: 0; gap: 0; }
    .nova-sidebar-tab {
      flex: 1; padding: 12px 14px;
      background: transparent; border: none; border-bottom: 2px solid transparent;
      color: var(--nova-text-muted); cursor: pointer;
      font-weight: 700; font-size: 13px; font-family: inherit;
      transition: color 0.15s, border-color 0.15s;
    }
    .nova-sidebar-tab.active { color: var(--nova-accent); border-bottom-color: var(--nova-accent); }
    .nova-sidebar-tab:hover:not(.active) { color: var(--nova-text); }

    /* ═══ MODULE ADD BAR + PICKER ═══ */
    .nova-module-add-bar { padding: 10px 12px; border-bottom: 1px solid var(--nova-border); }
    .nova-module-picker {
      background: var(--nova-surface);
      border: 1px solid var(--nova-border);
      border-radius: 12px;
      width: min(720px, 92vw);
      max-height: 82vh;
      display: flex; flex-direction: column;
      box-shadow: 0 24px 80px rgba(0,0,0,0.6);
      overflow: hidden;
    }
    .nova-module-picker-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 18px;
      border-bottom: 1px solid var(--nova-border);
      font-weight: 700; color: var(--nova-text); font-size: 15px;
    }
    .nova-module-picker-search {
      margin: 12px 18px 0;
      padding: 9px 12px;
      background: var(--nova-bg);
      border: 1px solid var(--nova-border);
      border-radius: 8px;
      color: var(--nova-text);
      font-family: inherit; font-size: 13px;
    }
    .nova-module-picker-search:focus { outline: none; border-color: var(--nova-accent); }
    .nova-module-picker-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px;
      padding: 14px 18px 18px;
      overflow-y: auto;
    }
    .nova-module-picker-item {
      background: var(--nova-surface2);
      border: 1px solid var(--nova-border);
      border-radius: 8px;
      padding: 14px 12px;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s, transform 0.15s;
      display: flex; flex-direction: column; gap: 4px;
    }
    .nova-module-picker-item:hover {
      border-color: var(--nova-accent);
      background: var(--nova-accent-dim);
      transform: translateY(-1px);
    }
    .nova-module-picker-item.hidden { display: none; }
    .nova-module-picker-name {
      font-weight: 700; color: var(--nova-text); font-size: 13px;
    }
    .nova-module-picker-group {
      font-size: 10px; color: var(--nova-text-muted);
      text-transform: uppercase; letter-spacing: 0.05em;
    }

    /* ═══ PAGE-LEVEL AI PANEL ═══ */
    .nova-page-ai {
      display: flex; flex-direction: column; flex: 1;
      overflow: hidden; padding: 12px;
    }
    .nova-page-ai-intro {
      font-size: 12px; color: var(--nova-text-muted);
      padding: 10px 12px; margin-bottom: 10px;
      background: var(--nova-accent-dim);
      border: 1px solid var(--nova-accent-dim);
      border-radius: 8px; line-height: 1.5;
    }
    .nova-page-ai-msgs {
      flex: 1; overflow-y: auto; margin-bottom: 10px;
      display: flex; flex-direction: column; gap: 10px;
    }
    .nova-page-ai-msg {
      padding: 10px 12px; border-radius: 8px; font-size: 12px; line-height: 1.55;
    }
    .nova-page-ai-msg.user {
      background: var(--nova-accent-dim); color: var(--nova-text);
      align-self: flex-end; max-width: 85%;
    }
    .nova-page-ai-msg.ai {
      background: var(--nova-surface2); color: var(--nova-text);
      border: 1px solid var(--nova-border);
    }
    .nova-page-ai-msg.action {
      background: rgba(63,185,80,0.1); color: var(--nova-green);
      border: 1px solid rgba(63,185,80,0.2);
      font-family: monospace; font-size: 11px;
    }
    .nova-page-ai-msg.error {
      background: rgba(248,81,73,0.1); color: var(--nova-red);
      border: 1px solid rgba(248,81,73,0.2);
    }
    .nova-page-ai-input-bar {
      display: flex; flex-direction: column; gap: 8px;
    }
    #nova-page-ai-input {
      width: 100%; padding: 10px 12px;
      background: var(--nova-surface2);
      border: 1px solid var(--nova-border);
      border-radius: 8px;
      color: var(--nova-text);
      font-size: 13px; font-family: inherit;
      resize: vertical;
    }
    #nova-page-ai-input:focus { outline: none; border-color: var(--nova-accent); }

    /* ═══ MODULE LIST ═══ */
    #nova-module-list-wrap { flex: 1; overflow-y: auto; }
    #nova-module-editor-wrap { display: flex; flex-direction: column; flex: 1; overflow: hidden; }
    .nova-module-list { padding: 8px 10px; }
    .nova-module-item {
      padding: 8px 10px; background: rgba(255,255,255,0.03);
      border: 1px solid rgba(48,54,61,0.5); border-radius: 8px;
      margin-bottom: 4px; cursor: pointer; transition: all 0.15s;
      display: flex; align-items: center; gap: 8px;
    }
    .nova-module-item:hover { border-color: var(--nova-accent); background: var(--nova-accent-dim); }
    .nova-module-icon {
      width: 28px; height: 28px; border-radius: 6px;
      background: var(--nova-accent-dim); color: var(--nova-accent);
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; flex-shrink: 0;
    }
    .nova-module-info { flex: 1; min-width: 0; }
    .nova-module-name {
      font-size: 12px; font-weight: 600; color: var(--nova-text);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .nova-module-type {
      font-size: 10px; font-family: 'JetBrains Mono', monospace; color: var(--nova-text-dim);
    }
    .nova-drag-handle {
      width: 18px; cursor: grab; color: var(--nova-text-dim); font-size: 13px;
      text-align: center; flex-shrink: 0; opacity: 0.4; transition: opacity 0.15s;
    }
    .nova-module-item:hover .nova-drag-handle { opacity: 1; }
    .nova-module-item.sortable-ghost { opacity: 0.3; border-color: var(--nova-accent); }
    .nova-module-item.sortable-chosen { box-shadow: 0 4px 20px rgba(47,129,247,0.2); }
    .nova-module-actions {
      display: flex; gap: 2px; margin-left: auto; flex-shrink: 0;
    }
    .nova-module-actions button {
      background: none; border: 1px solid var(--nova-border); border-radius: 4px;
      color: var(--nova-text-dim); cursor: pointer; width: 22px; height: 22px; font-size: 10px;
      display: flex; align-items: center; justify-content: center; transition: all 0.15s;
    }
    .nova-module-actions button:hover { border-color: rgba(255,255,255,0.15); color: var(--nova-text); }
    .nova-module-actions .nova-del-btn:hover { color: var(--nova-red); border-color: rgba(248,81,73,0.3); }

    /* ═══ BACK BAR ═══ */
    .nova-back-bar {
      display: flex; align-items: center; gap: 8px;
      padding: 8px 14px; border-bottom: 1px solid var(--nova-border);
    }
    .nova-back-btn {
      background: none; border: 1px solid var(--nova-border); border-radius: var(--radius);
      color: var(--nova-text-muted); font-size: 12px; padding: 4px 10px; cursor: pointer;
      font-family: inherit; transition: all 0.15s;
    }
    .nova-back-btn:hover { border-color: var(--nova-accent); color: var(--nova-text); }
    .nova-editing-label {
      font-size: 11px; font-weight: 600; color: var(--nova-accent);
      background: var(--nova-accent-dim); padding: 2px 8px; border-radius: 4px;
    }

    /* ═══ LANGUAGE BAR ═══ */
    .nova-lang-bar {
      display: flex; padding: 8px 12px; gap: 4px;
      border-bottom: 1px solid var(--nova-border);
    }
    .nova-lang-btn {
      flex: 1; padding: 5px; text-align: center; font-size: 11px; font-weight: 600;
      background: none; border: 1px solid var(--nova-border); color: var(--nova-text-muted);
      border-radius: var(--radius); cursor: pointer; transition: all 0.15s;
    }
    .nova-lang-btn:hover { color: var(--nova-text); background: rgba(255,255,255,0.03); }
    .nova-lang-btn.active { background: var(--nova-accent); color: #fff; border-color: var(--nova-accent); }

    /* ═══ SLOT MAP ═══ */
    .nova-slot-map {
      padding: 8px 12px; border-bottom: 1px solid var(--nova-border);
      max-height: 160px; overflow-y: auto;
    }
    .nova-slot-map-title {
      font-size: 10px; font-weight: 600; color: var(--nova-text-dim);
      text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;
    }
    .nova-slot-item {
      display: flex; align-items: center; gap: 8px;
      padding: 4px 8px; border-radius: 4px; cursor: pointer;
      font-size: 11px; color: var(--nova-text-muted);
      border: 1px dashed transparent; margin-bottom: 2px; transition: all 0.12s;
    }
    .nova-slot-item:hover { background: var(--nova-accent-dim); color: var(--nova-text); border-color: var(--nova-accent); }
    .nova-slot-item.active { background: rgba(57,210,192,0.1); color: var(--nova-teal); border-color: var(--nova-teal); font-weight: 600; }
    .nova-slot-item .slot-tag { font-size: 9px; color: var(--nova-text-dim); font-family: monospace; margin-left: auto; }
    .nova-slot-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
    .nova-slot-dot.ok { background: var(--nova-green); }
    .nova-slot-dot.warn { background: var(--nova-orange); }
    .nova-slot-dot.empty { background: var(--nova-text-dim); }

    /* ═══ TABS ═══ */
    .nova-tabs {
      display: flex; border-bottom: 1px solid var(--nova-border); flex-shrink: 0;
    }
    .nova-tab {
      flex: 1; padding: 8px; text-align: center; font-size: 12px; font-weight: 600;
      color: var(--nova-text-dim); background: none; border: none; cursor: pointer;
      border-bottom: 2px solid transparent; transition: all 0.15s;
    }
    .nova-tab.active { color: var(--nova-accent); border-bottom-color: var(--nova-accent); }
    .nova-tab:hover { color: var(--nova-text-muted); }

    /* ═══ TAB PANELS ═══ */
    .nova-tab-panel { flex: 1; overflow-y: auto; padding: 0 16px 16px; }
    .nova-tab-panel.nova-ai-panel { display: flex; flex-direction: column; overflow: hidden; }
    .nova-hint { color: var(--nova-text-dim); font-size: 13px; text-align: center; padding: 40px 20px; }

    /* ═══ CONTENT FIELDS ═══ */
    .nova-fld {
      padding: 10px 14px; border-bottom: 1px solid rgba(48,54,61,0.5);
      transition: background 0.15s;
    }
    .nova-fld:hover { background: rgba(255,255,255,0.02); }
    .nova-fld.active { background: rgba(57,210,192,0.05); border-left: 2px solid var(--nova-teal); }
    .nova-fld-label {
      font-size: 10px; font-weight: 600; color: var(--nova-text-dim);
      text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 5px;
      display: flex; align-items: center; gap: 4px;
    }
    .nova-fld input[type="text"], .nova-fld textarea, .nova-fld select {
      width: 100%; background: var(--nova-bg); border: 1px solid var(--nova-border);
      border-radius: var(--radius); color: var(--nova-text); padding: 7px 10px;
      font-size: 13px; font-family: inherit;
    }
    .nova-fld input:focus, .nova-fld textarea:focus { border-color: var(--nova-accent); outline: none; }
    .nova-fld textarea { resize: vertical; min-height: 50px; }

    /* ═══ RICH TEXT TOOLBAR ═══ */
    .nova-rt-bar {
      display: flex; gap: 1px; padding: 4px 6px; background: var(--nova-bg);
      border: 1px solid var(--nova-border); border-radius: var(--radius) var(--radius) 0 0;
      flex-wrap: wrap; align-items: center;
    }
    .nova-rt-bar button {
      background: none; border: 1px solid transparent; color: var(--nova-text-muted);
      width: 26px; height: 26px; border-radius: 4px; cursor: pointer;
      font-size: 11px; display: flex; align-items: center; justify-content: center;
    }
    .nova-rt-bar button:hover { background: rgba(255,255,255,0.05); color: var(--nova-text); }
    .nova-rt-bar button.active { background: var(--nova-accent-dim); color: var(--nova-accent); border-color: rgba(47,129,247,0.3); }
    .nova-rt-sep { width: 1px; height: 18px; background: var(--nova-border); margin: 0 3px; }
    .nova-rt-colors { display: flex; gap: 3px; align-items: center; margin-left: 4px; }
    .nova-rt-color {
      width: 16px; height: 16px; border-radius: 50%; border: 2px solid var(--nova-border);
      cursor: pointer; transition: border-color 0.15s;
    }
    .nova-rt-color.active { border-color: var(--nova-accent); }
    .nova-rt-color.custom { background: conic-gradient(red,yellow,lime,cyan,blue,magenta,red); }
    .nova-rt-edit {
      background: var(--nova-bg); border: 1px solid var(--nova-border); border-top: none;
      border-radius: 0 0 var(--radius) var(--radius);
      padding: 10px; min-height: 50px; color: var(--nova-text); font-size: 14px; line-height: 1.5;
    }
    .nova-rt-edit .tiptap { outline: none; min-height: 40px; }
    .nova-rt-edit .tiptap p { margin: 0 0 4px; }
    .nova-rt-edit .tiptap:focus { outline: none; }
    /* Make color-marked text clearly visible in the sidebar editor.
       Tiptap renders Color marks as <span style="color: …">. The
       inline style alone is hard to distinguish from white on dark bg,
       so we add an underline + slightly brighter rendering. */
    .nova-rt-edit .tiptap span[style*="color"] {
      text-decoration: underline;
      text-decoration-color: currentColor;
      text-underline-offset: 3px;
      filter: brightness(1.2);
    }

    /* ═══ INLINE TIPTAP PREVIEW FIX ═══ */
    /* When Tiptap writes back to DOM via onUpdate, it wraps content in
       <p> tags which break the original element's font/size/color.
       Force ProseMirror and its <p> children to inherit all styles from
       the parent [data-nova-el] element so the preview looks identical
       to the production rendering during live editing. */
    [data-nova-el] > .ProseMirror,
    [data-nova-el] > .ProseMirror > p,
    [data-nova-el] > .ProseMirror > div,
    [data-nova-el] .tiptap,
    [data-nova-el] .tiptap > p,
    [data-nova-el] .tiptap > div {
      font: inherit !important;
      color: inherit !important;
      letter-spacing: inherit !important;
      text-transform: inherit !important;
      margin: 0 !important;
      padding: 0 !important;
      line-height: inherit !important;
    }
    /* Hero-highlight (rendered on the preview page) — force brand
       teal so users always see the final look. Does NOT touch
       Tiptap-generated color-spans in the editor, so the color
       palette still works for users who want non-brand accents. */
    .ProseMirror [data-nova-el="hero-highlight"] {
      color: var(--color-brand-400, #2f81f7) !important;
    }

    /* ═══ INLINE LINK ═══ */
    .nova-link-icon { cursor: pointer; font-size: 12px; opacity: 0.5; transition: opacity 0.15s; }
    .nova-link-icon:hover { opacity: 1; }
    .nova-fld-link-display {
      font-size: 10px; color: var(--nova-accent); font-family: monospace;
      margin-top: 3px; opacity: 0.7;
    }

    /* ═══ STYLE TAB ═══ */
    .nova-style-group {
      margin: 8px 12px; border: 1px solid rgba(48,54,61,0.5); border-radius: var(--radius);
    }
    .nova-style-group-header {
      padding: 8px 10px; display: flex; justify-content: space-between; align-items: center;
      cursor: pointer; font-size: 11px; font-weight: 600; color: var(--nova-text-muted);
    }
    .nova-style-group-header:hover { background: rgba(255,255,255,0.02); }
    .nova-style-group-header .el-tag {
      font-size: 10px; color: var(--nova-text-dim); font-family: monospace;
    }
    .nova-style-group-body { padding: 8px 10px; border-top: 1px solid rgba(48,54,61,0.5); }
    .nova-style-group-focused { border: 1px solid var(--nova-accent); box-shadow: 0 0 0 2px var(--nova-accent-dim); }
    .nova-style-row { display: flex; gap: 6px; align-items: center; margin-bottom: 6px; }
    .nova-style-row label { font-size: 10px; color: var(--nova-text-dim); width: 70px; flex-shrink: 0; }
    .nova-style-row input[type="color"] { width: 24px; height: 24px; border: none; border-radius: 4px; cursor: pointer; padding: 0; }
    .nova-style-row input[type="text"] {
      flex: 1; background: var(--nova-bg); border: 1px solid var(--nova-border); border-radius: 4px;
      color: var(--nova-text-muted); padding: 4px 8px; font-size: 11px;
    }
    .nova-style-row input[type="text"]:focus { border-color: var(--nova-accent); outline: none; }
    .nova-style-row input[type="range"] { flex: 1; accent-color: var(--nova-accent); }
    .nova-style-row select {
      flex: 1; background: var(--nova-bg); border: 1px solid var(--nova-border); border-radius: 4px;
      color: var(--nova-text-muted); padding: 4px 8px; font-size: 11px;
    }

    /* Spacing box model */
    .nova-spacing-box { position: relative; margin: 8px auto; width: 200px; }
    .nova-spacing-margin {
      border: 2px dashed var(--nova-orange); border-radius: 8px; padding: 16px; position: relative;
    }
    .nova-spacing-margin::before {
      content: 'margin'; position: absolute; top: -9px; left: 10px;
      font-size: 9px; color: var(--nova-orange); background: var(--nova-surface); padding: 0 4px;
    }
    .nova-spacing-padding {
      border: 2px dashed var(--nova-green); border-radius: 6px; padding: 12px; position: relative;
    }
    .nova-spacing-padding::before {
      content: 'padding'; position: absolute; top: -9px; left: 10px;
      font-size: 9px; color: var(--nova-green); background: var(--nova-surface); padding: 0 4px;
    }
    .nova-spacing-content {
      background: var(--nova-accent-dim); border-radius: 4px; padding: 8px;
      text-align: center; font-size: 10px; color: var(--nova-accent); font-weight: 600;
    }
    .nova-spacing-val { position: absolute; font-size: 10px; font-family: monospace; }
    .nova-spacing-val.top { top: 2px; left: 50%; transform: translateX(-50%); }
    .nova-spacing-val.bottom { bottom: 2px; left: 50%; transform: translateX(-50%); }
    .nova-spacing-val.left { left: 4px; top: 50%; transform: translateY(-50%); }
    .nova-spacing-val.right { right: 4px; top: 50%; transform: translateY(-50%); }
    .nova-sp-m { color: var(--nova-orange); }
    .nova-sp-p { color: var(--nova-green); }

    /* Design tokens */
    .nova-tokens { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; padding: 8px 10px; }
    .nova-token { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--nova-text-muted); }
    .nova-token-swatch {
      width: 20px; height: 20px; border-radius: 4px; border: 1px solid var(--nova-border); flex-shrink: 0;
    }

    /* Image preview */
    .nova-img-preview {
      width: 100%; height: 48px; object-fit: cover; border-radius: 4px;
      margin-bottom: 4px; border: 1px solid var(--nova-border);
    }

    /* ═══ AI TAB ═══ */
    .nova-ai-quick {
      display: flex; flex-wrap: wrap; gap: 4px;
      padding: 10px 14px; border-bottom: 1px solid var(--nova-border); flex-shrink: 0;
    }
    .nova-ai-quick-btn {
      background: var(--nova-surface2); border: 1px solid var(--nova-border);
      color: var(--nova-text-muted); padding: 4px 10px; border-radius: 20px;
      font-size: 11px; cursor: pointer; transition: all 0.15s;
    }
    .nova-ai-quick-btn:hover { border-color: var(--nova-accent); color: var(--nova-text); background: var(--nova-accent-dim); }
    .nova-ai-msgs { flex: 1; overflow-y: auto; padding: 12px 14px; }
    .nova-ai-msg { margin-bottom: 12px; }
    .nova-ai-msg-who { font-size: 10px; font-weight: 600; color: var(--nova-text-dim); margin-bottom: 4px; }
    .nova-ai-msg-body {
      padding: 10px; border-radius: var(--radius); font-size: 13px; line-height: 1.5;
    }
    .nova-ai-msg.user .nova-ai-msg-body { background: var(--nova-surface2); border: 1px solid var(--nova-border); color: var(--nova-text); }
    .nova-ai-msg.ai .nova-ai-msg-body { background: var(--nova-accent-dim); border: 1px solid rgba(47,129,247,0.2); }
    .nova-ai-diff { margin: 8px 0; font-size: 12px; }
    .nova-ai-diff-old { color: var(--nova-red); text-decoration: line-through; opacity: 0.6; }
    .nova-ai-diff-new { color: var(--nova-green); font-weight: 600; }
    .nova-ai-actions { display: flex; gap: 4px; margin-top: 8px; }
    .nova-ai-action {
      padding: 4px 10px; border-radius: var(--radius); font-size: 11px;
      cursor: pointer; border: 1px solid; font-weight: 500;
    }
    .nova-ai-action.primary { background: var(--nova-accent); color: #fff; border-color: var(--nova-accent); }
    .nova-ai-action.secondary { background: none; color: var(--nova-text-muted); border-color: var(--nova-border); }
    .nova-ai-input-bar {
      padding: 10px 14px; border-top: 1px solid var(--nova-border);
      display: flex; gap: 6px; flex-shrink: 0;
    }
    .nova-ai-input-bar input {
      flex: 1; background: var(--nova-bg); border: 1px solid var(--nova-border);
      border-radius: 8px; color: var(--nova-text); padding: 8px 12px; font-size: 13px;
    }
    .nova-ai-input-bar input:focus { border-color: var(--nova-accent); outline: none; }
    .nova-ai-input-bar button {
      background: var(--nova-accent); border: none; color: #fff; border-radius: 8px;
      padding: 8px 14px; cursor: pointer; font-size: 14px;
    }

    /* ═══ SAVE BAR ═══ */
    .nova-save-bar {
      padding: 8px 14px; border-top: 1px solid var(--nova-border);
      display: flex; gap: 8px; flex-shrink: 0;
    }
    .nova-btn-save {
      flex: 1; padding: 8px; background: var(--nova-accent); color: #fff; border: none;
      border-radius: var(--radius); font-size: 13px; font-weight: 600; cursor: pointer;
      position: relative;
      transition: background 0.15s, box-shadow 0.15s;
    }
    .nova-btn-save:hover { background: var(--nova-accent-hover); }
    .nova-btn-save:disabled { opacity: 0.5; cursor: wait; }
    /* Dirty state: pulsing glow on the save button. Body.nova-dirty is
       toggled whenever `dirty` flips true/false so multiple buttons
       (sidebar save, page-level save) all reflect the same state. */
    body.nova-dirty #nova-save {
      box-shadow: 0 0 0 2px var(--nova-accent-dim), 0 0 20px rgba(47,129,247,0.35);
      animation: nova-dirty-pulse 2.2s ease-in-out infinite;
    }
    body.nova-dirty #nova-save::before {
      content: '\u25CF'; margin-right: 6px; font-size: 10px;
    }
    @keyframes nova-dirty-pulse {
      0%, 100% { box-shadow: 0 0 0 2px var(--nova-accent-dim), 0 0 10px rgba(47,129,247,0.25); }
      50%      { box-shadow: 0 0 0 2px var(--nova-accent-dim), 0 0 24px rgba(47,129,247,0.55); }
    }

    /* Global toast container — stacks below the top toolbar */
    #nova-toast-stack {
      position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
      z-index: 100001; display: flex; flex-direction: column; gap: 8px;
      pointer-events: none;
    }
    .nova-toast {
      padding: 10px 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
      color: #fff; box-shadow: 0 8px 30px rgba(0,0,0,0.5);
      max-width: 420px; pointer-events: auto;
      transition: opacity 0.35s, transform 0.35s;
      display: flex; align-items: center; gap: 8px;
    }
    .nova-toast.ok    { background: rgba(63,185,80,0.95); }
    .nova-toast.err   { background: rgba(248,81,73,0.95); }
    .nova-toast.info  { background: rgba(47,129,247,0.95); }
    .nova-toast.warn  { background: rgba(210,153,34,0.95); }
    .nova-toast.fade  { opacity: 0; transform: translateY(10px); }

    /* ═══ MODULE MODE BAR (linked/detached toggle) ═══ */
    .nova-mode-bar {
      display: flex; align-items: center; gap: 6px;
      padding: 8px 14px;
      border-bottom: 1px solid var(--nova-border);
      background: var(--nova-surface2);
      font-size: 11px;
    }
    .nova-mode-label { color: var(--nova-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-right: 4px; }
    .nova-mode-btn {
      padding: 4px 10px;
      background: transparent;
      border: 1px solid var(--nova-border);
      color: var(--nova-text-muted);
      border-radius: 999px;
      cursor: pointer;
      font-size: 11px; font-weight: 600; font-family: inherit;
      transition: all 0.15s;
    }
    .nova-mode-btn:hover { color: var(--nova-text); border-color: var(--nova-text-muted); }
    .nova-mode-btn.active[data-mode="linked"] {
      background: rgba(47,129,247,0.15);
      border-color: var(--nova-accent);
      color: var(--nova-accent);
    }
    .nova-mode-btn.active[data-mode="detached"] {
      background: rgba(210,153,34,0.15);
      border-color: var(--nova-orange);
      color: var(--nova-orange);
    }
    .nova-btn-ghost {
      padding: 8px 14px; background: none; border: 1px solid var(--nova-border);
      color: var(--nova-text-muted); border-radius: var(--radius); font-size: 12px; cursor: pointer;
    }
    .nova-btn-ghost:hover { border-color: var(--nova-accent); color: var(--nova-text); }

    /* ═══ VERSIONS ═══ */
    .nova-versions {
      position: absolute; bottom: 50px; left: 14px; right: 14px;
      background: var(--nova-surface2); border: 1px solid var(--nova-border);
      border-radius: 10px; padding: 12px; max-height: 300px; overflow-y: auto;
      box-shadow: 0 -4px 16px rgba(0,0,0,0.3);
    }

    /* ═══ FIELD GROUPS (legacy compat) ═══ */
    .field-group { margin-bottom: 10px; }
    .field-label {
      display: block; font-size: 10px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.5px; color: var(--nova-text-dim); margin-bottom: 4px;
    }
    .field-input {
      width: 100%; padding: 7px 10px;
      background: var(--nova-bg); border: 1px solid var(--nova-border);
      border-radius: var(--radius); color: var(--nova-text); font-family: inherit; font-size: 13px;
      outline: none; transition: border-color 0.15s;
    }
    .field-input:focus { border-color: var(--nova-accent); }
    .field-input::placeholder { color: var(--nova-text-dim); }
    textarea.field-input { min-height: 50px; resize: vertical; line-height: 1.5; }

    /* ═══ LANG FIELDS (content tab) ═══ */
    .lang-fields { display: none; }
    .lang-fields.active { display: block; }
    .shared-divider {
      font-size: 10px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.8px; color: var(--nova-text-dim); margin: 16px 0 8px;
      padding-top: 12px; border-top: 1px solid var(--nova-border);
    }

    /* ═══ REPEATER CARDS ═══ */
    .rep-section { margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--nova-border); }
    .rep-section-title {
      font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.8px; color: var(--nova-text-dim); margin-bottom: 8px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .rep-add-btn {
      font-size: 11px; font-weight: 600; color: var(--nova-accent);
      background: var(--nova-accent-dim); border: 1px solid rgba(47,129,247,0.2);
      border-radius: 6px; padding: 4px 10px; cursor: pointer; transition: all 0.15s;
    }
    .rep-add-btn:hover { background: rgba(47,129,247,0.25); border-color: var(--nova-accent); }
    .rep-list { display: flex; flex-direction: column; gap: 4px; }
    .rep-card {
      background: rgba(255,255,255,0.04); border: 1px solid rgba(48,54,61,0.5);
      border-radius: 8px; overflow: hidden; transition: border-color 0.15s;
    }
    .rep-card:hover { border-color: rgba(255,255,255,0.12); }
    .rep-card.sortable-ghost { opacity: 0.3; border-color: var(--nova-accent); }
    .rep-card-header {
      display: flex; align-items: center; gap: 6px; padding: 8px 10px;
      cursor: pointer; user-select: none;
    }
    .rep-drag { cursor: grab; color: var(--nova-text-dim); font-size: 12px; flex-shrink: 0; opacity: 0.5; }
    .rep-card:hover .rep-drag { opacity: 1; }
    .rep-card-title {
      flex: 1; font-size: 12px; font-weight: 600; color: var(--nova-text-muted);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .rep-card-actions { display: flex; gap: 2px; flex-shrink: 0; }
    .rep-card-actions button {
      background: none; border: none; color: var(--nova-text-dim); cursor: pointer;
      font-size: 12px; width: 24px; height: 24px; display: flex;
      align-items: center; justify-content: center; border-radius: 4px;
      transition: all 0.15s;
    }
    .rep-card-actions button:hover { background: var(--nova-surface2); color: var(--nova-text); }
    .rep-card-actions .rep-del:hover { color: var(--nova-red); }
    .rep-card-body { display: none; padding: 0 10px 10px; }
    .rep-card.expanded .rep-card-body { display: block; }
    .rep-card.expanded .rep-chevron { transform: rotate(90deg); }
    .rep-chevron { font-size: 10px; color: var(--nova-text-dim); transition: transform 0.15s; flex-shrink: 0; }
    .rep-field { margin-bottom: 8px; }
    .rep-field-label {
      font-size: 10px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.4px; color: var(--nova-text-dim); margin-bottom: 2px;
    }
    .rep-field-input {
      width: 100%; padding: 6px 8px; background: var(--nova-bg);
      border: 1px solid var(--nova-border); border-radius: 6px; color: var(--nova-text);
      font-family: inherit; font-size: 12px; outline: none; transition: border-color 0.15s;
    }
    .rep-field-input:focus { border-color: var(--nova-accent); }
    textarea.rep-field-input { min-height: 48px; resize: vertical; line-height: 1.4; }
    .rep-lang-group { display: flex; gap: 4px; flex-direction: column; }
    .rep-lang-row { display: flex; align-items: center; gap: 4px; }
    .rep-lang-badge {
      font-size: 9px; font-weight: 700; color: var(--nova-text-dim);
      background: var(--nova-surface2); border-radius: 3px; padding: 1px 5px;
      flex-shrink: 0; width: 24px; text-align: center;
    }
    .rep-lang-row .rep-field-input { flex: 1; }

    /* ═══ TIPTAP (full richtext) ═══ */
    .tiptap-wrap { border: 1px solid var(--nova-border); border-radius: 8px; overflow: hidden; margin-top: 6px; }
    .tiptap-toolbar { display: flex; gap: 2px; padding: 4px 6px; background: rgba(255,255,255,0.03); border-bottom: 1px solid var(--nova-border); flex-wrap: wrap; }
    .tiptap-toolbar button { background: none; border: 1px solid transparent; border-radius: 4px; color: var(--nova-text-muted); font-size: 12px; padding: 4px 8px; cursor: pointer; font-family: inherit; min-width: 28px; }
    .tiptap-toolbar button:hover { background: rgba(255,255,255,0.06); color: var(--nova-text); border-color: var(--nova-border); }
    .tiptap-toolbar .sep { width: 1px; background: var(--nova-border); margin: 2px 4px; }
    .tiptap-editor { padding: 12px; min-height: 180px; max-height: 400px; overflow-y: auto; color: var(--nova-text); font-size: 14px; line-height: 1.7; }
    .tiptap-editor .tiptap { outline: none; }
    .tiptap-editor h2 { font-size: 20px; font-weight: 700; color: #fff; margin: 16px 0 8px; }
    .tiptap-editor h3 { font-size: 17px; font-weight: 700; color: #fff; margin: 14px 0 6px; }
    .tiptap-editor h4 { font-size: 15px; font-weight: 600; color: #fff; margin: 12px 0 4px; }
    .tiptap-editor p { margin: 0 0 8px; }
    .tiptap-editor a { color: var(--nova-accent); }
    .tiptap-editor ul, .tiptap-editor ol { padding-left: 20px; margin: 8px 0; }
    .tiptap-editor li { margin: 4px 0; }
    .tiptap-editor img { max-width: 100%; border-radius: 6px; margin: 8px 0; }
    .tiptap-editor blockquote { border-left: 3px solid var(--nova-accent); padding-left: 12px; margin: 12px 0; color: var(--nova-text-dim); }
    .tiptap-code { min-height: 180px; font-family: 'JetBrains Mono', monospace; font-size: 12px; line-height: 1.5; }

    /* ═══ NOVA FIELD ROW (for color+hex combo) ═══ */
    .nova-field { margin-bottom: 10px; }
    .nova-field-label {
      font-size: 10px; font-weight: 600; color: var(--nova-text-dim); text-transform: uppercase;
      letter-spacing: 0.05em; margin-bottom: 4px;
    }
    .nova-field-row { display: flex; gap: 8px; align-items: center; }
    .nova-field input[type="color"] {
      width: 32px; height: 32px; border: none; border-radius: 6px; cursor: pointer; padding: 0;
    }
    .nova-field input[type="text"], .nova-field textarea, .nova-field select {
      width: 100%; background: var(--nova-bg); border: 1px solid var(--nova-border);
      border-radius: var(--radius); color: var(--nova-text); font-size: 13px; padding: 7px 10px;
      font-family: inherit; transition: border-color 0.15s;
    }
    .nova-field input:focus, .nova-field textarea:focus { border-color: var(--nova-accent); outline: none; }

    /* ═══ LANG BAR (content tab, inline for fallback path) ═══ */
    .lang-bar {
      display: flex; gap: 0; padding: 8px 0; margin-bottom: 8px; flex-shrink: 0;
    }
    .lang-btn {
      padding: 6px 14px; font-size: 12px; font-weight: 600;
      color: var(--nova-text-dim); background: none;
      border: 1px solid var(--nova-border); cursor: pointer; transition: all 0.15s;
    }
    .lang-btn:first-child { border-radius: 6px 0 0 6px; }
    .lang-btn:last-child { border-radius: 0 6px 6px 0; }
    .lang-btn:not(:first-child) { border-left: none; }
    .lang-btn:hover { color: var(--nova-text-muted); background: rgba(255,255,255,0.04); }
    .lang-btn.active { background: var(--nova-accent); border-color: var(--nova-accent); color: #fff; }
    .lang-btn.active + .lang-btn { border-left-color: var(--nova-accent); }

    /* ═══ SCROLLBAR ═══ */
    .nova-sidebar ::-webkit-scrollbar { width: 6px; }
    .nova-sidebar ::-webkit-scrollbar-thumb { background: var(--nova-border); border-radius: 3px; }
  </style>

  <script id="nova-data-sections" type="application/json" set:html={sectionsJSON} />
  <script id="nova-data-registry" type="application/json" set:html={registryJSON} />
  <script id="nova-data-advanced" type="application/json" set:html={advancedJSON} />
  <script id="nova-data-meta" type="application/json" set:html={JSON.stringify({ pageId, slug, brandName: site.brandName, domain: site.domain })} />

  <script>
    const sections = JSON.parse(document.getElementById('nova-data-sections').textContent);
    const REGISTRY = JSON.parse(document.getElementById('nova-data-registry').textContent);
    const ADVANCED = JSON.parse(document.getElementById('nova-data-advanced').textContent);
    const _meta = JSON.parse(document.getElementById('nova-data-meta').textContent);
    const pageId = _meta.pageId;
    const slug = _meta.slug;
    const brandName = _meta.brandName || 'ZDS';
    const siteDomain = _meta.domain || 'zds.es';
    // Mark body for CSS scoping — GSAP disable and other
    // editor-specific overrides only apply with this class.
    document.body.classList.add('nova-editing');
    let selectedModuleIdx = -1;
    let selectedModuleEl = null;
    let selectedSlotName = null;
    // ═══ Toast Helper ══════════════════════════════════════════
    function novaToast(text, kind, ttl) {
      let stack = document.getElementById('nova-toast-stack');
      if (!stack) {
        stack = document.createElement('div');
        stack.id = 'nova-toast-stack';
        document.body.appendChild(stack);
      }
      const t = document.createElement('div');
      t.className = 'nova-toast ' + (kind || 'info');
      t.textContent = text;
      stack.appendChild(t);
      setTimeout(() => { t.classList.add('fade'); setTimeout(() => t.remove(), 400); }, ttl || 2800);
      return t;
    }

    // Poll the `dirty` flag every 250ms and mirror into a body class
    // so CSS can highlight dirty-aware UI (Save button glow etc.).
    // Cheaper than wrapping every `dirty = true` assignment in the
    // codebase and doesn't need Proxy/defineProperty gymnastics.
    setInterval(() => {
      const want = !!dirty;
      const have = document.body.classList.contains('nova-dirty');
      if (want !== have) document.body.classList.toggle('nova-dirty', want);
    }, 250);

    let dirty = false;
    // Default language follows the project's configured default; only the
    // project-supported locales are exposed to the editor UI.
    let currentLang = window.__novaProjectDefaultLocale || 'en';
    const LANGS = (window.__novaProjectLocales && window.__novaProjectLocales.length)
      ? window.__novaProjectLocales
      : [currentLang];
    const LANG_LABELS = { es: '\ud83c\uddea\ud83c\uddf8 ES', en: '\ud83c\uddec\ud83c\udde7 EN', de: '\ud83c\udde9\ud83c\uddea DE' };

    // Module icons
    const ICONS = { Hero: '\u2b50', LogoTicker: '\u267b', Stats: '\ud83d\udcca', ThreeColumns: '\u25a6', CTABand: '\ud83d\udce3', TeamSection: '\ud83d\udc65', AIShowcase: '\ud83e\udd16', ProcessSteps: '\u2699', FeatureList: '\ud83d\udccb', FeatureDetail: '\ud83d\udd0d', CardGrid: '\ud83c\udccf', Testimonials: '\ud83d\udcac', Timeline: '\ud83d\udcc5', Comparison: '\u2696', CaseStudy: '\ud83d\udcc8', ImageGallery: '\ud83d\uddbc', LogoGrid: '\ud83c\udfc6', PricingTable: '\ud83d\udcb0', NumbersBar: '\ud83d\udcca', RichText: '\ud83d\udcdd', ContentSection: '\ud83d\udcc4', TextBlock: '\u270d', CTAForm: '\ud83d\udcdd', FAQ: '\u2753', TeamGrid: '\ud83d\udc65', ContactForm: '\u2709', Quote: '\ud83d\udcac', TabbedContent: '\ud83d\udcce', MagazineCard: '\ud83d\udcf0', ProgressiveReveal: '\ud83d\udd0e', StickyTOC: '\ud83d\udcd1', ScrollCarousel: '\ud83c\udfa0', BeforeAfter: '\u2194', VideoEmbed: '\ud83c\udfa5' };
    let moduleSortableInstance = null;

    // Page tree uses curated SITE_TREE + dynamic WP data. See below.

    // ====== GLOBAL LANGUAGE BAR ======
    document.querySelectorAll('.nova-lang-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const lang = btn.dataset.lang;
        switchLang(lang);
        // Also update global bar
        document.querySelectorAll('.nova-lang-btn').forEach(b => b.classList.toggle('active', b.dataset.lang === lang));
      });
    });

    // ====== PERSIST + PREVIEW REFRESH HELPERS ======
    // Persist current sections to WP via Astro API (no UI feedback, used by auto-save)
    async function persistSections() {
      if (!pageId) return false;
      const updatedSections = sections.map(s => {
        // Preserve link/detach mode. Linked sections need module_id,
        // detached ones need data (the inline content).
        const mode = s.mode === 'linked' ? 'linked' : 'detached';
        const base = {
          id: s.id,
          type: s.component,
          mode,
          style: s.style && Object.keys(s.style).length ? s.style : undefined,
          visual_overrides: s.overrides || undefined,
        };
        if (mode === 'linked' && s.module_id) {
          return { ...base, module_id: s.module_id };
        }
        return { ...base, data: s.content };
      });
      try {
        const res = await fetch('/api/pages/' + pageId + '/sections', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sections: updatedSections }),
        });
        if (!res.ok) return false;
        // Server normalizes any fake 'new-...' ids → real integer ids.
        // Swap them into our local sections so subsequent saves reference
        // the real id.
        try {
          const data = await res.json();
          if (data && Array.isArray(data.sections)) {
            data.sections.forEach((returnedSec: { id?: unknown }, i: number) => {
              if (sections[i] && returnedSec && returnedSec.id !== undefined) {
                sections[i].id = returnedSec.id;
              }
            });
          }
        } catch {}
        return true;
      } catch {
        return false;
      }
    }

    // Refresh the currently-selected module in the preview by re-fetching the
    // editor page and swapping its rendered module DOM in place. Handles
    // repeater-triggered changes (add/delete/reorder/edit) where client-side
    // DOM patching is infeasible across 30+ module types.
    let refreshInFlight = false;
    async function refreshPreview() {
      if (refreshInFlight) return;
      refreshInFlight = true;
      try {
        const res = await fetch(window.location.pathname + '?_t=' + Date.now(), {
          cache: 'no-store',
          credentials: 'same-origin',
        });
        if (!res.ok) return;
        const html = await res.text();
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const newMain = doc.querySelector('main');
        const currentMain = document.querySelector('main');
        if (!newMain || !currentMain) return;
        // Only swap the module wrappers, keep Navigation/Footer/editor chrome intact
        const newMods = newMain.querySelectorAll('[data-nova-module]');
        const currentMods = currentMain.querySelectorAll('[data-nova-module]');
        if (newMods.length !== sections.length) {
          // Section count mismatch (after add/delete) — full main swap is safer
          currentMain.innerHTML = newMain.innerHTML;
        } else {
          newMods.forEach((newEl, i) => {
            if (currentMods[i]) currentMods[i].replaceWith(newEl);
          });
        }
        // Re-bind click handlers on the new module elements
        bindModuleClickHandlers();
        // Re-select the current module if one was open
        if (selectedModuleIdx >= 0) {
          const mods = document.querySelectorAll('[data-nova-module]');
          if (mods[selectedModuleIdx]) {
            mods[selectedModuleIdx].classList.add('nova-selected');
            selectedModuleEl = mods[selectedModuleIdx];
          }
        }
      } catch (e) {
        console.warn('refreshPreview failed:', e);
      } finally {
        refreshInFlight = false;
      }
    }

    // Debounced auto-save: triggered from repeater edits so user sees live updates
    let autoSaveTimer = null;
    // Every N-th autosave creates a revision checkpoint so users don't
    // lose undo-points even when they never hit the big Save button.
    let autoSaveCount = 0;
    const AUTOSAVE_REVISION_EVERY = 10;

    function scheduleAutoSaveRefresh() {
      if (autoSaveTimer) clearTimeout(autoSaveTimer);
      autoSaveTimer = setTimeout(async () => {
        autoSaveTimer = null;
        // Collect repeater data into the current section before saving
        if (selectedModuleIdx >= 0) {
          const section = sections[selectedModuleIdx];
          const updatedContent = JSON.parse(JSON.stringify(section.content || {}));
          collectRepeaterData(updatedContent);
          // LogoTicker now uses standard repeater collector
          section.content = updatedContent;
        }
        const saved = await persistSections();
        if (saved) {
          autoSaveCount++;
          // Checkpoint every Nth autosave so the version history has
          // usable restore points from editing sessions.
          if (autoSaveCount % AUTOSAVE_REVISION_EVERY === 0 && pageId) {
            try {
              await fetch('/api/revisions', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ pageId, label: 'Auto-Checkpoint #' + autoSaveCount }),
              });
            } catch {}
          }
          await refreshPreview();
        }
      }, 700);
    }

    // ====== PAGE SELECTOR (curated tree + dynamic WP data) ======
    // Curated site tree: semantic groups with icons.
    // WP pages are merged in for draft status + new pages not yet in tree.
    // Nested site tree matching the real navigation hierarchy.
    // depth 0 = top-level, children[] = nested under parent.
    const SITE_TREE = [
      { slug: 'homepage', label: 'Homepage' },
      { slug: 'servicios', label: 'Servicios', children: [
        { slug: 'servicios-seo', label: 'SEO', children: [
