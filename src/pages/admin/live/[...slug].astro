    // ====== STATUS TOGGLE (draft <-> publish) ======
    (function statusToggle() {
      const btn = document.getElementById('nova-status-toggle');
      if (!btn || !pageId) return;

      function paint(status) {
        btn.dataset.status = status;
        btn.textContent = status === 'publish' ? '\u25CF Live'
          : status === 'draft' ? '\u25CB Draft'
          : status === 'private' ? '\u25CF Privat'
          : '\u2026';
      }

      // Load current status on init
      fetch('/api/pages/' + pageId + '/status')
        .then(r => r.ok ? r.json() : null)
        .then(d => { if (d && d.status) paint(d.status); })
        .catch(() => {});

      function showToast(text, kind) {
        const t = document.createElement('div');
        t.style.cssText = 'position:fixed;bottom:20px;left:50%;transform:translateX(-50%);z-index:100001;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:600;background:' + (kind === 'error' ? 'rgba(248,81,73,0.95)' : 'rgba(63,185,80,0.95)') + ';color:#fff;box-shadow:0 8px 30px rgba(0,0,0,0.5);';
        t.textContent = text;
        document.body.appendChild(t);
        setTimeout(() => { t.style.transition = 'opacity 0.4s'; t.style.opacity = '0'; setTimeout(() => t.remove(), 400); }, 2500);
      }

      btn.addEventListener('click', async () => {
        const current = btn.dataset.status;
        const next = current === 'publish' ? 'draft' : 'publish';
        const prev = btn.textContent;
        btn.textContent = '\u2026';
        btn.disabled = true;
        try {
          const res = await fetch('/api/pages/' + pageId + '/status', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: next }),
          });
          if (res.ok) {
            const d = await res.json();
            paint(d.status);
            showToast(d.status === 'publish' ? 'Seite ist jetzt LIVE' : 'Seite als DRAFT gespeichert', 'ok');
          } else {
            btn.textContent = prev;
            const err = await res.text().catch(() => '');
            showToast('Status-Update fehlgeschlagen (' + res.status + ')', 'error');
            console.warn('Status update failed:', res.status, err);
          }
        } catch (err) {
          btn.textContent = prev;
          showToast('Netzwerkfehler beim Status-Update', 'error');
          console.warn('Status toggle error:', err);
        } finally {
          btn.disabled = false;
        }
      });
    })();

    // ====== SEO TOOLBAR DROPDOWN ======
    (function() {
      const btn = document.getElementById('nova-seo-btn');
