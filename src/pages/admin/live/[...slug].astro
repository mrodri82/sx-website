        ]},
        { slug: 'servicios-consultoria', label: 'Design & Consulting', children: [
          { slug: 'servicios-web-design', label: 'Web Design & Dev' },
          { slug: 'servicios-ux', label: 'UX & Usabilidad' },
          { slug: 'servicios-branding', label: 'Branding' },
          { slug: 'servicios-analytics', label: 'Analytics & Dashboards' },
          { slug: 'servicios-accesibilidad', label: 'Accesibilidad Web' },
          { slug: 'servicios-audits', label: 'Auditor\u00edas' },
          { slug: 'servicios-training', label: 'Formaci\u00f3n & Workshops' },
        ]},
        { slug: 'servicios-ai-visibility', label: 'AI Visibility' },
        { slug: 'servicios-herramientas', label: 'Custom Tools' },
      ]},
      { slug: 'b2-performance', label: 'B2 Performance', children: [
        { slug: 'b2-performance-seo', label: 'SEO & Content' },
        { slug: 'b2-performance-ppc', label: 'PPC & Paid Media' },
        { slug: 'b2-performance-social', label: 'Social & Strategy' },
      ]},
      { slug: 'sectores', label: 'Sectores', children: [
        { slug: 'sectores-turismo', label: 'Turismo' },
        { slug: 'sectores-retail', label: 'Retail' },
        { slug: 'sectores-tech', label: 'Tech' },
        { slug: 'sectores-industrial', label: 'Industrial' },
        { slug: 'sectores-pharma', label: 'Pharma' },
        { slug: 'sectores-shk', label: 'SHK' },
        { slug: 'sectores-electro', label: 'Electro' },
        { slug: 'sectores-fashion', label: 'Fashion' },
        { slug: 'sectores-food', label: 'Food' },
        { slug: 'sectores-adult', label: 'Adult' },
        { slug: 'sectores-dating', label: 'Dating' },
      ]},
      { slug: 'proyectos', label: 'Proyectos' },
      { slug: 'nosotros', label: 'Nosotros' },
      { slug: 'about-us', label: 'About Us' },
      { slug: 'contacto', label: 'Contacto' },
      { slug: 'insights', label: 'Insights / Blog' },
      { slug: 'recursos', label: 'Recursos' },
      { slug: 'glosario', label: 'Glosario' },
      { slug: 'ki-assistent', label: 'KI-Assistent' },
      { slug: 'products', label: 'Products' },
      { slug: 'seo-barcelona', label: 'SEO Barcelona' },
      { slug: 'seo-madrid', label: 'SEO Madrid' },
      { slug: 'seo-deutschland', label: 'SEO Deutschland' },
      { slug: '_legal', label: 'Legal', virtual: true, children: [
        { slug: 'aviso-legal', label: 'Aviso Legal' },
        { slug: 'privacidad', label: 'Privacidad' },
        { slug: 'cookies', label: 'Cookies' },
      ]},
    ];

    window._novaWpPages = {};  // slug → { status, id }
    window._novaWpPosts = [];  // blog posts
    window._novaWpGlossary = []; // que-es-* pages
    window._novaExpanded = new Set(); // which nodes are open (by slug)

    // Find which tree nodes need auto-expanding to show the current page
    function autoExpandPath(nodes, target) {
      for (const n of nodes) {
        if (n.slug === target) return true;
        if (n.children && autoExpandPath(n.children, target)) {
          window._novaExpanded.add(n.slug || n.label);
          return true;
        }
      }
      return false;
    }

    (async () => {
      try {
        const res = await fetch('/api/pages/list');
        const data = await res.json();
        if (data.groups) {
          data.groups.forEach(group => {
            if (group.type === 'post') {
              window._novaWpPosts = group.items;
            } else if (group.type === 'page') {
              group.items.forEach(p => {
                window._novaWpPages[p.slug] = p;
                if (p.slug.startsWith('que-es-') || p.slug.startsWith('que-son-')) {
                  window._novaWpGlossary.push(p);
                }
              });
            } else {
              group.items.forEach(p => { window._novaWpPages[p.slug] = p; });
            }
          });
        }
        autoExpandPath(SITE_TREE, slug === '' ? 'homepage' : slug);
        renderPageTree();
      } catch (e) { console.warn('Failed to load page list:', e); }
    })();

    function renderPageTree(filter) {
      const list = document.getElementById('nova-page-tree-list');
      if (!list) return;
      list.innerHTML = '';
      const f = (filter || '').toLowerCase();
      const isSearching = !!f;
      const rendered = new Set();

      // Does a node or any descendant match the filter?
      function matches(node) {
        if (!f) return true;
        if (node.label.toLowerCase().includes(f) || (node.slug || '').includes(f)) return true;
        return (node.children || []).some(matches);
      }

      // Exists in WP? Check pages, posts, and special slugs
      function exists(s) {
        if (!s) return false;
        return window._novaWpPages[s] || s === slug || s === 'homepage' || s.startsWith('_')
          || window._novaWpPosts.some(p => p.slug === s);
      }

      // Render a recursive tree node
      function renderNode(container, node, depth) {
        if (node.virtual && !node.children) return;
        if (!node.virtual && !exists(node.slug)) return;
        if (!matches(node)) return;

        const hasKids = node.children && node.children.length;
        const nodeKey = node.slug || node.label;
        const isCurrent = node.slug === slug || (slug === 'homepage' && node.slug === 'homepage');
        const wp = window._novaWpPages[node.slug];
        const isDraft = wp?.status === 'draft';
        rendered.add(node.slug);

        if (hasKids) {
          // Collapsible parent node
          const isOpen = isSearching || window._novaExpanded.has(nodeKey);
          const row = document.createElement('div');
          row.style.cssText = 'font-size:12px;font-weight:' + (depth < 2 ? '600' : '500') + ';padding:4px 8px;cursor:pointer;display:flex;align-items:center;gap:5px;border-radius:5px;transition:background 0.1s;user-select:none;color:var(--nova-text)';
          if (isCurrent) row.style.cssText += ';background:var(--nova-accent-dim);outline:1px solid rgba(47,129,247,0.15)';

          const arrow = '<span style="font-size:8px;width:10px;color:var(--nova-text-dim);flex-shrink:0">' + (isOpen ? '\u25BE' : '\u25B8') + '</span>';
          const dot = !node.virtual ? '<span style="width:5px;height:5px;border-radius:50%;background:' + (isDraft ? 'var(--nova-text-dim)' : 'var(--green, #4ade80)') + ';flex-shrink:0"></span>' : '';
          row.innerHTML = arrow + dot +
            '<span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + node.label + '</span>';

          row.addEventListener('mouseenter', () => { if (!isCurrent) row.style.background = 'rgba(255,255,255,0.03)'; });
          row.addEventListener('mouseleave', () => { if (!isCurrent) row.style.background = 'none'; });

          container.appendChild(row);

          const kids = document.createElement('div');
          kids.style.cssText = 'margin-left:12px;padding-left:10px;border-left:1px solid rgba(255,255,255,0.06)';

          function fillKids() {
            kids.innerHTML = '';
            node.children.forEach(c => renderNode(kids, c, depth + 1));
          }

          if (isOpen) fillKids();
          else kids.style.display = 'none';

          // Click: toggle expand. Double-click: navigate (if real page)
          row.addEventListener('click', (e) => {
            if (!node.virtual && !isCurrent && e.detail === 2) {
              window.location.href = '/admin/live/' + (node.slug === 'homepage' ? '' : node.slug);
              return;
            }
            const nowOpen = kids.style.display !== 'none';
            if (nowOpen) {
              kids.style.display = 'none';
              window._novaExpanded.delete(nodeKey);
            } else {
              fillKids();
              kids.style.display = '';
              window._novaExpanded.add(nodeKey);
            }
            row.firstChild.textContent = nowOpen ? '\u25B8' : '\u25BE';
          });

          container.appendChild(kids);
        } else if (!node.virtual) {
          // Leaf node
          const el = document.createElement('div');
          el.style.cssText = 'padding:4px 8px 4px 18px;cursor:pointer;color:var(--nova-text);font-size:12px;border-radius:5px;display:flex;align-items:center;gap:6px;transition:background 0.1s';
          if (isCurrent) el.style.cssText += ';background:var(--nova-accent-dim);outline:1px solid rgba(47,129,247,0.15)';
          const dotColor = isDraft ? 'var(--nova-text-dim)' : 'var(--green, #4ade80)';
          el.innerHTML =
            '<span style="width:5px;height:5px;border-radius:50%;background:' + dotColor + ';flex-shrink:0"></span>' +
            '<span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + node.label + '</span>' +
            (isDraft ? '<span style="font-size:8px;color:var(--nova-text-dim);text-transform:uppercase">draft</span>' : '');
          el.addEventListener('mouseenter', () => { if (!isCurrent) el.style.background = 'rgba(59,130,246,0.06)'; });
          el.addEventListener('mouseleave', () => { if (!isCurrent) el.style.background = 'none'; });
          el.addEventListener('click', () => {
            if (!isCurrent) window.location.href = '/admin/live/' + (node.slug === 'homepage' ? '' : node.slug);
          });
          container.appendChild(el);
        }
      }

      // 1. Render site tree
      SITE_TREE.forEach(n => renderNode(list, n, 0));

      // 2. Blog posts
      if (window._novaWpPosts.length) {
        const filtered = window._novaWpPosts.filter(p => !f || (p.title || p.slug).toLowerCase().includes(f));
        if (filtered.length) {
          renderNode(list, {
            slug: '_blog', label: 'Blog', virtual: true,
            children: filtered.map(p => ({ slug: p.slug, label: (p.title || p.slug).replace(/<[^>]+>/g, ''), _status: p.status }))
          }, 0);
          filtered.forEach(p => rendered.add(p.slug));
        }
      }

      // 3. Glosario
      if (window._novaWpGlossary.length) {
        const filtered = window._novaWpGlossary.filter(p => !f || (p.title || p.slug).toLowerCase().includes(f));
        if (filtered.length) {
          renderNode(list, {
            slug: '_glosario', label: 'Glosario (' + window._novaWpGlossary.length + ')', virtual: true,
            children: filtered.slice(0, 30).map(p => ({ slug: p.slug, label: (p.title || p.slug).replace(/<[^>]+>/g, '') }))
          }, 0);
          filtered.forEach(p => rendered.add(p.slug));
        }
      }

      // 4. Remaining uncategorized WP pages
      const extra = Object.values(window._novaWpPages).filter(p =>
        !rendered.has(p.slug) && (!f || (p.title || p.slug).toLowerCase().includes(f))
      );
      if (extra.length) {
        extra.sort((a, b) => (a.title || a.slug).localeCompare(b.title || b.slug));
        renderNode(list, {
          slug: '_weitere', label: 'Weitere (' + extra.length + ')', virtual: true,
          children: extra.slice(0, 30).map(p => ({ slug: p.slug, label: (p.title || p.slug).replace(/<[^>]+>/g, '') }))
        }, 0);
      }

      if (!list.children.length) {
        list.innerHTML = '<div style="padding:12px;color:var(--nova-text-dim);font-size:12px;text-align:center">Keine Seiten gefunden</div>';
      }
    }

    // Toggle page tree dropdown
    document.getElementById('nova-page-tree-btn')?.addEventListener('click', () => {
      const panel = document.getElementById('nova-page-tree-panel');
      const isOpen = panel.style.display !== 'none';
      panel.style.display = isOpen ? 'none' : '';
      if (!isOpen) {
        document.getElementById('nova-page-search').value = '';
        renderPageTree();
        document.getElementById('nova-page-search').focus();
      }
    });

    document.getElementById('nova-page-search')?.addEventListener('input', (e) => {
      renderPageTree(e.target.value);
    });

    document.addEventListener('click', (e) => {
      const panel = document.getElementById('nova-page-tree-panel');
      if (panel && panel.style.display !== 'none' && !e.target.closest('#nova-page-tree-btn') && !e.target.closest('#nova-page-tree-panel')) {
        panel.style.display = 'none';
      }
    });

    // Toolbar logout. nova_session is HttpOnly — it can only be cleared
    // server-side via Set-Cookie, so we POST /api/auth/logout and wait for
    // the response (which destroys the session and clears the cookie)
    // before redirecting. Otherwise the next request re-authenticates
    // from the still-valid cookie and the editor "logs itself back in".
    document.getElementById('nova-logout-btn')?.addEventListener('click', async () => {
      try { await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' }); } catch {}
      window.location.href = '/admin/login';
    });

    // ====== SELECT SLOT (bidirectional sync) ======
    function selectSlot(slotName) {
      selectedSlotName = slotName;
      if (!selectedModuleEl) return;

      // 1. Clear all highlights on page
      document.querySelectorAll('[data-nova-el]').forEach(el => el.classList.remove('nova-el-active', 'nova-el-hover'));

      // 2. Find the DOM element with this data-nova-el and highlight it
      const pageEl = selectedModuleEl.querySelector('[data-nova-el="' + slotName + '"]');
      if (pageEl) {
        pageEl.classList.add('nova-el-active');
        pageEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }

      // 3. Activate slot in map
      document.querySelectorAll('.nova-slot-item').forEach(s => s.classList.remove('active'));
      const mapItem = document.querySelector('.nova-slot-item[data-slot="' + slotName + '"]');
      if (mapItem) mapItem.classList.add('active');

      // 4. Activate field in content panel + scroll to it
      document.querySelectorAll('.nova-fld').forEach(f => f.classList.remove('active'));
      const fieldEl = document.querySelector('.nova-fld[data-slot="' + slotName + '"]');
      if (fieldEl) {
        fieldEl.classList.add('active');
        fieldEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }

      // 5. Update breadcrumb
      document.getElementById('bc-sep-field').style.display = '';
      document.getElementById('bc-field-name').style.display = '';
      document.getElementById('bc-field-name').textContent = slotName;

      // 6. If the Style tab is visible, focus the matching style group
      const styleTab = document.getElementById('nova-tab-style');
      if (styleTab && styleTab.style.display !== 'none') {
        focusStyleGroup(slotName);
      }
    }

    // Expand + scroll + highlight the style group for a given slot
    function focusStyleGroup(slotName) {
      document.querySelectorAll('.nova-style-group').forEach(g => {
        g.classList.remove('nova-style-group-focused');
      });
      const group = document.querySelector('.nova-style-group[data-slot-name="' + slotName + '"]');
      if (!group) return;
      const body = group.querySelector('.nova-style-group-body');
      if (body) body.style.display = '';
      group.classList.add('nova-style-group-focused');
      group.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // ====== SLOT MAP RENDERING ======
    function renderSlotMap(moduleEl, component) {
      const container = document.getElementById('nova-slot-map-items');
      const title = document.getElementById('nova-slot-map-title');
      container.innerHTML = '';
      title.textContent = 'Slot Map \u2014 ' + component;

      if (!moduleEl) return;
      const novaEls = moduleEl.querySelectorAll('[data-nova-el]');
      if (!novaEls.length) {
        container.innerHTML = '<div style="font-size:11px;color:var(--nova-text-dim);padding:4px 0">Keine Slots gefunden</div>';
        return;
      }

      // Track repeated slot names so we can number duplicates
      const nameCount = {};
      novaEls.forEach(el => {
        const n = el.dataset.novaEl;
        nameCount[n] = (nameCount[n] || 0) + 1;
      });
      const nameIdx = {};

      novaEls.forEach(el => {
        const name = el.dataset.novaEl;
        // Skip section wrappers — redundant since we're already inside the module
        if (name.endsWith('-section')) return;
        const tag = el.tagName.toLowerCase();
        const hasContent = (el.textContent || '').trim().length > 0 || el.innerHTML.trim().length > 0;

        // For repeated slots: show index + content preview
        nameIdx[name] = (nameIdx[name] || 0) + 1;
        const isRepeated = nameCount[name] > 1;
        const idx = nameIdx[name];
        const preview = (el.textContent || '').trim().substring(0, 25);
        const displayName = isRepeated
          ? name + ' <span style="color:var(--nova-accent);font-size:10px">#' + idx + '</span>' +
            (preview ? ' <span style="color:var(--nova-text-dim);font-size:10px;font-style:italic">' + preview + '</span>' : '')
          : name;

        const item = document.createElement('div');
        item.className = 'nova-slot-item' + (name === selectedSlotName ? ' active' : '');
        item.dataset.slot = name;
        item.innerHTML = '<span class="nova-slot-dot ' + (hasContent ? 'ok' : 'empty') + '"></span> ' +
          '<span>' + displayName + '</span>' +
          '<span class="slot-tag">' + tag + '</span>';

        item.addEventListener('click', () => selectSlot(name));

        // Hover sync: slot map -> page element
        item.addEventListener('mouseenter', () => {
          el.classList.add('nova-el-hover');
        });
        item.addEventListener('mouseleave', () => {
          el.classList.remove('nova-el-hover');
        });

        container.appendChild(item);
      });

      // Reverse: make page elements clickable to select slots
      novaEls.forEach(el => {
        el.style.cursor = 'pointer';
        el.addEventListener('click', (e) => {
          e.stopPropagation();
          selectSlot(el.dataset.novaEl);
        });
      });
    }

    // ====== MODULE LIST RENDERING ======
    function renderModuleList() {
      const list = document.getElementById('nova-module-list');
      if (!list) return;

      if (moduleSortableInstance) { moduleSortableInstance.destroy(); moduleSortableInstance = null; }

      list.innerHTML = sections.map((s, idx) => {
        const icon = ICONS[s.component] || '\u25a0';
        const name = s.content?.headline_es || s.content?.title_es || s.content?.headline || s.content?.title || s.component + ' ' + (idx + 1);
        return '<div class="nova-module-item" data-idx="' + idx + '">' +
          '<div class="nova-drag-handle">\u2630</div>' +
          '<div class="nova-module-icon">' + icon + '</div>' +
          '<div class="nova-module-info">' +
            '<div class="nova-module-name">' + name.replace(/<[^>]+>/g, '').substring(0, 35) + '</div>' +
            '<div class="nova-module-type">' + s.component + '</div>' +
          '</div>' +
          '<div class="nova-module-actions">' +
            '<button class="nova-dup-btn" data-dup-idx="' + idx + '" title="Duplizieren">&#x2398;</button>' +
            '<button class="nova-del-btn" data-del-idx="' + idx + '" title="L\u00f6schen">&times;</button>' +
          '</div>' +
        '</div>';
      }).join('');

      list.querySelectorAll('.nova-module-item').forEach(item => {
        item.addEventListener('click', (e) => {
          if (e.target.closest('.nova-drag-handle') || e.target.closest('.nova-dup-btn') || e.target.closest('.nova-del-btn')) return;
          const idx = parseInt(item.dataset.idx);
          openModuleFromList(idx);
        });
      });

      list.querySelectorAll('.nova-dup-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const idx = parseInt(btn.dataset.dupIdx);
          if (idx < 0 || idx >= sections.length) return;
          const clone = JSON.parse(JSON.stringify(sections[idx]));
          sections.splice(idx + 1, 0, clone);
          if (pageId) {
            await persistSections();
            await refreshPreview();
          }
          renderModuleList();
        });
      });

      list.querySelectorAll('.nova-del-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const idx = parseInt(btn.dataset.delIdx);
          if (idx < 0 || idx >= sections.length) return;
          const name = sections[idx].content?.headline_es || sections[idx].content?.title_es || sections[idx].component;
          if (!confirm('"' + name + '" wirklich l\u00f6schen?')) return;
          sections.splice(idx, 1);
          if (pageId) {
            await persistSections();
            await refreshPreview();
          }
          renderModuleList();
        });
      });

      initModuleListSortable(list);
    }

    async function initModuleListSortable(list) {
      try {
        const { default: Sortable } = await import('https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/+esm');
        moduleSortableInstance = Sortable.create(list, {
          handle: '.nova-drag-handle',
          animation: 150,
          ghostClass: 'sortable-ghost',
          chosenClass: 'sortable-chosen',
          onEnd: async function(evt) {
            if (evt.oldIndex === evt.newIndex) return;
            const moved = sections.splice(evt.oldIndex, 1)[0];
            sections.splice(evt.newIndex, 0, moved);

            // Reorder the actual module elements in the preview DOM
            const allMods = Array.from(document.querySelectorAll('[data-nova-module]'));
            const movedEl = allMods[evt.oldIndex];
            const targetEl = allMods[evt.newIndex];
            if (movedEl && targetEl && movedEl.parentNode) {
              if (evt.newIndex > evt.oldIndex) {
                targetEl.parentNode.insertBefore(movedEl, targetEl.nextSibling);
              } else {
                targetEl.parentNode.insertBefore(movedEl, targetEl);
              }
            }

            // Update selection index if a module was selected
            if (selectedModuleIdx === evt.oldIndex) selectedModuleIdx = evt.newIndex;
            else if (selectedModuleIdx > evt.oldIndex && selectedModuleIdx <= evt.newIndex) selectedModuleIdx--;
            else if (selectedModuleIdx < evt.oldIndex && selectedModuleIdx >= evt.newIndex) selectedModuleIdx++;

            if (pageId) {
              const updatedSections = sections.map(s => ({
                type: s.component, mode: 'detached', data: s.content,
                visual_overrides: s.overrides || undefined,
              }));
              await fetch('/api/pages/' + pageId + '/sections', {
                method: 'PUT', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sections: updatedSections }),
              });
              fetch('/api/rebuild', { method: 'POST' }).catch(() => {});
            }
          }
        });
      } catch {}
    }

    function openModuleFromList(idx) {
      document.getElementById('nova-module-list-wrap').style.display = 'none';
      const editorWrap = document.getElementById('nova-module-editor-wrap');
      editorWrap.style.display = 'flex';

      const section = sections[idx];
      if (!section) return;

      // Update editing label + breadcrumb
      const label = document.getElementById('nova-editing-label');
      if (label) label.textContent = section.component;
      document.getElementById('bc-sep-module').style.display = '';
      document.getElementById('bc-module-name').style.display = '';
      document.getElementById('bc-module-name').textContent = section.component;
      document.getElementById('bc-sep-field').style.display = 'none';
      document.getElementById('bc-field-name').style.display = 'none';

      // Find and select the corresponding module in the page
      const allMods = document.querySelectorAll('[data-nova-module]');
      allMods.forEach(m => m.classList.remove('nova-selected'));
      if (allMods[idx]) {
        allMods[idx].classList.add('nova-selected');
        selectedModuleEl = allMods[idx];
        allMods[idx].scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      selectedModuleIdx = idx;
      selectedSlotName = null;

      // Render mode bar if this component supports being globally shared
      // (registry.source === 'global' means a central zds_module post can
      // act as the single source of truth across all pages).
      updateModeBar(section);

      // Render slot map
      renderSlotMap(selectedModuleEl, section.component);

      // Load content and style
      loadContentFields(idx);
      loadStyleFields(selectedModuleEl || document.createElement('div'), idx);

      // Switch to content tab
      document.querySelectorAll('.nova-tab').forEach(t => t.classList.remove('active'));
      document.querySelector('[data-tab="content"]')?.classList.add('active');
      document.querySelectorAll('.nova-tab-panel').forEach(c => c.style.display = 'none');
      document.getElementById('nova-tab-content').style.display = '';
    }

    // ═══ Module Mode (linked ↔ detached) ═══════════════════════
    function componentSupportsGlobal(component) {
      const entry = REGISTRY[component];
      // Registry entry from editor-registry.ts is keyed by component.
      // The OTHER module-registry.ts has source:'global' for sharable
      // types. We mirror the whitelist here for client-side checks.
      const globallyShared = ['LogoTicker', 'Stats'];
      return globallyShared.includes(component);
    }

    function updateModeBar(section) {
      const bar = document.getElementById('nova-mode-bar');
      if (!bar) return;
      if (!componentSupportsGlobal(section.component)) {
        bar.style.display = 'none';
        return;
      }
      bar.style.display = '';
      const mode = section.mode || 'detached';
      bar.querySelectorAll('.nova-mode-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.mode === mode);
      });
    }

    async function setModuleMode(newMode) {
      if (selectedModuleIdx < 0) return;
      const section = sections[selectedModuleIdx];
      if (!section) return;
      const currentMode = section.mode || 'detached';
      if (currentMode === newMode) return;

      if (newMode === 'detached' && currentMode === 'linked') {
        // Linked → detached: copy the current data into section.data so
        // the page has a standalone snapshot. Warn user first.
        if (!confirm('Entkoppeln? Das Modul wird eine eigene Kopie — \u00c4nderungen wirken nur auf dieser Seite.')) return;
        section.data = JSON.parse(JSON.stringify(section.content || {}));
        section.mode = 'detached';
        novaToast('Modul entkoppelt', 'info');
      } else if (newMode === 'linked' && currentMode === 'detached') {
        // Detached → linked: find or create a globally-shared module
        // for this component and point module_id there. Local content
        // will be replaced by the global one on next load.
        if (!confirm('Wieder ankoppeln? Die lokalen \u00c4nderungen dieser Seite gehen verloren und werden durch den globalen Stand ersetzt.')) return;
        try {
          const res = await fetch('/api/modules/global/' + section.component);
          if (res.ok) {
            const data = await res.json();
            if (data.id) {
              section.module_id = data.id;
              section.mode = 'linked';
              delete section.data;
              novaToast('Modul an globale Quelle gekoppelt', 'ok');
            } else {
              novaToast('Kein globales Modul gefunden', 'err');
              return;
            }
          } else {
            novaToast('Fehler beim Ankoppeln', 'err');
            return;
          }
        } catch (e) {
          novaToast('Netzwerkfehler', 'err');
          return;
        }
      }
      dirty = true;
      updateModeBar(section);
      await persistSections();
      await refreshPreview();
    }

    document.getElementById('nova-mode-linked')?.addEventListener('click', () => setModuleMode('linked'));
    document.getElementById('nova-mode-detached')?.addEventListener('click', () => setModuleMode('detached'));

    // Back to list
    document.getElementById('nova-back-to-list')?.addEventListener('click', () => {
      document.getElementById('nova-module-editor-wrap').style.display = 'none';
      document.getElementById('nova-module-list-wrap').style.display = '';
      document.querySelectorAll('[data-nova-module]').forEach(m => m.classList.remove('nova-selected'));
      document.querySelectorAll('[data-nova-el]').forEach(el => el.classList.remove('nova-el-active', 'nova-el-hover'));
      selectedModuleIdx = -1;
      selectedModuleEl = null;
      selectedSlotName = null;
      document.getElementById('bc-sep-module').style.display = 'none';
      document.getElementById('bc-module-name').style.display = 'none';
      document.getElementById('bc-sep-field').style.display = 'none';
      document.getElementById('bc-field-name').style.display = 'none';
      renderModuleList();
    });

    // Initial render
    renderModuleList();

    // ====== TAB SWITCHING ======
    document.querySelectorAll('.nova-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.nova-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        document.querySelectorAll('.nova-tab-panel').forEach(c => c.style.display = 'none');
        const panel = document.getElementById('nova-tab-' + tab.dataset.tab);
        panel.style.display = tab.dataset.tab === 'ai' ? 'flex' : '';
      });
    });

    // ====== PANEL TOGGLE ======
    document.getElementById('nova-toggle-panel')?.addEventListener('click', () => {
      const panel = document.getElementById('nova-live-panel');
      panel.classList.toggle('collapsed');
      document.body.classList.toggle('nova-collapsed');
    });

    // ====== SMART DOM UPDATE ======
    function smartUpdateElement(target, newVal, content, fieldKey) {
      // Image/media fields: update src attribute
      if (fieldKey && fieldKey.match(/image|photo|logo|avatar|poster/i)) {
        // Find img inside or the element itself
        const img = target.tagName === 'IMG' ? target : target.querySelector('img');
        if (img) { img.src = newVal; return; }
        // No img found — might be a background-image
        if (newVal.match(/\.(jpg|jpeg|png|webp|gif|svg)/i)) {
          target.style.backgroundImage = 'url(' + newVal + ')';
          return;
        }
      }
      // URL fields: update href
      if (fieldKey && fieldKey.match(/url$|href$/i)) {
        if (target.tagName === 'A') { target.href = newVal; return; }
      }
      // HTML content
      if (newVal.includes('<')) { target.innerHTML = newVal; return; }
      // Simple text without children
      const hasChildren = target.querySelector('span, br, a, strong, em');
      if (!hasChildren) { target.textContent = newVal; return; }
      // Complex text with highlights/breaks
      const highlightWord = content.highlight_word || '';
      const lines = newVal.split('\n');
      let html = '';
      for (let i = 0; i < lines.length; i++) {
        let line = lines[i];
        if (highlightWord && line.includes(highlightWord)) {
          line = line.replace(highlightWord, '<span data-nova-el="hero-highlight" class="text-brand-400">' + highlightWord + '</span>');
        }
        html += line;
        if (i < lines.length - 1) html += '<br>';
      }
      target.innerHTML = html;
    }

    // ====== FIELD ALIAS SYSTEM ======
    const FIELD_ALIASES = {
      badge:'label', section_label:'label', body:'subtitle', description:'subtitle',
      cta_primary_text:'cta_text', button_text:'cta_text', footer_link_text:'cta_text',
      cta_primary_url:'cta_url', button_url:'cta_url', footer_link_url:'cta_url',
      cta_secondary_text:'cta2_text', cta_secondary_url:'cta2_url',
      background_image:'image', hero_image:'image', photo:'image', person_image:'image',
    };
    const REVERSE_ALIASES = {};
    for (const [old, norm] of Object.entries(FIELD_ALIASES)) {
      if (!REVERSE_ALIASES[norm]) REVERSE_ALIASES[norm] = [];
      REVERSE_ALIASES[norm].push(old);
    }
    function contentLookup(content, key, lang) {
      const fullKey = lang ? key + '_' + lang : key;
      if (content[fullKey] !== undefined && content[fullKey] !== '') return { key: fullKey, val: content[fullKey] };
      const aliases = REVERSE_ALIASES[key] || [];
      for (const alias of aliases) {
        const aliasKey = lang ? alias + '_' + lang : alias;
        if (content[aliasKey] !== undefined && content[aliasKey] !== '') return { key: aliasKey, val: content[aliasKey] };
      }
      if (lang && content[key] !== undefined) return { key, val: content[key] };
      return { key: fullKey, val: '' };
    }

    // ====== FIELD->DOM ELEMENT MAPPING ======
    const FIELD_TO_EL = {
      'headline': ['title', 'headline'], 'subtitle': ['subtitle'], 'badge': ['badge'],
      'label': ['label'], 'section_label': ['label'], 'quote': ['quote'],
      'cta_text': ['cta-button', 'cta'], 'cta_primary': ['cta-primary'],
      'cta_secondary': ['cta-secondary'], 'highlight': ['highlight'],
      'founder_name': ['name'], 'founder_role': ['role'],
    };
    // ====== INLINE PREVIEW EDITING (click text in preview → edit in place) ======
    // Delegated click handler: clicking any data-nova-el text element
    // switches it into contentEditable, mirrors changes back to the
    // sidebar field + section.content, and blurs on Escape or clicking
    // elsewhere. Links inside modules don't navigate while editing.
    (function inlinePreviewEditing() {
      let activeEl = null;
      let activeSlotName = null;

      function getFieldKeyForSlot(slotName) {
        // Map hero-title → headline_<lang>, hero-subtitle → subtitle_<lang>, etc.
        const slotKeyMap = {
          'hero-title': 'headline',
          'hero-subtitle': 'subtitle',
          'hero-badge': 'badge',
          'hero-cta-primary': 'cta_primary_text',
          'hero-cta-secondary': 'cta_secondary_text',
          'columns-title': 'headline',
          'columns-subtitle': 'subtitle',
          'columns-label': 'label',
          'cardgrid-title': 'headline',
          'cardgrid-label': 'label',
          'faq-title': 'headline',
          'cta-title': 'headline',
          'cta-subtitle': 'subtitle',
          'cta-highlight': 'highlight',
          'cta-button': 'button_text',
        };
        return slotKeyMap[slotName] || null;
      }

      function deactivate(save) {
        if (!activeEl) return;
        activeEl.contentEditable = 'false';
        activeEl.classList.remove('nova-inline-editing');
        if (save) syncToContent();
        activeEl = null;
        activeSlotName = null;
      }

      function syncToContent() {
        if (!activeEl || selectedModuleIdx < 0) return;
        const baseKey = getFieldKeyForSlot(activeSlotName);
        if (!baseKey) return;
        const section = sections[selectedModuleIdx];
        if (!section || !section.content) return;
        const isHtmlField = /title|headline|highlight/.test(activeSlotName);
        let value;
        if (isHtmlField) {
          // contentEditable inserts <br> or <div> on Enter — normalize
          // both to \n so Hero.astro split('\n') works as expected.
          value = activeEl.innerHTML
            .replace(/<br\s*\/?>/gi, '\n')
            .replace(/<div[^>]*>/gi, '\n')
            .replace(/<\/div>/gi, '')
            .replace(/&nbsp;/g, ' ');
        } else {
          value = activeEl.textContent || '';
        }
        // Write to the current-locale variant if the field is translatable
        const localeKey = baseKey + '_' + currentLang;
        if (localeKey in section.content || baseKey + '_es' in section.content) {
          section.content[localeKey] = value;
        } else {
          section.content[baseKey] = value;
        }
        dirty = true;
        // Sync to sidebar input — preserve the same value we store in
        // section.content so the two never drift apart. textareas render
        // \n as line breaks; inputs show them inline which is acceptable.
        const sidebarInput = document.querySelector('.nova-fld[data-slot="' + activeSlotName + '"] input, .nova-fld[data-slot="' + activeSlotName + '"] textarea');
        if (sidebarInput) sidebarInput.value = value;
      }

      function activate(el) {
        if (activeEl === el) return;
        deactivate(true);
        // Walk up the DOM to the OUTERMOST data-nova-el inside the
        // selected module. This handles clicks on nested elements
        // (e.g., a <span data-nova-el="hero-highlight"> inside an
        // <h1 data-nova-el="hero-title">). We want the headline, not
        // the highlight span, because the inner span's value is part
        // of the headline itself.
        let topEl = el;
        while (topEl.parentElement && selectedModuleEl && selectedModuleEl.contains(topEl.parentElement)) {
          const parentNovaEl = topEl.parentElement.closest('[data-nova-el]');
          if (parentNovaEl && selectedModuleEl.contains(parentNovaEl)) {
            topEl = parentNovaEl;
          } else {
            break;
          }
        }
        activeEl = topEl;
        activeSlotName = topEl.dataset.novaEl;
        topEl.contentEditable = 'true';
        topEl.classList.add('nova-inline-editing');
        // Focus and place cursor at end rather than selecting everything
        topEl.focus();
        try {
          const range = document.createRange();
          range.selectNodeContents(topEl);
          range.collapse(false);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        } catch {}
      }

      // All panels/modals that should NOT trigger deactivation when clicked
      const EDITOR_CHROME_SELECTORS = [
        '#nova-live-panel',
        '.nova-toolbar',
        '.nova-breadcrumb',
        '#nova-module-picker-backdrop',
        '#nova-device-iframe-wrap',
        '#nova-seo-panel',
        '#nova-versions-panel',
      ].join(', ');

      document.addEventListener('click', (e) => {
        // Skip clicks inside editor chrome unless they're on a
        // data-nova-el element (which only happens in the preview).
        if (e.target.closest(EDITOR_CHROME_SELECTORS)) {
          if (!e.target.closest('#nova-live-panel [data-nova-el]')) return;
        }
        const el = e.target.closest('[data-nova-el]');
        if (!el) return;
        // Only act on elements inside the selected module
        if (!selectedModuleEl || !selectedModuleEl.contains(el)) return;
        // ──────────────────────────────────────────────────────────
        // CRITICAL: if we're already editing something in this module
        // and the click is INSIDE the active element, don't bubble-up
        // to a sibling element. Prevents "typing in headline jumps to
        // CTA-secondary" bug where text clicks near CTA swap activeEl.
        if (activeEl && activeEl.contains(e.target)) return;
        // ──────────────────────────────────────────────────────────
        // Only for text-ish elements, not for buttons/links (clicking a CTA
        // button should follow the link unless user holds Ctrl/Meta)
        const tag = el.tagName.toLowerCase();
        const isTextTag = ['h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'p', 'span', 'div', 'a', 'button'].includes(tag);
        if (!isTextTag) return;
        // Prevent link navigation while editing
        const link = e.target.closest('a');
        if (link && (e.ctrlKey || e.metaKey)) return; // let ctrl+click open links
        if (link) e.preventDefault();
        activate(el);
      }, true);

      // Sync on typing (debounced for performance)
      let inputTimer;
      document.addEventListener('input', (e) => {
        if (!activeEl || !activeEl.contains(e.target) && activeEl !== e.target) return;
        clearTimeout(inputTimer);
        inputTimer = setTimeout(syncToContent, 200);
      });

      // Escape / Click outside → deactivate
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && activeEl) { e.preventDefault(); deactivate(true); }
      });
      document.addEventListener('click', (e) => {
        if (!activeEl) return;
        if (activeEl.contains(e.target)) return;
        // Don't close inline-editor when clicking any editor chrome
        // (sidebar, toolbar, SEO panel, versions, module picker, etc.)
        if (e.target.closest(EDITOR_CHROME_SELECTORS)) return;
        deactivate(true);
      });
    })();

    function findTargetElement(moduleEl, fieldKey) {
      if (!moduleEl) return null;
      const base = fieldKey.replace(/_es$|_en$|_de$/, '').replace(/_text$/, '');
      const candidates = FIELD_TO_EL[base] || [base];
      const allEls = moduleEl.querySelectorAll('[data-nova-el]');
      for (const term of candidates) {
        for (const el of allEls) {
          if (el.dataset.novaEl === term || el.dataset.novaEl.endsWith('-' + term)) return el;
        }
      }
      for (const term of candidates) {
        for (const el of allEls) {
          if (el.dataset.novaEl.includes(term)) return el;
        }
      }
      return null;
    }

    // ====== MEDIA PICKER ======
    let _mediaPickerCallback = null;
    let _mediaSearchTimeout = null;
    function loadMediaGrid(search) {
      const grid = document.getElementById('media-grid');
      grid.innerHTML = '<div style="color:var(--nova-text-dim);padding:20px;text-align:center">Laden...</div>';
      const searchParam = search ? '?search=' + encodeURIComponent(search) : '';
      fetch('/api/media/list' + searchParam).then(r => r.json()).then(images => {
        grid.innerHTML = '';
        images.forEach(img => {
          const thumb = img.media_details?.sizes?.thumbnail?.source_url || img.source_url;
          const div = document.createElement('div');
          div.style.cssText = 'cursor:pointer;border-radius:6px;overflow:hidden;border:2px solid transparent;background:var(--nova-bg);width:100%;height:0;padding-bottom:100%;position:relative';
          div.innerHTML = '<img src="' + thumb + '" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block" loading="lazy" />';
          div.title = img.title?.rendered || '';
          div.addEventListener('click', () => {
            if (_mediaPickerCallback) _mediaPickerCallback(img.source_url);
            document.getElementById('media-modal').style.display = 'none';
          });
          div.addEventListener('mouseenter', () => div.style.borderColor = 'var(--nova-accent)');
          div.addEventListener('mouseleave', () => div.style.borderColor = 'transparent');
          grid.appendChild(div);
        });
      }).catch(() => { grid.innerHTML = '<div style="color:var(--nova-red);padding:20px">Fehler beim Laden</div>'; });
    }

    function openMediaPicker(callback) {
      _mediaPickerCallback = callback;
      const modal = document.getElementById('media-modal');
      const searchInput = document.getElementById('media-search');
      modal.style.display = 'flex';
      searchInput.value = '';
      loadMediaGrid('');
      searchInput.oninput = () => {
        clearTimeout(_mediaSearchTimeout);
        _mediaSearchTimeout = setTimeout(() => loadMediaGrid(searchInput.value), 300);
      };
    }

    // Inject media modal (includes upload button + file input)
    document.body.insertAdjacentHTML('beforeend', `
      <div id="media-modal" style="display:none;position:fixed;inset:0;z-index:99998;background:rgba(0,0,0,0.8);align-items:center;justify-content:center">
        <div style="background:var(--nova-surface);border:1px solid var(--nova-border);border-radius:12px;width:90%;max-width:700px;max-height:80vh;display:flex;flex-direction:column;overflow:hidden">
          <div style="padding:12px 16px;display:flex;justify-content:space-between;align-items:center;gap:10px;border-bottom:1px solid var(--nova-border)">
            <span style="color:var(--nova-text);font-weight:600;font-size:14px;flex-shrink:0">Media Library</span>
            <input id="media-search" type="text" placeholder="Suchen..." style="flex:1;background:var(--nova-bg);border:1px solid var(--nova-border);border-radius:6px;padding:5px 10px;color:var(--nova-text);font-size:12px" />
            <label for="media-upload" style="cursor:pointer;background:var(--nova-accent);color:#fff;padding:5px 12px;border-radius:6px;font-size:12px;font-weight:600;flex-shrink:0">\u2191 Upload</label>
            <input id="media-upload" type="file" accept="image/*,video/*" style="display:none" />
            <button onclick="document.getElementById('media-modal').style.display='none'" style="background:none;border:none;color:var(--nova-text-dim);font-size:20px;cursor:pointer;flex-shrink:0">&times;</button>
          </div>
          <div id="media-upload-progress" style="display:none;padding:8px 16px;background:var(--nova-accent-dim);color:var(--nova-accent);font-size:12px;border-bottom:1px solid var(--nova-border)"></div>
          <div id="media-grid" style="padding:12px;display:grid;grid-template-columns:repeat(4,1fr);gap:8px;overflow-y:auto;flex:1"></div>
        </div>
      </div>
    `);

    // Upload handler — POST file to /api/media/upload, then refresh grid
    document.getElementById('media-upload')?.addEventListener('change', async (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      const progress = document.getElementById('media-upload-progress');
      progress.style.display = '';
      progress.textContent = 'Uploading ' + file.name + '\u2026';
      const fd = new FormData();
      fd.append('file', file);
      try {
        const res = await fetch('/api/media/upload', { method: 'POST', body: fd });
        if (res.ok) {
          const data = await res.json();
          progress.textContent = '\u2713 ' + file.name + ' hochgeladen';
          // If a picker is waiting, auto-select the uploaded file.
          if (_mediaPickerCallback && data.source_url) {
            _mediaPickerCallback(data.source_url);
            _mediaPickerCallback = null;
            document.getElementById('media-modal').style.display = 'none';
            novaToast('Upload fertig + eingef\u00fcgt', 'ok');
          } else {
            loadMediaGrid('');
            novaToast('Upload fertig', 'ok');
          }
          setTimeout(() => { progress.style.display = 'none'; }, 1800);
        } else {
          const err = await res.text();
          progress.textContent = 'Fehler: ' + res.status;
          novaToast('Upload fehlgeschlagen', 'err');
          console.warn('Upload failed:', err);
        }
      } catch (err) {
        progress.textContent = 'Netzwerkfehler';
        novaToast('Upload-Netzwerkfehler', 'err');
      }
      e.target.value = '';
    });

    function makeMediaInput(input) {
      const wrap = document.createElement('div');
      wrap.style.cssText = 'display:flex;flex-direction:column;gap:6px';
      input.parentNode.insertBefore(wrap, input);
      const topRow = document.createElement('div');
      topRow.style.cssText = 'display:flex;gap:8px;align-items:center';
      const preview = document.createElement('div');
      preview.style.cssText = 'width:72px;height:72px;border-radius:6px;overflow:hidden;flex-shrink:0;background:var(--nova-bg);border:1px solid var(--nova-border);display:flex;align-items:center;justify-content:center;cursor:pointer';
      const img = document.createElement('img');
      img.style.cssText = 'width:100%;height:100%;object-fit:cover';
      img.src = input.value || '';
      function updatePreview() {
        if (input.value) { img.src = input.value; preview.innerHTML = ''; preview.appendChild(img); }
        else { preview.innerHTML = '<span style="color:var(--nova-text-dim);font-size:22px">\ud83d\uddbc</span>'; }
      }
      updatePreview();
      topRow.appendChild(preview);
      const btns = document.createElement('div');
      btns.style.cssText = 'display:flex;flex-direction:column;gap:4px';
      const selectBtn = document.createElement('button');
      selectBtn.textContent = '\ud83d\uddbc Ausw\u00e4hlen';
      selectBtn.style.cssText = 'background:var(--nova-accent-dim);border:1px solid rgba(47,129,247,0.3);color:var(--nova-accent);border-radius:4px;padding:5px 12px;cursor:pointer;font-size:11px;font-weight:600;white-space:nowrap';
      selectBtn.addEventListener('click', (e) => {
        e.preventDefault();
        openMediaPicker(url => { input.value = url; updatePreview(); input.dispatchEvent(new Event('input')); });
      });
      preview.addEventListener('click', () => selectBtn.click());
      const clearBtn = document.createElement('button');
      clearBtn.textContent = '\u2715 Entfernen';
      clearBtn.style.cssText = 'background:rgba(248,81,73,0.08);border:1px solid rgba(248,81,73,0.2);color:var(--nova-red);border-radius:4px;padding:4px 12px;cursor:pointer;font-size:10px;white-space:nowrap';
      clearBtn.addEventListener('click', (e) => {
        e.preventDefault();
        input.value = '';
        updatePreview();
        input.dispatchEvent(new Event('input'));
      });
      // AI image generation — small "✦ AI" button. Prompts for a
      // description, sends to /api/media/generate, and writes the
      // returned URL into this field.
      const aiBtn = document.createElement('button');
      aiBtn.innerHTML = '\u2728 AI';
      aiBtn.style.cssText = 'background:rgba(168,85,247,0.10);border:1px solid rgba(168,85,247,0.3);color:#c084fc;border-radius:4px;padding:4px 12px;cursor:pointer;font-size:10px;font-weight:600;white-space:nowrap';
      aiBtn.addEventListener('click', async (e) => {
        e.preventDefault();
        const prompt = window.prompt('Bild-Prompt (was soll generiert werden?):');
        if (!prompt || !prompt.trim()) return;
        aiBtn.disabled = true; aiBtn.textContent = 'Generiere\u2026';
        novaToast('Generiere Bild\u2026', 'info', 8000);
        try {
          const res = await fetch('/api/media/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: prompt.trim() }),
          });
          if (res.ok) {
            const data = await res.json();
            const url = data.source_url || data.url;
            if (url) {
              input.value = url;
              updatePreview();
              input.dispatchEvent(new Event('input'));
              novaToast('\u2713 Bild generiert', 'ok');
            } else {
              novaToast('Keine URL in der Antwort', 'err');
            }
          } else {
            novaToast('Generierung fehlgeschlagen (' + res.status + ')', 'err');
          }
        } catch (err) {
          novaToast('Fehler: ' + err.message, 'err');
        } finally {
          aiBtn.disabled = false; aiBtn.innerHTML = '\u2728 AI';
        }
      });
      btns.appendChild(selectBtn);
      btns.appendChild(clearBtn);
      btns.appendChild(aiBtn);
      topRow.appendChild(btns);
      wrap.appendChild(topRow);
      input.style.display = 'none';
      wrap.appendChild(input);
      const urlDisplay = document.createElement('a');
      urlDisplay.style.cssText = 'font-size:10px;color:var(--nova-text-dim);text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block';
      urlDisplay.target = '_blank';
      function updateUrl() {
        const val = input.value || '';
        const short = val.replace(/^https?:\/\/cms\.zds\.es/, '').replace(/^\/wp-content\/uploads\//, '/uploads/');
        urlDisplay.textContent = short || 'Kein Bild ausgew\u00e4hlt';
        urlDisplay.href = val || '#';
        urlDisplay.style.color = val ? 'var(--nova-text-dim)' : 'var(--nova-text-dim)';
      }
      updateUrl();
      input.addEventListener('input', updateUrl);
      wrap.appendChild(urlDisplay);
    }

    // ====== PAGE LINKER ======
    // Uses SITE_TREE + WP data for a structured page picker.
    function openPageLinker(callback) {
      const modal = document.getElementById('page-linker-modal');
      const list = document.getElementById('page-linker-list');
      modal.style.display = 'flex';
      list.innerHTML = '';

      const allPages = window._novaWpPages || {};
      if (!Object.keys(allPages).length) {
        list.innerHTML = '<div style="padding:20px;color:var(--nova-text-dim);text-align:center;font-size:12px">Lade Seiten...</div>';
        return;
      }

      const shown = new Set();
      SITE_TREE.forEach(group => {
        const visible = group.pages.filter(p => allPages[p.slug]);
        if (!visible.length) return;
        const header = document.createElement('div');
        header.style.cssText = 'color:var(--nova-text-dim);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;padding:8px 12px 4px;margin-top:4px';
        header.textContent = group.group;
        list.appendChild(header);

        visible.forEach(p => {
          shown.add(p.slug);
          const path = p.slug === 'homepage' ? '/' : '/' + p.slug;
          const item = document.createElement('div');
          item.style.cssText = 'padding:8px 12px;cursor:pointer;color:var(--nova-text);font-size:13px;border-radius:6px;display:flex;align-items:center;gap:8px';
          if (p.child) item.style.paddingLeft = '28px';
          item.innerHTML = '<span style="font-size:13px">' + (p.icon || '') + '</span><span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + p.label + '</span><span style="color:var(--nova-text-dim);font-size:11px;font-family:monospace">' + path + '</span>';
          item.addEventListener('mouseenter', () => item.style.background = 'var(--nova-accent-dim)');
          item.addEventListener('mouseleave', () => item.style.background = 'none');
          item.addEventListener('click', () => { callback(path); modal.style.display = 'none'; });
          list.appendChild(item);
        });
      });

      // Blog posts
      if (window._novaWpPosts.length) {
        const header = document.createElement('div');
        header.style.cssText = 'color:var(--nova-text-dim);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;padding:8px 12px 4px;margin-top:4px';
        header.textContent = '\ud83d\udcdd Blog (' + window._novaWpPosts.length + ')';
        list.appendChild(header);
        window._novaWpPosts.forEach(p => {
          shown.add(p.slug);
          const clean = (p.title || p.slug).replace(/<[^>]+>/g, '');
          const item = document.createElement('div');
          item.style.cssText = 'padding:8px 12px;cursor:pointer;color:var(--nova-text);font-size:13px;border-radius:6px;display:flex;align-items:center;gap:8px';
          item.innerHTML = '<span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + clean + '</span><span style="color:var(--nova-text-dim);font-size:11px;font-family:monospace">/insights/' + p.slug + '</span>';
          item.addEventListener('mouseenter', () => item.style.background = 'var(--nova-accent-dim)');
          item.addEventListener('mouseleave', () => item.style.background = 'none');
          item.addEventListener('click', () => { callback('/insights/' + p.slug); modal.style.display = 'none'; });
          list.appendChild(item);
        });
      }

      const extDiv = document.createElement('div');
      extDiv.style.cssText = 'padding:12px;border-top:1px solid var(--nova-border);margin-top:8px;display:flex;gap:6px';
      const extInput = document.createElement('input');
      extInput.type = 'text';
      extInput.placeholder = 'Externe URL (https://...)';
      extInput.style.cssText = 'flex:1;background:var(--nova-bg);border:1px solid var(--nova-border);border-radius:6px;padding:6px 10px;color:var(--nova-text);font-size:12px';
      const extBtn = document.createElement('button');
      extBtn.textContent = 'OK';
      extBtn.style.cssText = 'background:var(--nova-accent);color:white;border:none;border-radius:6px;padding:6px 14px;cursor:pointer;font-size:12px;font-weight:600';
      extBtn.addEventListener('click', () => { if (extInput.value) { callback(extInput.value); modal.style.display = 'none'; } });
      extDiv.appendChild(extInput);
      extDiv.appendChild(extBtn);
      list.appendChild(extDiv);
    }

    document.body.insertAdjacentHTML('beforeend', `
