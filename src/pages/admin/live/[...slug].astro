    // ====== HELPERS ======
    function rgbToHex(rgb) {
      if (rgb.startsWith('#')) return rgb;
      if (rgb === 'transparent' || rgb === 'rgba(0, 0, 0, 0)') return 'transparent';
      const match = rgb.match(/[\d.]+/g);
      if (!match || match.length < 3) return '#000000';
      const hex = '#' + match.slice(0, 3).map(n => parseInt(n).toString(16).padStart(2, '0')).join('');
      if (match.length >= 4 && parseFloat(match[3]) < 1) {
        return hex + ' (' + Math.round(parseFloat(match[3]) * 100) + '%)';
      }
      return hex;
    }
    function hexToDisplay(val) {
      if (val.includes('(')) return val.split(' ')[0];
      return val;
    }

    // ═══════════════════════════════════════════════════════════
    // PAGE-LEVEL AI — seitenweiter AI Chat + Action Executor
    // ═══════════════════════════════════════════════════════════
    (function setupPageLevelAI() {
      // Tab switching between Module list and AI
      document.querySelectorAll('.nova-sidebar-tab').forEach(tab => {
        tab.addEventListener('click', () => {
          document.querySelectorAll('.nova-sidebar-tab').forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          const which = tab.dataset.sidebarTab;
          document.getElementById('nova-module-list').style.display = which === 'modules' ? '' : 'none';
          document.getElementById('nova-page-ai').style.display    = which === 'page-ai' ? 'flex' : 'none';
        });
      });

      const msgsEl = document.getElementById('nova-page-ai-msgs');
      const input = document.getElementById('nova-page-ai-input');
      const sendBtn = document.getElementById('nova-page-ai-send');
      if (!sendBtn) return;

      function addMsg(kind, text) {
        const div = document.createElement('div');
        div.className = 'nova-page-ai-msg ' + kind;
        div.textContent = text;
        msgsEl.appendChild(div);
        msgsEl.scrollTop = msgsEl.scrollHeight;
        return div;
      }

      // Execute a single nova-action object
      async function executeAction(action) {
        if (!action || !action.action) return false;
        try {
          if (action.action === 'create_module') {
            const res = await fetch('/api/modules/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                title: action.title || (action.component + ' (AI)'),
                component: action.component,
                content: action.content || {},
                style: action.style || { theme: 'dark' },
                pageId: action.pageId || pageId,
                position: action.position,
              }),
            });
            if (!res.ok) { addMsg('error', 'create_module failed: ' + await res.text()); return false; }
            const data = await res.json();
            addMsg('action', 'Modul erstellt: ' + action.component + ' (ID #' + data.id + ')');
            return true;
          }
          if (action.action === 'update_module' && action.module_id && action.changes) {
            const res = await fetch('/api/modules/' + action.module_id, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ content: action.changes }),
            });
            if (!res.ok) { addMsg('error', 'update_module failed'); return false; }
            addMsg('action', 'Modul #' + action.module_id + ' aktualisiert');
            return true;
          }
          if (action.action === 'generate_image' && action.prompt) {
            const payload = { prompt: action.prompt };
            if (action.pageId || pageId) payload.pageId = action.pageId || pageId;
            if (action.module_id) payload.module_id = action.module_id;
            if (action.field) payload.field = action.field;
            if (action.set_featured) payload.set_featured = true;
            const res = await fetch('/api/media/generate', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            if (!res.ok) { addMsg('error', 'generate_image failed'); return false; }
            addMsg('action', 'Bild generiert: ' + action.prompt.substring(0, 60) + '...');
            return true;
          }
          addMsg('error', 'Unbekannte Aktion: ' + action.action);
          return false;
        } catch (e) {
          addMsg('error', 'Fehler: ' + e.message);
          return false;
        }
      }

      // Extract nova-action JSON blocks from streamed text
      function extractActions(text) {
        const regex = /```nova-action\s*([\s\S]*?)```/g;
        const actions = [];
        let m;
        while ((m = regex.exec(text)) !== null) {
          try { actions.push(JSON.parse(m[1].trim())); } catch { /* skip bad JSON */ }
        }
        return actions;
      }

      async function buildPage() {
        const prompt = input.value.trim();
        if (!prompt) return;
        addMsg('user', prompt);
        input.value = '';
        sendBtn.disabled = true;
        sendBtn.textContent = 'KI denkt...';

        const aiBubble = addMsg('ai', '');
        let buffer = '';
        const processedActions = new Set();

        try {
          const res = await fetch('/api/ai/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              message: prompt,
              context: {
                pageId: pageId,
                pageName: slug,
                sections: sections.map((s, i) => ({
                  component: s.component,
                  title: s.title || s.component,
                  id: s.id,
                  position: i,
                })),
              },
            }),
          });
          if (!res.ok || !res.body) {
            addMsg('error', 'AI API Fehler: ' + res.status);
            return;
          }

          const reader = res.body.getReader();
          const decoder = new TextDecoder();
          let sseBuffer = '';
          while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            sseBuffer += decoder.decode(value, { stream: true });
            const lines = sseBuffer.split('\n');
            sseBuffer = lines.pop() || '';
            for (const line of lines) {
              if (!line.startsWith('data: ')) continue;
              const payload = line.slice(6).trim();
              if (payload === '[DONE]') continue;
              try {
                const data = JSON.parse(payload);
                const delta = data.choices?.[0]?.delta?.content || '';
                if (delta) {
                  buffer += delta;
                  // Show text without the action blocks
                  aiBubble.textContent = buffer.replace(/```nova-action[\s\S]*?```/g, '[Aktion...]');
                  msgsEl.scrollTop = msgsEl.scrollHeight;
                }
              } catch { /* skip malformed */ }
            }
          }

          // Execute all actions in order
          const actions = extractActions(buffer);
          if (actions.length === 0) {
            addMsg('action', 'Keine Aktionen erkannt. Antwort war nur Text.');
          } else {
            addMsg('action', actions.length + ' Aktion(en) erkannt, f\u00fchre aus...');
            for (const action of actions) {
              await executeAction(action);
            }
            addMsg('action', 'Fertig. Lade Seite neu um Ergebnis zu sehen.');
            // Trigger a reload after a short delay so user can read the messages
            setTimeout(() => location.reload(), 2500);
          }
        } catch (e) {
          addMsg('error', 'Stream-Fehler: ' + e.message);
        } finally {
          sendBtn.disabled = false;
          sendBtn.textContent = 'KI baut Seite \u2192';
        }
      }

      sendBtn.addEventListener('click', buildPage);
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) { e.preventDefault(); buildPage(); }
      });
    })();

    // Warn on leave with unsaved changes
    window.addEventListener('beforeunload', (e) => { if (dirty) e.preventDefault(); });

    // Ctrl+S to save
    document.addEventListener('keydown', e => {
      if (e.ctrlKey && e.key === 's' && selectedModuleIdx >= 0) {
        e.preventDefault();
        document.getElementById('nova-save')?.click();
      }
    });
  </script>
</BaseLayout>
