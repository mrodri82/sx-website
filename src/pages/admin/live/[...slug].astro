    // ====== RENDER REPEATER ======
    function renderRepeater(container, content, repDef) {
      const items = Array.isArray(content[repDef.arr]) ? JSON.parse(JSON.stringify(content[repDef.arr])) : [];
      const section = document.createElement('div');
      section.className = 'rep-section';
      section.dataset.repArr = repDef.arr;

      const titleRow = document.createElement('div');
      titleRow.className = 'rep-section-title';
      const titleSpan = document.createElement('span');
      titleSpan.textContent = repDef.label + ' (' + items.length + ')';
      titleRow.appendChild(titleSpan);
      const addBtn = document.createElement('button');
      addBtn.type = 'button';
      addBtn.className = 'rep-add-btn';
      addBtn.textContent = '+ ' + repDef.label;
      addBtn.addEventListener('click', function() {
        var newItem = {};
        repDef.fields.forEach(function(f) {
          if (f.tr) {
            LANGS.forEach(function(lang) { newItem[f.key + '_' + lang] = ''; });
          } else if (f.type === 'features-list') {
            LANGS.forEach(function(lang) { newItem[f.key + '_' + lang] = []; });
            newItem[f.key] = [];
          } else {
            newItem[f.key] = '';
          }
        });
        var list = section.querySelector('.rep-list');
        var card = buildRepCard(newItem, list.children.length, repDef);
        card.classList.add('expanded');
        list.appendChild(card);
        updateRepCount(section, repDef);
        dirty = true;
        scheduleAutoSaveRefresh();
      });
      titleRow.appendChild(addBtn);
      section.appendChild(titleRow);

      var list = document.createElement('div');
      list.className = 'rep-list';
      items.forEach(function(item, idx) {
        list.appendChild(buildRepCard(item, idx, repDef));
      });
      section.appendChild(list);
      initRepSortable(list);
      container.appendChild(section);
    }

    function initRepSortable(listEl) {
      import('https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/+esm').then(function(mod) {
        mod.default.create(listEl, {
          handle: '.rep-drag',
          animation: 150,
          ghostClass: 'sortable-ghost',
          onEnd: function(evt) {
            if (evt.oldIndex === evt.newIndex) return;
            dirty = true;
            scheduleAutoSaveRefresh();
          },
        });
      });
    }

    function updateRepCount(sectionEl, repDef) {
      var count = sectionEl.querySelector('.rep-list').children.length;
      var titleSpan = sectionEl.querySelector('.rep-section-title span');
      if (titleSpan) titleSpan.textContent = repDef.label + ' (' + count + ')';
    }

    function buildRepCard(item, idx, repDef) {
      var card = document.createElement('div');
      card.className = 'rep-card';
      var header = document.createElement('div');
      header.className = 'rep-card-header';
      var drag = document.createElement('span');
      drag.className = 'rep-drag';
      drag.textContent = '\u2630';
      header.appendChild(drag);
      var chevron = document.createElement('span');
      chevron.className = 'rep-chevron';
      chevron.textContent = '\u25B6';
      header.appendChild(chevron);
      var title = document.createElement('span');
      title.className = 'rep-card-title';
      var colVal = item[repDef.col + '_es'] || item[repDef.col] || (repDef.label + ' ' + (idx + 1));
      title.textContent = colVal;
      header.appendChild(title);
      var actions = document.createElement('div');
      actions.className = 'rep-card-actions';
      var dupBtn = document.createElement('button');
      dupBtn.type = 'button';
      dupBtn.title = 'Duplizieren';
      dupBtn.textContent = '\u2398';
      dupBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var clonedItem = collectSingleCardData(card, repDef);
        var newCard = buildRepCard(clonedItem, 0, repDef);
        card.parentElement.insertBefore(newCard, card.nextSibling);
        updateRepCount(card.closest('.rep-section'), repDef);
        dirty = true;
        scheduleAutoSaveRefresh();
      });
      actions.appendChild(dupBtn);
      var delBtn = document.createElement('button');
      delBtn.type = 'button';
      delBtn.className = 'rep-del';
      delBtn.title = 'L\u00f6schen';
      delBtn.textContent = '\u2715';
      delBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var sec = card.closest('.rep-section');
        card.remove();
        updateRepCount(sec, repDef);
        dirty = true;
        scheduleAutoSaveRefresh();
      });
      actions.appendChild(delBtn);
      header.appendChild(actions);
      header.addEventListener('click', function(e) {
        if (e.target.closest('.rep-card-actions')) return;
        card.classList.toggle('expanded');
      });
      card.appendChild(header);

      var body = document.createElement('div');
      body.className = 'rep-card-body';

      repDef.fields.forEach(function(fieldDef) {
        var fieldWrap = document.createElement('div');
        fieldWrap.className = 'rep-field';
        var label = document.createElement('div');
        label.className = 'rep-field-label';
        label.textContent = fieldDef.label;
        fieldWrap.appendChild(label);

        if (fieldDef.type === 'features-list') {
          if (fieldDef.tr) {
            var langGroup = document.createElement('div');
            langGroup.className = 'rep-lang-group';
            LANGS.forEach(function(lang) {
              var row = document.createElement('div');
              row.className = 'rep-lang-row';
              var badge = document.createElement('span');
              badge.className = 'rep-lang-badge';
              badge.textContent = lang.toUpperCase();
              row.appendChild(badge);
              var ta = document.createElement('textarea');
              ta.className = 'rep-field-input';
              ta.dataset.repField = fieldDef.key;
              ta.dataset.repLang = lang;
              ta.dataset.repType = 'features-list';
              var arr = item[fieldDef.key + '_' + lang] || item[fieldDef.key] || [];
              ta.value = Array.isArray(arr) ? arr.join('\n') : String(arr);
              ta.rows = 3;
              row.appendChild(ta);
              langGroup.appendChild(row);
            });
            fieldWrap.appendChild(langGroup);
          } else {
            var ta = document.createElement('textarea');
            ta.className = 'rep-field-input';
            ta.dataset.repField = fieldDef.key;
            ta.dataset.repType = 'features-list';
            var arr = item[fieldDef.key] || [];
            ta.value = Array.isArray(arr) ? arr.join('\n') : String(arr);
            ta.rows = 3;
            fieldWrap.appendChild(ta);
          }
        } else if (fieldDef.tr) {
          var langGroup = document.createElement('div');
          langGroup.className = 'rep-lang-group';
          LANGS.forEach(function(lang) {
            var row = document.createElement('div');
            row.className = 'rep-lang-row';
            var badge = document.createElement('span');
            badge.className = 'rep-lang-badge';
            badge.textContent = lang.toUpperCase();
            row.appendChild(badge);
            var isTextarea = fieldDef.type === 'textarea';
            var input = document.createElement(isTextarea ? 'textarea' : 'input');
            input.className = 'rep-field-input';
            input.dataset.repField = fieldDef.key;
            input.dataset.repLang = lang;
            input.value = item[fieldDef.key + '_' + lang] || '';
            if (!isTextarea) input.type = 'text';
            if (isTextarea) input.rows = 2;
            if (fieldDef.key === repDef.col && lang === 'es') {
              input.addEventListener('input', function() {
                title.textContent = input.value || (repDef.label + ' ' + (Array.from(card.parentElement.children).indexOf(card) + 1));
              });
            }
            row.appendChild(input);
            langGroup.appendChild(row);
          });
          fieldWrap.appendChild(langGroup);
        } else {
          var input = document.createElement('input');
          input.type = 'text';
          input.className = 'rep-field-input';
          input.dataset.repField = fieldDef.key;
          input.value = String(item[fieldDef.key] != null ? item[fieldDef.key] : '');
          if (fieldDef.key === repDef.col) {
            input.addEventListener('input', function() {
              title.textContent = input.value || (repDef.label + ' ' + (Array.from(card.parentElement.children).indexOf(card) + 1));
            });
          }
          fieldWrap.appendChild(input);
        }
        body.appendChild(fieldWrap);
      });

      repDef.fields.forEach(function(fieldDef) {
        if (fieldDef.tr || fieldDef.type === 'features-list' || fieldDef.type === 'textarea') return;
        var inp = body.querySelector('[data-rep-field="' + fieldDef.key + '"]:not([data-rep-lang])');
        if (!inp) return;
        if (fieldDef.media) makeMediaInput(inp);
        else if (fieldDef.pagelink) makePageLinkInput(inp);
      });

      card.appendChild(body);
      return card;
    }

    function collectSingleCardData(card, repDef) {
      var itemData = {};
      repDef.fields.forEach(function(fieldDef) {
        if (fieldDef.type === 'features-list') {
          if (fieldDef.tr) {
            LANGS.forEach(function(lang) {
              var ta = card.querySelector('[data-rep-field="' + fieldDef.key + '"][data-rep-lang="' + lang + '"]');
              var val = ta ? ta.value.split('\n').map(function(s) { return s.trim(); }).filter(Boolean) : [];
              itemData[fieldDef.key + '_' + lang] = val;
            });
            var esTA = card.querySelector('[data-rep-field="' + fieldDef.key + '"][data-rep-lang="es"]');
            itemData[fieldDef.key] = esTA ? esTA.value.split('\n').map(function(s) { return s.trim(); }).filter(Boolean) : [];
          } else {
            var ta = card.querySelector('[data-rep-field="' + fieldDef.key + '"]');
            itemData[fieldDef.key] = ta ? ta.value.split('\n').map(function(s) { return s.trim(); }).filter(Boolean) : [];
          }
        } else if (fieldDef.tr) {
          LANGS.forEach(function(lang) {
            var input = card.querySelector('[data-rep-field="' + fieldDef.key + '"][data-rep-lang="' + lang + '"]');
            itemData[fieldDef.key + '_' + lang] = input ? input.value : '';
          });
        } else {
          var input = card.querySelector('[data-rep-field="' + fieldDef.key + '"]');
          var val = input ? input.value : '';
          if (val === 'true') val = true;
          else if (val === 'false') val = false;
          itemData[fieldDef.key] = val;
        }
      });
      return itemData;
    }

    function collectRepeaterData(updatedContent) {
      document.querySelectorAll('#nova-content-fields .rep-section').forEach(function(section) {
        var arrKey = section.dataset.repArr;
        if (!arrKey) return;
        var cards = section.querySelectorAll('.rep-list > .rep-card');
        var repDef = null;
        for (var comp in REPEATERS) {
          if (REPEATERS[comp].arr === arrKey) { repDef = REPEATERS[comp]; break; }
        }
        if (!repDef) return;
        var items = [];
        cards.forEach(function(card) {
          items.push(collectSingleCardData(card, repDef));
        });
        updatedContent[arrKey] = items;
      });
    }

    function renderLogoTickerEditor(container, content) {
      var clients = Array.isArray(content.clients) ? content.clients : [];
      var section = document.createElement('div');
      section.className = 'rep-section';
      var titleEl = document.createElement('div');
      titleEl.className = 'rep-section-title';
      var titleSpan = document.createElement('span');
      titleSpan.textContent = 'Clients (' + clients.length + ')';
      titleEl.appendChild(titleSpan);
      section.appendChild(titleEl);
      var hint = document.createElement('div');
      hint.style.cssText = 'font-size:10px;color:var(--nova-text-dim);margin-bottom:4px';
      hint.textContent = 'Ein Name pro Zeile';
      section.appendChild(hint);
      var ta = document.createElement('textarea');
      ta.className = 'field-input';
      ta.id = 'logoticker-clients';
      ta.value = clients.join('\n');
      ta.rows = Math.max(6, Math.min(20, clients.length + 2));
      ta.style.fontFamily = "'JetBrains Mono', monospace";
      ta.style.fontSize = '12px';
      section.appendChild(ta);
      container.appendChild(section);
    }

    function collectLogoTickerData(updatedContent) {
      var ta = document.getElementById('logoticker-clients');
      if (ta) {
        updatedContent.clients = ta.value.split('\n').map(function(s) { return s.trim(); }).filter(Boolean);
      }
    }

    // ====== RENDER FIELD (adapted for prototype design with slot binding) ======
    function renderField(field, content, lang) {
      const lookup = contentLookup(content, field.key, field.tr ? lang : null);
      const key = lookup.key;
      let val = String(lookup.val || '');
      const fallbackLookup = field.tr ? contentLookup(content, field.key, 'es') : { val: '' };
      const fallbackVal = String(fallbackLookup.val || '');

      // Check if this field has a domEl binding in the registry
      const hasDomEl = !!field.domEl;
      const domElName = field.domEl || null;
      const domRead = field.domRead || null;

      // If domEl exists and we're in the current lang, try reading from DOM
      if (hasDomEl && selectedModuleEl && (!field.tr || lang === currentLang)) {
        const domTarget = selectedModuleEl.querySelector('[data-nova-el="' + domElName + '"]');
        if (domTarget) {
          if (domRead === 'innerHTML') {
            val = domTarget.innerHTML;
          } else if (domRead === 'textContent') {
            val = domTarget.textContent || '';
          } else if (domRead === 'attribute' && field.domAttribute) {
            val = domTarget.getAttribute(field.domAttribute) || '';
          }
        }
      }

      const isRichText = field.type === 'inline-html' || field.type === 'richtext';
      const isButton = field.key.includes('cta') || field.key.includes('button');
      const isPageLink = field.type === 'pagelink';

      // Build the field wrapper with nova-fld class + data-slot for bidirectional selection
      const fld = document.createElement('div');
      fld.className = 'nova-fld';
      if (domElName) fld.dataset.slot = domElName;

      // Conditional visibility: hide if showWhen condition not met
      if (field.showWhen) {
        const vals = Array.isArray(field.showWhen.equals) ? field.showWhen.equals : [field.showWhen.equals];
        fld.dataset.showWhenField = field.showWhen.field;
        fld.dataset.showWhenValues = vals.join(',');
        const cur = String(content[field.showWhen.field] || '');
        if (!vals.includes(cur)) fld.style.display = 'none';
      }

      // Click or focus on field to select corresponding slot.
      // Only fire selectSlot for DIRECT native-input focus (text/textarea/
      // select). Tiptap ProseMirror contentEditable + inline preview
      // editing bubble focus events through the same nova-fld, causing
      // the selector to jump randomly mid-edit. Restrict to explicit
      // form inputs only.
      if (domElName) {
        fld.addEventListener('click', (e) => {
          if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT' || e.target.contentEditable === 'true' || e.target.closest('.nova-rt-bar') || e.target.closest('.tiptap-toolbar')) return;
          selectSlot(domElName);
        });
        fld.addEventListener('focusin', (e) => {
          const t = e.target;
          if (!t) return;
          const tag = t.tagName;
          // Only react to native form inputs. Skip contentEditable
          // (Tiptap / inline preview), buttons, anything inside rich-
          // text toolbars, and clicks on file-picker buttons — those
          // are NOT real field-focus intents.
          if (tag !== 'INPUT' && tag !== 'TEXTAREA' && tag !== 'SELECT') return;
          if (t.type === 'button' || t.type === 'file' || t.type === 'submit') return;
          if (t.closest('.nova-rt-bar') || t.closest('.tiptap-toolbar')) return;
          // Also ignore focus events triggered programmatically (e.g.
          // by our own inline-preview-edit sync). relatedTarget is null
          // for programmatic focus in some browsers — but user-initiated
          // focus always has a legit trigger (keyboard tab, click).
          if (selectedSlotName !== domElName) selectSlot(domElName);
        });
      }

      // Label
      const labelEl = document.createElement('div');
      labelEl.className = 'nova-fld-label';
      const labelText = field.label || field.key.replace(/_/g, ' ');
      labelEl.textContent = labelText;

      // For button fields, add inline link icon
      if (isButton && !isPageLink) {
        // Find the corresponding URL field
        const urlKey = field.key.replace(/_text$/, '_url').replace(/^cta_text$/, 'cta_url').replace(/^cta2_text$/, 'cta2_url');
        const urlLookup = contentLookup(content, urlKey, null);
        const urlVal = String(urlLookup.val || '');
        if (urlVal) {
          const linkIcon = document.createElement('span');
          linkIcon.className = 'nova-link-icon';
          linkIcon.innerHTML = '\ud83d\udd17';
          linkIcon.title = 'Link: ' + urlVal;
          linkIcon.addEventListener('click', (e) => {
            e.stopPropagation();
            openPageLinker(path => {
              content[urlLookup.key] = path;
              routeDisplay.textContent = path;
              dirty = true;
            });
          });
          labelEl.appendChild(linkIcon);
        }
      }

      fld.appendChild(labelEl);

      // For pagelink type: show route
      if (isPageLink) {
        const wrap = document.createElement('div');
        wrap.style.cssText = 'display:flex;gap:4px;align-items:center';
        const input = document.createElement('input');
        input.type = 'text';
        input.value = val;
        input.dataset.key = key;
        input.style.flex = '1';
        wrap.appendChild(input);
        const btn = document.createElement('button');
        btn.textContent = '\ud83d\udd17';
        btn.title = 'Seite verkn\u00fcpfen';
        btn.style.cssText = 'background:var(--nova-accent-dim);border:1px solid rgba(47,129,247,0.3);color:var(--nova-accent);border-radius:4px;padding:4px 8px;cursor:pointer;font-size:14px;flex-shrink:0';
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          openPageLinker(path => { input.value = path; input.dispatchEvent(new Event('input')); });
        });
        wrap.appendChild(btn);
        fld.appendChild(wrap);

        input.addEventListener('input', function() {
          dirty = true;
          content[key] = this.value;
          if (hasDomEl && selectedModuleEl) {
            const target = selectedModuleEl.querySelector('[data-nova-el="' + domElName + '"]');
            if (target && field.domAttribute) target.setAttribute(field.domAttribute, this.value);
          }
        });
        return fld;
      }

      // Rich text fields (inline-html, richtext): use Tiptap-style inline editor
      if (isRichText) {
        // Build toolbar
        const rtBar = document.createElement('div');
        rtBar.className = 'nova-rt-bar';
        rtBar.innerHTML =
          '<button data-rt-cmd="bold" title="Fett"><b>B</b></button>' +
          '<button data-rt-cmd="italic" title="Kursiv"><i>I</i></button>' +
          '<button data-rt-cmd="underline" title="Unterstrichen" style="text-decoration:underline">U</button>' +
          '<div class="nova-rt-sep"></div>' +
          '<button data-rt-cmd="color" title="Textfarbe" style="position:relative">A<span style="position:absolute;bottom:3px;left:6px;right:6px;height:2px;background:var(--nova-accent);border-radius:1px"></span></button>' +
          '<button data-rt-cmd="highlight" title="Hintergrundfarbe"><span style="background:rgba(47,129,247,0.3);padding:0 3px;border-radius:2px;font-size:10px">ab</span></button>' +
          '<div class="nova-rt-sep"></div>' +
          '<button data-rt-cmd="hardBreak" title="Zeilenumbruch">&#8629;</button>' +
          '<button data-rt-cmd="link" title="Link">&#128279;</button>' +
          '<div class="nova-rt-sep"></div>' +
          '<div class="nova-rt-colors">' +
            '<div class="nova-rt-color" style="background:var(--nova-accent)" title="Brand Blue" data-color="#2f81f7"></div>' +
            '<div class="nova-rt-color" style="background:var(--nova-green)" title="Green" data-color="#3fb950"></div>' +
            '<div class="nova-rt-color" style="background:var(--nova-orange)" title="Orange" data-color="#d29922"></div>' +
            '<div class="nova-rt-color" style="background:#fff" title="White" data-color="#ffffff"></div>' +
            '<div class="nova-rt-color custom" title="Free Color Picker" data-color="custom"></div>' +
          '</div>';
        fld.appendChild(rtBar);

        // Editor area (will be initialized by Tiptap)
        const editArea = document.createElement('div');
        editArea.className = 'nova-rt-edit';
        editArea.dataset.rtKey = key;
        editArea.dataset.rtDomEl = domElName || '';
        editArea.dataset.rtDomRead = domRead || '';
        fld.appendChild(editArea);

        // Store initial value for Tiptap init.
        // If the content is plain text (no <span>) and a legacy
        // highlight_word exists, inject a color-span so the Tiptap
        // editor shows the highlighted word in brand color from the
        // start — not just white text that the user has to manually
        // re-highlight every time they edit.
        let rtVal = val;
        if (rtVal && !/<span/i.test(rtVal)) {
          const hw = content.highlight_word || '';
          if (hw && rtVal.includes(hw)) {
            rtVal = rtVal.replace(hw, '<span style="color: #2f81f7">' + hw + '</span>');
          }
        }
        editArea.dataset.rtInitial = rtVal;

        return fld;
      }

      // Standard inputs
      let input;
      switch (field.type) {
        case 'textarea':
          input = document.createElement('textarea');
          input.value = val;
          input.rows = 3;
          break;
        case 'select':
          input = document.createElement('select');
          (field.options || []).forEach(opt => {
            const o = document.createElement('option');
            o.value = opt; o.textContent = opt;
            if (opt === val) o.selected = true;
            input.appendChild(o);
          });
          break;
        case 'toggle':
          input = document.createElement('input');
          input.type = 'checkbox';
          input.checked = val === 'true' || val === '1';
          input.style.cssText = 'width:auto;margin-right:8px';
          break;
        case 'icon':
          var row = document.createElement('div');
          row.className = 'nova-field-row';
          row.innerHTML = '<i class="' + val + '" style="font-size:18px;color:var(--nova-accent);width:24px"></i>';
          input = document.createElement('input');
          input.type = 'text';
          input.value = val;
          input.placeholder = 'fa-solid fa-...';
          input.style.flex = '1';
          row.appendChild(input);
          fld.appendChild(row);
          input.dataset.key = key;
          input.addEventListener('input', function() {
            dirty = true;
            content[key] = this.value;
            var icon = this.parentElement.querySelector('i');
            if (icon) icon.className = this.value;
            var target = findTargetElement(selectedModuleEl, key);
            if (target && target.tagName === 'I') target.className = this.value;
          });
          return fld;
        case 'color':
          var crow = document.createElement('div');
          crow.className = 'nova-field-row';
          var colorInput = document.createElement('input');
          colorInput.type = 'color';
          colorInput.value = val.startsWith('#') ? val : '#3b82f6';
          input = document.createElement('input');
          input.type = 'text';
          input.value = val;
          input.style.flex = '1';
          crow.appendChild(colorInput);
          crow.appendChild(input);
          fld.appendChild(crow);
          colorInput.addEventListener('input', function() { input.value = this.value; input.dispatchEvent(new Event('input')); });
          input.addEventListener('input', function() { if (this.value.match(/^#[0-9a-f]{3,8}$/i)) colorInput.value = this.value; });
          input.dataset.key = key;
          input.addEventListener('input', function() { dirty = true; content[key] = this.value; });
          return fld;
        case 'media':
          input = document.createElement('input');
          input.type = 'text';
          input.value = val;
          input.dataset.key = key;
          fld.appendChild(input);
          setTimeout(() => makeMediaInput(input), 0);
          input.addEventListener('input', function() {
            dirty = true;
            content[key] = this.value;
          });
          return fld;
        default: // text, size
          input = document.createElement('input');
          input.type = 'text';
          input.value = val;
          break;
      }

      input.dataset.key = key;
      if (field.hint) input.placeholder = field.hint;
      if (!val && lang && lang !== 'es' && fallbackVal) {
        input.placeholder = fallbackVal.substring(0, 60) + '...';
      }

      fld.appendChild(input);

      // For button text fields: show route below
      var routeDisplay;
      if (isButton && !isPageLink) {
        const urlKey = field.key.replace(/_text$/, '_url').replace(/^cta_text$/, 'cta_url').replace(/^cta2_text$/, 'cta2_url');
        const urlVal = String(contentLookup(content, urlKey, null).val || '');
        if (urlVal) {
          routeDisplay = document.createElement('div');
          routeDisplay.className = 'nova-fld-link-display';
          routeDisplay.textContent = urlVal;
          fld.appendChild(routeDisplay);
        }
      }

      // Live update handler
      input.addEventListener('input', function() {
        dirty = true;
        var newVal = input.type === 'checkbox' ? String(input.checked) : input.value;
        content[key] = newVal;

        // Re-evaluate conditional visibility for fields that depend on this key
        document.querySelectorAll('[data-show-when-field="' + key + '"]').forEach(function(dep) {
          var allowedVals = (dep.dataset.showWhenValues || '').split(',');
          dep.style.display = allowedVals.includes(newVal) ? '' : 'none';
        });

        // Use domEl if available, else fallback to findTargetElement
        if (hasDomEl && selectedModuleEl) {
          const target = selectedModuleEl.querySelector('[data-nova-el="' + domElName + '"]');
          if (target) {
            if (domRead === 'innerHTML') {
              smartUpdateElement(target, newVal, content, key);
            } else if (domRead === 'textContent') {
              target.textContent = newVal;
            } else if (domRead === 'attribute' && field.domAttribute) {
              target.setAttribute(field.domAttribute, newVal);
            }
          }
        } else {
          var target = findTargetElement(selectedModuleEl, key);
          if (target) smartUpdateElement(target, newVal, content, key);
        }
      });
      // Select elements need 'change' as well (some browsers don't fire 'input' on <select>)
      if (input.tagName === 'SELECT') {
        input.addEventListener('change', function() { input.dispatchEvent(new Event('input')); });
      }

      return fld;
    }

    // ====== REGISTRY-BASED CONTENT RENDERING ======
    function renderRegistryContent(section, fieldsEl) {
      const reg = REGISTRY[section.component];
      if (!reg) return false;

      const content = section.content || {};

      // Render content sections
      for (const sect of reg.content) {
        const header = document.createElement('div');
        header.className = 'shared-divider';
        header.style.cssText = 'cursor:pointer;user-select:none;display:flex;justify-content:space-between;align-items:center';
        header.innerHTML = sect.section + ' <span style="font-size:10px;color:var(--nova-text-dim)">\u25bc</span>';

        const sectionBody = document.createElement('div');
        sectionBody.className = 'registry-section';

        let collapsed = sect.collapsed || false;
        if (collapsed) sectionBody.style.display = 'none';
        header.addEventListener('click', () => {
          collapsed = !collapsed;
          sectionBody.style.display = collapsed ? 'none' : '';
          header.querySelector('span').textContent = collapsed ? '\u25b6' : '\u25bc';
        });

        fieldsEl.appendChild(header);

        const trFields = sect.fields.filter(f => f.tr);
        const sharedFields = sect.fields.filter(f => !f.tr);

        if (trFields.length > 0) {
          LANGS.forEach(lang => {
            const container = document.createElement('div');
            container.className = 'lang-fields' + (lang === currentLang ? ' active' : '');
            container.dataset.lang = lang;
            for (const field of trFields) {
              container.appendChild(renderField(field, content, lang));
            }
            sectionBody.appendChild(container);
          });
        }

        for (const field of sharedFields) {
          sectionBody.appendChild(renderField(field, content, null));
        }

        fieldsEl.appendChild(sectionBody);
      }

      // Render repeaters
      for (const rep of reg.repeaters) {
        const existingRepDef = REPEATERS[section.component];
        if (existingRepDef) {
          renderRepeater(fieldsEl, content, existingRepDef);
        }
      }

      return true;
    }

    // ====== LANGUAGE SWITCHING ======
    function switchLang(lang) {
      if (lang === currentLang) return;
      // Before switching: flush the currently-active Tiptap editors
      // into their respective content keys so mid-edit data doesn't
      // vanish when the DOM container hides.
      (window.__tiptapInlineEditors || []).forEach(ed => {
        try {
          const editArea = ed.options?.element;
          const key = editArea?.dataset?.rtKey;
          if (!editArea || !key) return;
          // Only flush if this editor's field matches the old lang
          // (its wrapper's .lang-fields data-lang === currentLang).
          const wrap = editArea.closest('.lang-fields');
          if (wrap && wrap.dataset.lang !== currentLang) return;
          if (selectedModuleIdx < 0) return;
          const section = sections[selectedModuleIdx];
          if (!section || !section.content) return;
          let html = ed.getHTML();
          html = html.replace(/<br\s*\/?>/gi, '\n');
          const singleP = html.match(/^<p>([\s\S]*)<\/p>\s*$/);
          if (singleP && !singleP[1].includes('<p>')) html = singleP[1];
          section.content[key] = html.replace(/\n+$/, '');
        } catch {}
      });

      currentLang = lang;
      // Update inline lang-btn (old style)
      document.querySelectorAll('.lang-btn').forEach(b => b.classList.toggle('active', b.dataset.lang === lang));
      // Update global sidebar lang bar
      document.querySelectorAll('.nova-lang-btn').forEach(b => b.classList.toggle('active', b.dataset.lang === lang));

      // Reload the preview SSR with the chosen locale so module content
      // re-renders with the new translations. If there are unsaved edits,
      // confirm before navigating away.
      const url = new URL(window.location.href);
      const urlLang = url.searchParams.get('nova_preview_lang') || (window.__novaProjectDefaultLocale || 'en');
      if (urlLang !== lang) {
        if (dirty && !window.confirm('Ungespeicherte Änderungen gehen verloren beim Sprachwechsel. Trotzdem wechseln?')) {
          return;
        }
        if (lang === (window.__novaProjectDefaultLocale || 'en')) {
          url.searchParams.delete('nova_preview_lang');
        } else {
          url.searchParams.set('nova_preview_lang', lang);
        }
        window.location.href = url.toString();
        return;
      }
      // Show/hide language fields
      document.querySelectorAll('.lang-fields').forEach(c => c.classList.toggle('active', c.dataset.lang === lang));
    }

    // ====== MODULE SELECTION FROM PAGE ======
    // Extracted as reusable function so refreshPreview() can re-bind after DOM swap
    function bindModuleClickHandlers() {
      const mods = document.querySelectorAll('[data-nova-module]');
      mods.forEach((el, idx) => {
        if (el.dataset.novaBound === '1') return;
        el.dataset.novaBound = '1';
        el.addEventListener('click', (e) => {
          if (e.target.closest('.nova-sidebar') || e.target.closest('.nova-toolbar')) return;
          e.preventDefault();
          e.stopPropagation();
          if (selectedModuleIdx === idx) {
            const slotEl = e.target.closest('[data-nova-el]');
            if (slotEl && !slotEl.dataset.novaEl.endsWith('-section')) {
              selectSlot(slotEl.dataset.novaEl);
            }
          } else {
            openModuleFromList(idx);
          }
        });
      });
    }
    bindModuleClickHandlers();

    // ====== REPEATER LIVE PREVIEW: delegated input listener ======
    // Any edit to a .rep-field-input inside the editor schedules an auto-save
    // + preview refresh so users see item changes immediately in the page.
    document.getElementById('nova-content-fields')?.addEventListener('input', function(e) {
      const t = e.target;
      if (t && t.classList && t.classList.contains('rep-field-input')) {
        dirty = true;
        scheduleAutoSaveRefresh();
      }
    });

    // ====== CONTENT FIELDS (REGISTRY-BASED) ======
    function loadContentFields(idx) {
      const section = sections[idx];
      if (!section) return;

      const container = document.getElementById('nova-content-fields');
      container.innerHTML = '';

      const content = section.content || {};

      // Try registry-based rendering first
      const usedRegistry = renderRegistryContent(section, container);

      if (!usedRegistry) {
        // ---- FALLBACK: Dynamic field detection ----
        const translatableFields = new Map();
        const sharedFields = new Map();

        for (const [key, value] of Object.entries(content)) {
          if (Array.isArray(value) || (typeof value === 'object' && value !== null)) continue;
          const m = key.match(/^(.+)_(es|en|de)$/);
          if (m) {
            if (!translatableFields.has(m[1])) translatableFields.set(m[1], {});
            translatableFields.get(m[1])[m[2]] = String(value || '');
          } else {
            sharedFields.set(key, String(value || ''));
          }
        }

        if (translatableFields.size > 0) {
          LANGS.forEach(lang => {
            const langContainer = document.createElement('div');
            langContainer.className = 'lang-fields' + (lang === currentLang ? ' active' : '');
            langContainer.dataset.lang = lang;

            for (const [base, values] of translatableFields) {
              const fld = document.createElement('div');
              fld.className = 'nova-fld';
              const label = document.createElement('div');
              label.className = 'nova-fld-label';
              label.textContent = base.replace(/_/g, ' ');
              const val = values[lang] || '';
              const isLong = val.length > 50 || (values.es || '').length > 50;
              const inp = document.createElement(isLong ? 'textarea' : 'input');
              inp.value = val;
              inp.dataset.key = base + '_' + lang;
              if (!val && lang !== 'es' && values.es) inp.placeholder = values.es.substring(0, 60) + '...';
              if (!isLong) inp.type = 'text';
              inp.addEventListener('input', function() {
                dirty = true;
                content[inp.dataset.key] = inp.value;
                var target = findTargetElement(selectedModuleEl, inp.dataset.key);
                if (target) smartUpdateElement(target, inp.value, content, inp.dataset.key);
              });
              fld.appendChild(label);
              fld.appendChild(inp);
              langContainer.appendChild(fld);
            }
            container.appendChild(langContainer);
          });
        }

        if (sharedFields.size > 0) {
          if (translatableFields.size > 0) {
            const divider = document.createElement('div');
            divider.className = 'shared-divider';
            divider.textContent = 'Allgemein';
            container.appendChild(divider);
          }
          for (const [key, value] of sharedFields) {
            if (['items','steps','clients','locations','dashboard_stats','members','images'].includes(key)) continue;
            if (typeof value !== 'string') continue;
            const fld = document.createElement('div');
            fld.className = 'nova-fld';
            const label = document.createElement('div');
            label.className = 'nova-fld-label';
            label.textContent = key.replace(/_/g, ' ');
            const isMedia = key.match(/image|photo|poster|logo|avatar/i);
            const isUrl = key.match(/url$|href$/i) && !isMedia;
            const inp = document.createElement((!isMedia && value.length > 50) ? 'textarea' : 'input');
            inp.value = value;
            inp.dataset.key = key;
            if (inp.tagName === 'INPUT') inp.type = 'text';
            inp.addEventListener('input', function() {
              dirty = true;
              content[key] = this.value;
              var target = findTargetElement(selectedModuleEl, key);
              if (target) smartUpdateElement(target, this.value, content, key);
            });
            fld.appendChild(label);
            fld.appendChild(inp);
            container.appendChild(fld);
            if (isMedia) makeMediaInput(inp);
            if (isUrl) makePageLinkInput(inp);
          }
        }

        // Repeater rendering (LogoTicker now uses standard repeater with name+logo fields)
        {
          const repDef = REPEATERS[section.component];
          if (repDef) renderRepeater(container, content, repDef);
        }
      }

      // LogoTicker special case for registry path too
      if (usedRegistry && section.component === 'LogoTicker' && content.clients) {
        renderLogoTickerEditor(container, content);
      }

      // Simple array fields (clients) for non-LogoTicker fallback
      if (!usedRegistry && content.clients && Array.isArray(content.clients) && section.component !== 'LogoTicker') {
        const cDiv = document.createElement('div');
        cDiv.className = 'nova-fld';
        cDiv.innerHTML = '<div class="nova-fld-label">Clients (kommasepariert)</div>' +
          '<input type="text" id="nova-clients-field" value="' + content.clients.join(', ') + '" />';
        container.appendChild(cDiv);
        cDiv.querySelector('input').addEventListener('input', function() {
          dirty = true;
          section.content.clients = this.value.split(',').map(c => c.trim()).filter(Boolean);
        });
      }

      // ---- Initialize Tiptap inline editors for richtext fields ----
      initInlineTiptapEditors(container, section);
    }

    // ====== INLINE TIPTAP INITIALIZATION ======
    function initInlineTiptapEditors(container, section) {
      const content = section.content || {};

      // Destroy old editors
      (window.__tiptapInlineEditors || []).forEach(e => { try { e.destroy(); } catch {} });
      window.__tiptapInlineEditors = [];

      function doInit() {
        if (!window.__tiptap) return;
        const { Editor, StarterKit, Link, TextStyle, Color, Highlight, Underline } = window.__tiptap;

        container.querySelectorAll('.nova-rt-edit[data-rt-key]').forEach(editArea => {
          const key = editArea.dataset.rtKey;
          const domElName = editArea.dataset.rtDomEl;
          const domRead = editArea.dataset.rtDomRead;
          let initialHtml = editArea.dataset.rtInitial || '';
          const toolbar = editArea.previousElementSibling;

          // Normalize content for Tiptap: raw text with \n mixed with
          // HTML spans confuses the parser. Convert \n→<br>, wrap in
          // <p> if not already wrapped, so Tiptap sees well-formed HTML
          // and correctly parses Color marks from <span style="color:…">.
          if (initialHtml && !initialHtml.startsWith('<p>')) {
            initialHtml = '<p>' + initialHtml.replace(/\n/g, '<br>') + '</p>';
          }

          const editor = new Editor({
            element: editArea,
            extensions: [
              StarterKit.configure({ heading: false }),
              Link.configure({ openOnClick: false }),
              TextStyle,
              Color,
              Highlight.configure({ multicolor: true }),
              Underline,
            ],
            content: initialHtml || '<p></p>',
            onUpdate: ({ editor: ed }) => {
              const html = ed.getHTML();
              dirty = true;
              content[key] = html;

              // Live preview: write back to DOM — strip outer <p> wrapper
              // so the content inherits the parent element's styles (h1, span, etc.)
              // instead of adding a block-level <p> inside an inline/heading element.
              if (domElName && selectedModuleEl) {
                const target = selectedModuleEl.querySelector('[data-nova-el="' + domElName + '"]');
                if (target && domRead === 'innerHTML') {
                  let clean = html;
                  // Strip single outer <p>...</p> wrapper
                  const singleP = clean.match(/^<p>([\s\S]*)<\/p>$/);
                  if (singleP && !singleP[1].includes('<p>')) {
                    clean = singleP[1];
                  }
                  target.innerHTML = clean;
                }
              }
            },
          });

          window.__tiptapInlineEditors.push(editor);

          // Wire up toolbar buttons
          if (toolbar && toolbar.classList.contains('nova-rt-bar')) {
            toolbar.querySelectorAll('button[data-rt-cmd]').forEach(btn => {
              btn.addEventListener('click', (e) => {
                e.preventDefault();
                const cmd = btn.dataset.rtCmd;
                if (cmd === 'bold') editor.chain().focus().toggleBold().run();
                else if (cmd === 'italic') editor.chain().focus().toggleItalic().run();
                else if (cmd === 'underline') editor.chain().focus().toggleUnderline().run();
                else if (cmd === 'hardBreak') editor.chain().focus().setHardBreak().run();
                else if (cmd === 'link') {
                  const url = prompt('URL:');
                  if (url) editor.chain().focus().setLink({ href: url }).run();
                }
                else if (cmd === 'color') {
                  // Use the currently active color from palette
                  const activeColor = toolbar.querySelector('.nova-rt-color.active');
                  if (activeColor && activeColor.dataset.color && activeColor.dataset.color !== 'custom') {
                    editor.chain().focus().setColor(activeColor.dataset.color).run();
                  }
                }
                else if (cmd === 'highlight') {
                  // Hero-highlight mark: apply brand color to selection.
                  // The renderer normalizes <span style="color:…"> into
                  // <span data-nova-el="hero-highlight" class="text-brand-400">
                  // so the source of truth is this inline color, not a
                  // separate highlight_word field.
                  // Tiptap isActive() compares attrs by equality — can't
                  // use regex. Read the current color attribute directly.
                  const currentColor = editor.getAttributes('textStyle').color;
                  if (currentColor) {
                    editor.chain().focus().unsetColor().run();
                  } else {
                    editor.chain().focus().setColor('#2f81f7').run();
                  }
                }
              });
            });

            // Wire up color palette
            toolbar.querySelectorAll('.nova-rt-color').forEach(swatch => {
              swatch.addEventListener('click', () => {
                toolbar.querySelectorAll('.nova-rt-color').forEach(s => s.classList.remove('active'));
                swatch.classList.add('active');
                const color = swatch.dataset.color;
                if (color === 'custom') {
                  const pick = document.createElement('input');
                  pick.type = 'color';
                  pick.style.cssText = 'position:absolute;opacity:0;pointer-events:none';
                  document.body.appendChild(pick);
                  pick.click();
                  pick.addEventListener('input', () => {
                    editor.chain().focus().setColor(pick.value).run();
                    swatch.style.background = pick.value;
                    pick.remove();
                  });
                } else if (color) {
                  editor.chain().focus().setColor(color).run();
                }
              });
            });
          }
        });
      }

      if (window.__tiptap) {
        doInit();
      } else {
        window.addEventListener('tiptap-ready', doInit, { once: true });
      }

      // Also init full Tiptap for richtext textareas (body_html etc.) from old editor path
      function initFullTiptapEditors() {
        if (!window.__tiptap) {
          setTimeout(initFullTiptapEditors, 200);
          return;
        }
        const { Editor: Ed, StarterKit: SK, Link: Lk, Image: Img } = window.__tiptap;
        (window.__tiptapEditors || []).forEach(e => { try { e.destroy(); } catch {} });
        window.__tiptapEditors = [];

        const richFields = ['body_html', 'subtitle', 'body', 'description', 'teaser'];
        container.querySelectorAll('textarea.field-input[data-key]').forEach(ta => {
          const key = ta.dataset.key.replace(/_(es|en|de)$/, '');
          if (richFields.some(f => key.includes(f)) || ta.value.includes('<') || ta.classList.contains('tiptap-target')) {
            ta.style.display = 'none';
            const wrap = document.createElement('div');
            wrap.className = 'tiptap-wrap';
            ta.parentElement.appendChild(wrap);

            const toolbar = document.createElement('div');
            toolbar.className = 'tiptap-toolbar';
            toolbar.innerHTML = '<button data-cmd="h2" title="H2">H2</button><button data-cmd="h3" title="H3">H3</button><button data-cmd="h4" title="H4">H4</button><span class="sep"></span><button data-cmd="bold" title="Bold"><b>B</b></button><button data-cmd="italic" title="Italic"><i>I</i></button><span class="sep"></span><button data-cmd="bulletList" title="List">&#8226;</button><button data-cmd="orderedList" title="Numbered">1.</button><span class="sep"></span><button data-cmd="link" title="Link">&#128279;</button><button data-cmd="image" title="Image">&#128247;</button><span class="sep"></span><button data-cmd="code" title="HTML">&lt;/&gt;</button>';
            wrap.appendChild(toolbar);

            const editorEl = document.createElement('div');
            editorEl.className = 'tiptap-editor';
            wrap.appendChild(editorEl);

            const editor = new Ed({
              element: editorEl,
              extensions: [ SK, Lk.configure({ openOnClick: false }), Img ],
              content: ta.value || '<p></p>',
              onUpdate: ({ editor: ed }) => {
                ta.value = ed.getHTML();
                dirty = true;
                const sec = sections[selectedModuleIdx];
                if (sec) sec.content[ta.dataset.key] = ed.getHTML();
              },
            });
            window.__tiptapEditors.push(editor);

            let showingCode = false;
            const codeArea = document.createElement('textarea');
            codeArea.className = 'field-input tiptap-code';
            codeArea.style.display = 'none';
            wrap.appendChild(codeArea);

            toolbar.querySelectorAll('button').forEach(btn => {
              btn.addEventListener('click', (e) => {
                e.preventDefault();
                const cmd = btn.dataset.cmd;
                if (cmd === 'h2') editor.chain().focus().toggleHeading({ level: 2 }).run();
                else if (cmd === 'h3') editor.chain().focus().toggleHeading({ level: 3 }).run();
                else if (cmd === 'h4') editor.chain().focus().toggleHeading({ level: 4 }).run();
                else if (cmd === 'bold') editor.chain().focus().toggleBold().run();
                else if (cmd === 'italic') editor.chain().focus().toggleItalic().run();
                else if (cmd === 'bulletList') editor.chain().focus().toggleBulletList().run();
                else if (cmd === 'orderedList') editor.chain().focus().toggleOrderedList().run();
                else if (cmd === 'link') { const url = prompt('URL:'); if (url) editor.chain().focus().setLink({ href: url }).run(); }
                else if (cmd === 'image') { const src = prompt('Image URL:'); if (src) editor.chain().focus().setImage({ src }).run(); }
                else if (cmd === 'code') {
                  showingCode = !showingCode;
                  if (showingCode) { codeArea.value = editor.getHTML(); codeArea.style.display = ''; editorEl.style.display = 'none'; }
                  else { editor.commands.setContent(codeArea.value); ta.value = codeArea.value; codeArea.style.display = 'none'; editorEl.style.display = ''; }
                }
              });
            });
          }
        });
      }
      initFullTiptapEditors();
    }

    // ====== STYLE FIELDS ======
    // ====== MODULE-LEVEL STYLE PANEL ======
    // Renders: Background Image, Background Video, Background Overlay,
    // Theme (light/dark), Spacing. Persists into sections[idx].style and
    // triggers scheduleAutoSaveRefresh() so the preview updates live.
    function renderModuleLevelStyle(container, idx) {
      const section = sections[idx];
      if (!section) return;
      if (!section.style) section.style = {};
      const style = section.style;

      const panel = document.createElement('div');
      panel.className = 'nova-style-group';
      const header = document.createElement('div');
      header.className = 'nova-style-group-header';
      header.innerHTML = '<span>Modul-Hintergrund & Layout</span><span class="el-tag">module</span>';
      panel.appendChild(header);

      const body = document.createElement('div');
      body.className = 'nova-style-group-body';
      body.style.display = '';
      header.addEventListener('click', () => {
        body.style.display = body.style.display === 'none' ? '' : 'none';
      });

      // --- Background Image ---
      const bgImgWrap = document.createElement('div');
      bgImgWrap.className = 'nova-field';
      bgImgWrap.innerHTML = '<div class="nova-field-label">Hintergrundbild</div>';
      const bgImgInput = document.createElement('input');
      bgImgInput.type = 'text';
      bgImgInput.placeholder = '/images/bg.jpg oder https://…';
      bgImgInput.value = style.background_image || '';
      bgImgInput.style.cssText = 'width:100%';
      bgImgInput.addEventListener('input', () => {
        style.background_image = bgImgInput.value.trim();
        dirty = true;
        scheduleAutoSaveRefresh();
      });
      bgImgWrap.appendChild(bgImgInput);
      makeMediaInput(bgImgInput);
      body.appendChild(bgImgWrap);

      // --- Background Video ---
      const bgVidWrap = document.createElement('div');
      bgVidWrap.className = 'nova-field';
      bgVidWrap.innerHTML = '<div class="nova-field-label">Hintergrund-Video (mp4)</div>';
      const bgVidInput = document.createElement('input');
      bgVidInput.type = 'text';
      bgVidInput.placeholder = '/videos/hero.mp4';
      bgVidInput.value = style.background_video || '';
      bgVidInput.style.cssText = 'width:100%';
      bgVidInput.addEventListener('input', () => {
        style.background_video = bgVidInput.value.trim();
        dirty = true;
        scheduleAutoSaveRefresh();
      });
      bgVidWrap.appendChild(bgVidInput);
      makeMediaInput(bgVidInput);
      body.appendChild(bgVidWrap);

      // --- Background Overlay (rgba) ---
      const bgOvWrap = document.createElement('div');
      bgOvWrap.className = 'nova-field';
      bgOvWrap.innerHTML = '<div class="nova-field-label">Overlay (rgba oder gradient)</div>';
      const bgOvInput = document.createElement('input');
      bgOvInput.type = 'text';
      bgOvInput.placeholder = 'rgba(0,0,0,0.5) oder linear-gradient(…)';
      bgOvInput.value = style.background_overlay || '';
      bgOvInput.style.cssText = 'width:100%';
      bgOvInput.addEventListener('input', () => {
        style.background_overlay = bgOvInput.value.trim();
        dirty = true;
        scheduleAutoSaveRefresh();
      });
      bgOvWrap.appendChild(bgOvInput);
      body.appendChild(bgOvWrap);

      // --- Background Color (solid color behind the module) ---
      const bgColorWrap = document.createElement('div');
      bgColorWrap.className = 'nova-field';
      bgColorWrap.innerHTML = '<div class="nova-field-label">Hintergrundfarbe</div>';
      const bgColorRow = document.createElement('div');
      bgColorRow.className = 'nova-style-row';
      bgColorRow.style.gap = '6px';
      const bgColorInput = document.createElement('input');
      bgColorInput.type = 'color';
      bgColorInput.style.cssText = 'width:48px;height:32px;cursor:pointer;border:1px solid var(--nova-border);border-radius:4px;background:transparent';
      const bgColorText = document.createElement('input');
      bgColorText.type = 'text';
      bgColorText.placeholder = 'transparent, #0e1930, rgba(…)';
      bgColorText.style.cssText = 'flex:1';
      bgColorText.value = style.background_color || '';
      // If stored value is a plain hex, set the color picker too
      if (/^#[0-9a-fA-F]{6}$/.test(style.background_color || '')) bgColorInput.value = style.background_color;
      const applyBgColor = (val) => {
        if (val) style.background_color = val;
        else delete style.background_color;
        dirty = true;
        scheduleAutoSaveRefresh();
      };
      bgColorInput.addEventListener('input', () => {
        bgColorText.value = bgColorInput.value;
        applyBgColor(bgColorInput.value);
      });
      bgColorText.addEventListener('input', () => {
        applyBgColor(bgColorText.value.trim());
      });
      const bgColorClear = document.createElement('button');
      bgColorClear.type = 'button';
      bgColorClear.textContent = '\u00d7';
      bgColorClear.title = 'Farbe entfernen';
      bgColorClear.style.cssText = 'padding:4px 10px;background:var(--nova-surface2);border:1px solid var(--nova-border);color:var(--nova-text-muted);border-radius:4px;cursor:pointer';
      bgColorClear.addEventListener('click', () => {
        bgColorText.value = '';
        applyBgColor('');
      });
      bgColorRow.appendChild(bgColorInput);
      bgColorRow.appendChild(bgColorText);
      bgColorRow.appendChild(bgColorClear);
      bgColorWrap.appendChild(bgColorRow);
      body.appendChild(bgColorWrap);

      // --- Background Size / Position (only meaningful for images) ---
      const bgMetaRow = document.createElement('div');
      bgMetaRow.className = 'nova-style-row';
      bgMetaRow.style.marginTop = '6px';

      const sizeSel = document.createElement('select');
      ['cover','contain','auto','100% 100%'].forEach(v => {
        const o = document.createElement('option');
        o.value = v; o.textContent = 'size: ' + v;
        if ((style.background_size || 'cover') === v) o.selected = true;
        sizeSel.appendChild(o);
      });
      sizeSel.addEventListener('change', () => {
        style.background_size = sizeSel.value;
        dirty = true;
        scheduleAutoSaveRefresh();
      });

      const posInput = document.createElement('input');
      posInput.type = 'text';
      posInput.placeholder = 'center, top left, 50% 50%';
      posInput.value = style.background_position || 'center';
      posInput.style.cssText = 'flex:1';
      posInput.addEventListener('input', () => {
        style.background_position = posInput.value.trim();
        dirty = true;
        scheduleAutoSaveRefresh();
      });

      bgMetaRow.appendChild(sizeSel);
      bgMetaRow.appendChild(posInput);
      body.appendChild(bgMetaRow);

      // --- Theme / Spacing / Animation grid ---
      function addSelect(label, key, options) {
        const wrap = document.createElement('div');
        wrap.className = 'nova-field';
        wrap.style.marginTop = '10px';
        wrap.innerHTML = '<div class="nova-field-label">' + label + '</div>';
        const sel = document.createElement('select');
        sel.style.cssText = 'width:100%';
        options.forEach(([v, l]) => {
          const o = document.createElement('option');
          o.value = v; o.textContent = l;
          if ((style[key] || '') === v) o.selected = true;
          sel.appendChild(o);
        });
        sel.addEventListener('change', () => {
          if (sel.value) style[key] = sel.value;
          else delete style[key];
          dirty = true;
          scheduleAutoSaveRefresh();
        });
        wrap.appendChild(sel);
        body.appendChild(wrap);
      }

      addSelect('Theme', 'theme', [
        ['', '(Standard)'],
        ['dark', 'Dark'],
        ['light', 'Light'],
      ]);

      addSelect('Spacing', 'spacing', [
        ['', '(Standard)'],
        ['compact', 'Compact'],
        ['normal', 'Normal'],
        ['spacious', 'Spacious'],
      ]);

      addSelect('Entry-Animation', 'animation', [
        ['', '(Standard — Fade up)'],
        ['none', 'Keine Animation'],
        ['fade-up', 'Fade up'],
        ['fade-left', 'Fade left'],
        ['scale-in', 'Scale in'],
      ]);

      // --- Reset Button ---
      const resetBtn = document.createElement('button');
      resetBtn.type = 'button';
      resetBtn.textContent = 'Modul-Style zurücksetzen';
      resetBtn.style.cssText = 'margin-top:12px;width:100%;padding:6px 10px;background:transparent;border:1px solid var(--nova-border);border-radius:6px;color:var(--nova-text-dim);font-size:11px;cursor:pointer';
      resetBtn.addEventListener('click', () => {
        if (!confirm('Alle Modul-Style-Einstellungen (Hintergrund, Theme, Spacing, Animation) zurücksetzen?')) return;
        section.style = {};
        dirty = true;
        scheduleAutoSaveRefresh();
        loadStyleFields(selectedModuleEl || document.createElement('div'), idx);
      });
      body.appendChild(resetBtn);

      panel.appendChild(body);
      container.appendChild(panel);
    }

    function loadStyleFields(moduleEl, idx) {
      const container = document.getElementById('nova-style-fields');
      container.innerHTML = '';

      // ====== MODULE-LEVEL STYLE (bg image/video/overlay/theme) ======
      // Always render this first so it works regardless of whether the
      // module has data-nova-el children.
      renderModuleLevelStyle(container, idx);

      const elements = moduleEl.querySelectorAll('[data-nova-el]');
      if (!elements.length) {
        const hint = document.createElement('div');
        hint.className = 'nova-hint';
        hint.style.marginTop = '12px';
        hint.textContent = 'Keine steuerbaren Element-Slots in diesem Modul — nur Modul-Hintergrund oben verfügbar.';
        container.appendChild(hint);
        return;
      }

      const PROPS = {
        'color': { label: 'Textfarbe', type: 'color' },
        'background-color': { label: 'Hintergrund', type: 'color' },
        'background-image': { label: 'Hintergrundbild', type: 'bg-image' },
        'font-size': { label: 'Schriftgr\u00f6\u00dfe', type: 'text' },
        'font-weight': { label: 'Schriftst\u00e4rke', type: 'select', options: ['300','400','500','600','700','800'] },
        'padding': { label: 'Padding', type: 'text' },
        'margin': { label: 'Margin', type: 'text' },
        'border': { label: 'Border', type: 'text' },
        'border-radius': { label: 'Radius', type: 'text' },
        'opacity': { label: 'Transparenz', type: 'text' },
        'letter-spacing': { label: 'Zeichenabstand', type: 'text' },
      };

      elements.forEach(el => {
        const elId = el.dataset.novaEl;
        const computed = getComputedStyle(el);
        const group = document.createElement('div');
        group.className = 'nova-style-group';
        // Tag the group with its slot name so selectSlot() can auto-focus it
        group.dataset.slotName = elId;

        const groupHeader = document.createElement('div');
        groupHeader.className = 'nova-style-group-header';
        groupHeader.innerHTML = '<span>' + elId + '</span><span class="el-tag">' + el.tagName.toLowerCase() + '</span>';
        group.appendChild(groupHeader);

        const body = document.createElement('div');
        body.className = 'nova-style-group-body';
        body.style.display = 'none';

        groupHeader.addEventListener('click', () => {
          body.style.display = body.style.display === 'none' ? '' : 'none';
        });

        for (const [prop, config] of Object.entries(PROPS)) {
          const current = computed.getPropertyValue(prop).trim();
          if (!current || current === 'none' || current === 'normal') continue;

          const field = document.createElement('div');
          field.className = 'nova-field';

          if (config.type === 'color') {
            const display = rgbToHex(current);
            const hexClean = hexToDisplay(display);
            const isTransparent = display === 'transparent';
            const alphaMatch = current.match(/[\d.]+/g);
            const alpha = alphaMatch && alphaMatch.length >= 4 ? parseFloat(alphaMatch[3]) : 1;

            field.innerHTML = '<div class="nova-field-label">' + config.label + '</div>' +
              '<div class="nova-style-row">' +
              '<input type="color" value="' + (isTransparent ? '#000000' : hexClean) + '" />' +
              '<input type="text" value="' + display + '" style="flex:1" />' +
              '</div>' +
              '<div class="nova-style-row" style="margin-top:4px">' +
              '<label>Transparenz</label>' +
              '<input type="range" min="0" max="100" value="' + Math.round(alpha * 100) + '" />' +
              '<span style="font-size:10px;color:var(--nova-text-muted);width:30px;text-align:right">' + Math.round(alpha * 100) + '%</span>' +
              '</div>';

            const colorInput = field.querySelector('input[type="color"]');
            const textInput = field.querySelector('input[type="text"]');
            const rangeInput = field.querySelector('input[type="range"]');
            const alphaLabel = field.querySelector('span:last-child');
            const jsProp = prop.replace(/-([a-z])/g, (_, c) => c.toUpperCase());

            function applyColor() {
              const a = parseInt(rangeInput.value) / 100;
              const hex = colorInput.value;
              const r = parseInt(hex.slice(1,3), 16);
              const g = parseInt(hex.slice(3,5), 16);
              const b = parseInt(hex.slice(5,7), 16);
              el.style[jsProp] = 'rgba(' + r + ',' + g + ',' + b + ',' + a + ')';
              textInput.value = a < 1 ? hex + ' (' + Math.round(a*100) + '%)' : hex;
              alphaLabel.textContent = Math.round(a*100) + '%';
              dirty = true;
            }
            colorInput.addEventListener('input', applyColor);
            rangeInput.addEventListener('input', applyColor);
            textInput.addEventListener('input', () => {
              const val = textInput.value.trim();
              if (val === 'transparent') { el.style[jsProp] = 'transparent'; rangeInput.value = 0; alphaLabel.textContent = '0%'; }
              else if (val.startsWith('#')) { colorInput.value = val.slice(0,7); applyColor(); }
              else { el.style[jsProp] = val; }
              dirty = true;
            });
          } else if (config.type === 'bg-image' || prop === 'background-image') {
            const urlMatch = current.match(/url\("?([^")\s]+)"?\)/);
            const imgUrl = urlMatch ? urlMatch[1] : '';
            field.innerHTML = '<div class="nova-field-label">' + (config.label || 'Hintergrundbild') + '</div>' +
              (imgUrl ? '<img src="' + imgUrl + '" class="nova-img-preview" />' : '<div style="font-size:11px;color:var(--nova-text-dim);margin-bottom:4px">Kein Bild gesetzt</div>') +
              '<div class="nova-style-row"><input type="text" value="' + imgUrl + '" placeholder="URL oder /images/..." /></div>' +
              '<div class="nova-style-row" style="margin-top:4px"><label>Position</label><input type="text" value="' + (computed.backgroundPosition || 'center') + '" /></div>';
            const inputs = field.querySelectorAll('input[type="text"]');
            inputs[0].addEventListener('input', function() {
              el.style.backgroundImage = this.value ? 'url(' + this.value + ')' : 'none';
              el.style.backgroundSize = 'cover';
              const img = field.querySelector('img');
              if (img) img.src = this.value;
              dirty = true;
            });
            if (inputs[1]) {
              inputs[1].addEventListener('input', function() {
                el.style.backgroundPosition = this.value;
                dirty = true;
              });
            }
          } else if (config.type === 'select') {
            field.innerHTML = '<div class="nova-field-label">' + config.label + '</div>' +
              '<div class="nova-style-row"><select>' + config.options.map(o => '<option ' + (current === o ? 'selected' : '') + '>' + o + '</option>').join('') + '</select></div>';
            field.querySelector('select').addEventListener('change', (e) => {
              el.style[prop.replace(/-([a-z])/g, (_, c) => c.toUpperCase())] = e.target.value;
              dirty = true;
            });
          } else {
            field.innerHTML = '<div class="nova-field-label">' + config.label + '</div>' +
              '<div class="nova-style-row"><input type="text" value="' + current + '" /></div>';
            field.querySelector('input').addEventListener('input', (e) => {
              el.style[prop.replace(/-([a-z])/g, (_, c) => c.toUpperCase())] = e.target.value;
              dirty = true;
            });
          }

          body.appendChild(field);
        }

        // Check for <img> children (Hero/CTA background images)
        const bgImg = el.querySelector('img[class*="object-cover"], img[fetchpriority]');
        if (bgImg) {
          const imgField = document.createElement('div');
          imgField.className = 'nova-field';
          imgField.innerHTML = '<div class="nova-field-label">Hintergrundbild</div>' +
            '<img src="' + bgImg.src + '" class="nova-img-preview" />' +
            '<div class="nova-style-row"><input type="text" value="' + bgImg.getAttribute('src') + '" placeholder="Bild URL..." /></div>';
          imgField.querySelector('input').addEventListener('input', function() {
            bgImg.src = this.value;
            var preview = imgField.querySelector('img');
            if (preview) preview.src = this.value;
            dirty = true;
          });
          body.appendChild(imgField);

          const posField = document.createElement('div');
          posField.className = 'nova-field';
          posField.innerHTML = '<div class="nova-field-label">Bildposition</div>' +
            '<div class="nova-style-row"><input type="text" value="' + (bgImg.style.objectPosition || 'center') + '" placeholder="z.B. top center" /></div>';
          posField.querySelector('input').addEventListener('input', function() {
            bgImg.style.objectPosition = this.value;
            dirty = true;
          });
          body.appendChild(posField);
        }

        group.appendChild(body);
        if (body.children.length) container.appendChild(group);
      });

      // ---- DESIGN TOKENS ----
      const tokensGroup = document.createElement('div');
      tokensGroup.className = 'nova-style-group';
      tokensGroup.innerHTML =
        '<div class="nova-style-group-header"><span>Design Tokens</span><span class="el-tag">:root</span></div>' +
        '<div class="nova-style-group-body">' +
          '<div class="nova-tokens">' +
            '<div class="nova-token"><div class="nova-token-swatch" style="background:var(--nova-accent)"></div>Accent</div>' +
            '<div class="nova-token"><div class="nova-token-swatch" style="background:var(--nova-bg)"></div>Background</div>' +
            '<div class="nova-token"><div class="nova-token-swatch" style="background:var(--nova-text)"></div>Text</div>' +
            '<div class="nova-token"><div class="nova-token-swatch" style="background:var(--nova-text-muted)"></div>Muted</div>' +
          '</div>' +
        '</div>';
      const tokensBody = tokensGroup.querySelector('.nova-style-group-body');
      tokensBody.style.display = 'none';
      tokensGroup.querySelector('.nova-style-group-header').addEventListener('click', () => {
        tokensBody.style.display = tokensBody.style.display === 'none' ? '' : 'none';
      });
      container.appendChild(tokensGroup);

      // ---- ERWEITERT: Spacing Box Model ----
      const advGroup = document.createElement('div');
      advGroup.className = 'nova-style-group';
      const sectionEl = moduleEl;
      const cs = getComputedStyle(sectionEl);
      const mt = parseInt(cs.marginTop) || 0;
      const mr = parseInt(cs.marginRight) || 0;
      const mb = parseInt(cs.marginBottom) || 0;
      const ml = parseInt(cs.marginLeft) || 0;
      const pt = parseInt(cs.paddingTop) || 0;
      const pr = parseInt(cs.paddingRight) || 0;
      const pb = parseInt(cs.paddingBottom) || 0;
      const pl = parseInt(cs.paddingLeft) || 0;

      advGroup.innerHTML =
        '<div class="nova-style-group-header" style="color:var(--nova-text-dim)"><span>Erweitert</span><span class="el-tag">spacing &amp; overrides</span></div>' +
        '<div class="nova-style-group-body" style="display:none">' +
          '<div style="font-size:10px;color:var(--nova-text-dim);margin-bottom:8px">Nur anpassen wenn das Modul-Template nicht passt.</div>' +
          '<div class="nova-spacing-box">' +
            '<div class="nova-spacing-margin">' +
              '<span class="nova-spacing-val top nova-sp-m">' + mt + '</span>' +
              '<span class="nova-spacing-val left nova-sp-m">' + ml + '</span>' +
              '<span class="nova-spacing-val right nova-sp-m">' + mr + '</span>' +
              '<span class="nova-spacing-val bottom nova-sp-m">' + mb + '</span>' +
              '<div class="nova-spacing-padding">' +
                '<span class="nova-spacing-val top nova-sp-p">' + pt + '</span>' +
                '<span class="nova-spacing-val left nova-sp-p">' + pl + '</span>' +
                '<span class="nova-spacing-val right nova-sp-p">' + pr + '</span>' +
                '<span class="nova-spacing-val bottom nova-sp-p">' + pb + '</span>' +
                '<div class="nova-spacing-content">content</div>' +
              '</div>' +
            '</div>' +
          '</div>' +
        '</div>';
      advGroup.querySelector('.nova-style-group-header').addEventListener('click', () => {
        const b = advGroup.querySelector('.nova-style-group-body');
        b.style.display = b.style.display === 'none' ? '' : 'none';
      });
      container.appendChild(advGroup);

      if (!container.children.length) {
        container.innerHTML = '<div class="nova-hint">Keine Style-Eigenschaften erkannt.</div>';
      }
    }

    // ====== AI TAB ======
    // ===== Per-Module AI Chat (real API + action executor) =====
    function addAiMessage(who, html) {
      const msgs = document.getElementById('nova-ai-msgs');
      const msg = document.createElement('div');
      msg.className = 'nova-ai-msg ' + who;
      msg.innerHTML = '<div class="nova-ai-msg-who">' + (who === 'user' ? 'Du' : 'AI') + '</div>' +
        '<div class="nova-ai-msg-body">' + html + '</div>';
      msgs.appendChild(msg);
      msgs.scrollTop = msgs.scrollHeight;
      return msg;
    }

    // Quick-action buttons: pre-fill input + auto-send
    document.querySelectorAll('.nova-ai-quick-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const input = document.getElementById('nova-ai-input');
        input.value = btn.dataset.action || btn.textContent;
        document.getElementById('nova-ai-send')?.click();
      });
    });

    // Extract nova-action JSON blocks from AI response text
    function extractModuleActions(text) {
      const regex = /```nova-action\s*([\s\S]*?)```/g;
      const actions = [];
      let m;
      while ((m = regex.exec(text)) !== null) {
        try { actions.push(JSON.parse(m[1].trim())); } catch {}
      }
      return actions;
    }

    // Execute a per-module AI action (update text, color, etc.)
    async function executeModuleAction(action, moduleId) {
      if (!action || !action.action) return false;

      // update_module — change content fields
      if (action.action === 'update_module' && action.changes) {
        const mid = action.module_id || moduleId;
        if (!mid) return false;
        // Apply changes into the in-memory section + WP
        const section = sections[selectedModuleIdx];
        if (!section || !section.content) return false;
        Object.assign(section.content, action.changes);
        dirty = true;
        // Refresh the visible field values in the sidebar
        renderRegistryContent();
        // Refresh the page DOM — for each changed text field, update its [data-nova-el] target
        for (const [key, val] of Object.entries(action.changes)) {
          const baseMatch = key.match(/^(.+)_(es|en|de)$/);
          const base = baseMatch ? baseMatch[1] : key;
          // Only update if it matches the current language
          const lang = baseMatch ? baseMatch[2] : null;
          if (lang && lang !== currentLang) continue;
          const novaEl = selectedModuleEl?.querySelector('[data-nova-el*="' + base.replace(/_/g, '-') + '"]');
          if (novaEl) {
            if (novaEl.tagName === 'IMG') novaEl.src = String(val);
            else novaEl.textContent = String(val);
          }
        }
        return true;
      }

      // update_element — change inline CSS on a nova-el target
      if (action.action === 'update_element' && action.element_id && action.changes) {
        const target = selectedModuleEl?.querySelector('[data-nova-el="' + action.element_id + '"]');
        if (!target) return false;
        for (const [prop, val] of Object.entries(action.changes)) {
          const jsProp = prop.replace(/-([a-z])/g, (_, c) => c.toUpperCase());
          target.style[jsProp] = String(val);
        }
        // Also persist to section.overrides so it survives save
        const section = sections[selectedModuleIdx];
        if (section) {
          section.overrides = section.overrides || {};
          section.overrides.elements = section.overrides.elements || {};
          section.overrides.elements[action.element_id] = {
            ...(section.overrides.elements[action.element_id] || {}),
            ...action.changes,
          };
          dirty = true;
        }
        return true;
      }
      return false;
    }

    document.getElementById('nova-ai-send')?.addEventListener('click', async () => {
      const input = document.getElementById('nova-ai-input');
      const sendBtn = document.getElementById('nova-ai-send');
      const text = input.value.trim();
      if (!text) return;
      if (selectedModuleIdx < 0 || !sections[selectedModuleIdx]) {
        addAiMessage('ai', '<div style="color:var(--nova-red)">Kein Modul ausgew\u00e4hlt.</div>');
        return;
      }
      input.value = '';
      sendBtn.disabled = true;

      // Clear intro placeholder on first message
      const msgs = document.getElementById('nova-ai-msgs');
      if (msgs.children.length === 1 && !msgs.children[0].classList.contains('nova-ai-msg')) {
        msgs.innerHTML = '';
      }

      addAiMessage('user', text.replace(/</g, '&lt;'));
      const aiBubble = addAiMessage('ai', '<span style="color:var(--nova-text-dim)">KI denkt...</span>');
      const bodyEl = aiBubble.querySelector('.nova-ai-msg-body');

      const section = sections[selectedModuleIdx];
      const moduleContext = {
        pageId: pageId,
        pageName: slug,
        targetModule: {
          id: section.id,
          component: section.component,
          content: section.content,
          style: section.style,
        },
        sections: sections.map((s) => ({ component: s.component, id: s.id, title: s.title || s.component })),
      };

      let buffer = '';
      try {
        const res = await fetch('/api/ai/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message: text + '\n\n(Nutze update_module/update_element actions f\u00fcr \u00c4nderungen an Modul-ID ' + section.id + '.)',
            context: moduleContext,
          }),
        });
        if (!res.ok || !res.body) {
          bodyEl.innerHTML = '<span style="color:var(--nova-red)">API-Fehler ' + res.status + '</span>';
          return;
        }
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let sseBuffer = '';
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          sseBuffer += decoder.decode(value, { stream: true });
          const lines = sseBuffer.split('\n');
          sseBuffer = lines.pop() || '';
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            const payload = line.slice(6).trim();
            if (payload === '[DONE]') continue;
            try {
              const data = JSON.parse(payload);
              const delta = data.choices?.[0]?.delta?.content || '';
              if (delta) {
                buffer += delta;
                bodyEl.textContent = buffer.replace(/```nova-action[\s\S]*?```/g, '[Aktion...]');
                msgs.scrollTop = msgs.scrollHeight;
              }
            } catch {}
          }
        }

        // Execute actions from the full buffer
        const actions = extractModuleActions(buffer);
        if (actions.length > 0) {
          let applied = 0;
          for (const a of actions) {
            if (await executeModuleAction(a, section.id)) applied++;
          }
          const note = document.createElement('div');
          note.style.cssText = 'margin-top:6px;font-size:11px;color:var(--nova-green)';
          note.textContent = '\u2713 ' + applied + '/' + actions.length + ' Aktion(en) angewendet. Speichern nicht vergessen.';
          bodyEl.appendChild(note);
        }
      } catch (e) {
        bodyEl.innerHTML = '<span style="color:var(--nova-red)">Fehler: ' + String(e).replace(/</g, '&lt;') + '</span>';
      } finally {
        sendBtn.disabled = false;
      }
    });

    // Also send on Enter (without Shift)
    document.getElementById('nova-ai-input')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        document.getElementById('nova-ai-send')?.click();
      }
    });

    // ====== SAVE ======
    document.getElementById('nova-save')?.addEventListener('click', async () => {
      const btn = document.getElementById('nova-save');
      btn.disabled = true;
      btn.textContent = 'Speichert...';

      // Sync inline Tiptap editors before collecting
      (window.__tiptapInlineEditors || []).forEach(ed => {});
      (window.__tiptapEditors || []).forEach(ed => {});

      // Collect content from fields
      if (selectedModuleIdx >= 0) {
        const section = sections[selectedModuleIdx];
        const updatedContent = JSON.parse(JSON.stringify(section.content || {}));

        // 1. Standard inputs (text, textarea, select, checkbox)
        document.querySelectorAll('#nova-content-fields [data-key]').forEach(input => {
          updatedContent[input.dataset.key] = input.type === 'checkbox' ? String(input.checked) : input.value;
        });

        // 2. Tiptap inline editors (Rich Text / inline-html fields)
        //    Collect HTML from each Tiptap editor and normalize back to storage format
        (window.__tiptapInlineEditors || []).forEach(ed => {
          try {
            const editArea = ed.options.element;
            if (!editArea || !editArea.dataset.rtKey) return;
            const key = editArea.dataset.rtKey;
            let html = ed.getHTML();

            // ── NORMALIZER ──
            // Headlines now preserve their inline color-spans (Tiptap's
            // highlight = setColor). The renderer converts those spans
            // to hero-highlight on output, so we keep the mark intact
            // here. Legacy: clear any stale highlight_word field that
            // old saves might have left on this section.
            if (key.startsWith('headline') && updatedContent.highlight_word !== undefined) {
              delete updatedContent.highlight_word;
            }

            // Normalize Tiptap style="color: rgb(47, 129, 247)" variations
            // (with or without spaces/commas) back to the canonical hex
            // so saved markup is consistent.
            html = html.replace(
              /style="color:\s*rgb\(\s*47\s*,\s*129\s*,\s*247\s*\)\s*;?"/gi,
              'style="color: #2f81f7"'
            );

            // Convert <br> / <br /> to \n for headline-like fields
            html = html.replace(/<br\s*\/?>/gi, '\n');

            // Strip <p> wrapper if single paragraph
            const singleP = html.match(/^<p>([\s\S]*)<\/p>\s*$/);
            if (singleP && !singleP[1].includes('<p>')) {
              html = singleP[1];
            }

            // Trim trailing \n that comes from <br> at end of last line
            html = html.replace(/\n+$/, '');

            updatedContent[key] = html;
          } catch (e) { console.warn('Tiptap collect error:', e); }
        });

        // 3. Repeater data
        collectRepeaterData(updatedContent);
        // LogoTicker now uses standard repeater collector
        section.content = updatedContent;
      }

      try {
        await fetch('/api/revisions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ pageId }),
        });

        // For linked modules, push content to the central zds_module post
        // so all pages that reference it pick up the change. Do this BEFORE
        // we save the page's section list so the data is consistent.
        const linkedUpdates = sections
          .map((s, i) => ({ s, i }))
          .filter(({ s }) => s.mode === 'linked' && s.module_id);
        for (const { s } of linkedUpdates) {
          try {
            await fetch('/api/modules/' + s.module_id, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ content: s.content }),
            });
          } catch (e) {
            console.warn('linked module save failed:', s.module_id, e);
          }
        }

        const updatedSections = sections.map(s => {
          const mode = s.mode === 'linked' ? 'linked' : 'detached';
          const base = {
            id: s.id,
            type: s.component,
            mode,
            style: s.style && Object.keys(s.style).length ? s.style : undefined,
            visual_overrides: s.overrides || undefined,
          };
          if (mode === 'linked' && s.module_id) return { ...base, module_id: s.module_id };
          return { ...base, data: s.content };
        });

        const res = await fetch('/api/pages/' + pageId + '/sections', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sections: updatedSections }),
        });

        if (res.ok) {
          btn.textContent = '\u2713 Gespeichert!';
          btn.style.background = 'var(--nova-green)';
          dirty = false;
          novaToast('Gespeichert. Build l\u00e4uft\u2026', 'info', 2000);
          // Trigger rebuild + report back whether it succeeded.
          (async () => {
            try {
              const rb = await fetch('/api/rebuild', { method: 'POST' });
              if (rb.ok) {
                novaToast('\u2713 Seite ist live (Build fertig)', 'ok', 3000);
              } else {
                novaToast('Build fehlgeschlagen (' + rb.status + ')', 'err', 4000);
              }
            } catch (e) {
              novaToast('Build-Netzwerkfehler', 'err', 4000);
            }
          })();
          setTimeout(() => {
            btn.textContent = 'Speichern';
            btn.style.background = '';
            btn.disabled = false;
          }, 2000);
        } else {
          throw new Error('Save failed');
        }
      } catch {
        btn.textContent = 'Fehler!';
        btn.style.background = 'var(--nova-red)';
        setTimeout(() => { btn.textContent = 'Speichern'; btn.style.background = ''; btn.disabled = false; }, 2000);
      }
    });

    // ====== RESPONSIVE DEVICE PREVIEW ======
    // Desktop: inline editor (click-to-edit, Tiptap, etc.)
    // Tablet/Mobile: iframe preview at fixed viewport width so CSS
    // media queries actually evaluate at the narrow width (max-width
    // on <main> doesn't trigger Tailwind md:/lg: queries — only real
