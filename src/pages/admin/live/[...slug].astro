      const titleInput = document.getElementById('nova-seo-title');
      const descInput = document.getElementById('nova-seo-desc');
      const slugInput = document.getElementById('nova-seo-slug');
      const titleCount = document.getElementById('nova-seo-title-count');
      const descCount = document.getElementById('nova-seo-desc-count');
      const serpTitle = document.getElementById('nova-serp-title');
      const serpDesc = document.getElementById('nova-serp-desc');
      const serpUrl = document.getElementById('nova-serp-url');
      const saveBtn = document.getElementById('nova-seo-save');

      if (!btn || !panel) return;

      // Toggle
      btn.addEventListener('click', async function() {
        if (panel.style.display !== 'none') { panel.style.display = 'none'; return; }
        panel.style.display = '';
        // Always show a preview immediately — even before API returns.
        // If slug is set but other fields empty, preview still gives
        // a sensible placeholder with brand name + domain.
        if (!slugInput.value) slugInput.value = slug;
        updateCounters();
        updateSerpPreview();
        // Load real SEO data from WP in the background
        if (pageId) {
          try {
            const res = await fetch('/api/pages/' + pageId + '/seo');
            if (res.ok) {
              const data = await res.json();
              titleInput.value = data.title || titleInput.value;
              descInput.value = data.description || descInput.value;
              slugInput.value = data.slug || slug;
              updateCounters();
              updateSerpPreview();
            }
          } catch {}
        }
      });
      closeBtn?.addEventListener('click', function() { panel.style.display = 'none'; });

      // Close on outside click
      document.addEventListener('click', function(e) {
        if (panel.style.display !== 'none' && !panel.contains(e.target) && e.target !== btn) {
          panel.style.display = 'none';
        }
      });

      function updateCounters() {
        var tl = titleInput.value.length;
        var dl = descInput.value.length;
        titleCount.textContent = tl + '/60';
        titleCount.style.color = tl > 60 ? 'var(--nova-red)' : tl >= 50 ? 'var(--nova-green)' : 'var(--nova-text-dim)';
        descCount.textContent = dl + '/160';
        descCount.style.color = dl > 160 ? 'var(--nova-red)' : dl >= 140 ? 'var(--nova-green)' : 'var(--nova-text-dim)';
      }

      function updateSerpPreview() {
        var t = titleInput.value || slug + ' — ' + brandName;
        var d = descInput.value || 'Keine Meta Description gesetzt.';
        var s = slugInput.value || slug;
        serpTitle.textContent = t.length > 60 ? t.substring(0, 57) + '...' : t;
        serpDesc.textContent = d.length > 155 ? d.substring(0, 152) + '...' : d;
        serpUrl.textContent = siteDomain + ' › ' + s.replace(/\//g, ' › ');
      }

      titleInput?.addEventListener('input', function() { updateCounters(); updateSerpPreview(); });
      descInput?.addEventListener('input', function() { updateCounters(); updateSerpPreview(); });
      slugInput?.addEventListener('input', updateSerpPreview);

      // Save
      saveBtn?.addEventListener('click', async function() {
        saveBtn.disabled = true;
        saveBtn.textContent = 'Speichert...';
        try {
          const res = await fetch('/api/pages/' + pageId + '/seo', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              title: titleInput.value,
              description: descInput.value,
              slug: slugInput.value,
            }),
          });
          if (res.ok) {
            saveBtn.textContent = '\u2713 Gespeichert!';
            saveBtn.style.background = 'var(--nova-green)';
            setTimeout(function() {
              saveBtn.textContent = 'SEO speichern';
              saveBtn.style.background = '';
              saveBtn.disabled = false;
            }, 2000);
          } else throw new Error();
        } catch {
          saveBtn.textContent = 'Fehler!';
          saveBtn.style.background = 'var(--nova-red)';
          setTimeout(function() {
            saveBtn.textContent = 'SEO speichern';
            saveBtn.style.background = '';
            saveBtn.disabled = false;
          }, 2000);
        }
      });
    })();

