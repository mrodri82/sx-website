    (function deviceSwitcher() {
      const btns = document.querySelectorAll('.nova-device-btn');
      const main = document.querySelector('main');
      if (!main) return;

      // Build the iframe container once, keep it hidden until needed
      const iframeWrap = document.createElement('div');
      iframeWrap.id = 'nova-device-iframe-wrap';
      iframeWrap.style.cssText = 'display:none;position:fixed;top:calc(var(--toolbar-h) + var(--breadcrumb-h));left:0;right:var(--sidebar-w);bottom:0;z-index:90;background:#0a0e1a;overflow:auto;padding:24px 12px;transition:right 0.3s;';
      const iframe = document.createElement('iframe');
      iframe.id = 'nova-device-iframe';
      iframe.style.cssText = 'display:block;margin:0 auto;background:#fff;border:none;box-shadow:0 0 60px rgba(0,0,0,0.5);border-radius:8px;';
      iframeWrap.appendChild(iframe);
      const hint = document.createElement('div');
      hint.style.cssText = 'position:fixed;bottom:12px;left:50%;transform:translateX(-50%);color:var(--nova-text-muted);font-size:11px;background:var(--nova-surface);padding:6px 12px;border-radius:999px;border:1px solid var(--nova-border);pointer-events:none;';
      hint.textContent = 'Preview-Modus (read-only). Desktop w\u00e4hlen zum Editieren.';
      iframeWrap.appendChild(hint);
      document.body.appendChild(iframeWrap);
      // Keep iframe-wrap respecting the sidebar collapse state
      function syncRight() {
        iframeWrap.style.right = document.body.classList.contains('nova-collapsed') ? '40px' : 'var(--sidebar-w)';
      }
      new MutationObserver(syncRight).observe(document.body, { attributes: true, attributeFilter: ['class'] });
      syncRight();

      btns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          btns.forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          const device = btn.dataset.device;

          if (device === 'desktop') {
            iframeWrap.style.display = 'none';
            main.style.display = '';
            iframe.src = 'about:blank';
            return;
          }

          // Mobile or tablet: swap to iframe at true viewport width
          const width = device === 'mobile' ? 375 : 768;
          const pagePath = '/' + (slug === 'homepage' ? '' : slug);
          // ?nova-preview=1 tells BaseLayout this is an iframe preview
          const src = pagePath + (pagePath.includes('?') ? '&' : '?') + 'nova-preview=1';
          iframe.style.width = width + 'px';
          iframe.style.height = 'calc(100vh - var(--toolbar-h) - var(--breadcrumb-h) - 48px)';
          if (iframe.src !== window.location.origin + src) iframe.src = src;
          main.style.display = 'none';
          iframeWrap.style.display = 'block';
        });
      });
    })();

