---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import ModuleRenderer from '@/components/modules/ModuleRenderer.astro';
import { getPageSections } from '@/lib/wordpress';

let sections = [];
let seoTitle = '';
let seoDescription = '';
let ogImage = '';
let heroImage = '';
try {
  const result = await getPageSections('homepage');
  sections = result.sections;
  seoTitle = result.seoTitle || '';
  seoDescription = result.seoDescription || '';
  ogImage = result.ogImage || '';
} catch (err) {
  console.error('Failed to fetch sections from WP:', err);
}

---

<BaseLayout
  title={seoTitle || "SX Festival & Expo 2026 | Berlin — June 26-28"}
  description={seoDescription || "The world's most anticipated adult event. Modern Sex Culture."}
  ogImage={ogImage || undefined}
  heroImage={heroImage || undefined}
>
  <Navigation variant={sections.length === 0 ? 'solid' : 'transparent'} />
  {sections.length === 0 ? (
    <div class="min-h-[calc(100vh-98px)] pt-[98px] bg-black flex items-center justify-center">
      <p class="text-white/30 text-sm uppercase tracking-widest">Homepage unter Aufbau — Sektionen werden eine nach der anderen nachgebaut.</p>
    </div>
  ) : (
    <ModuleRenderer sections={sections} />
  )}
  <Footer />
</BaseLayout>
