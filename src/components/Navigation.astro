---
/**
 * SX Festival — Navigation
 * Matches sxtech.eu: 98px tall, transparent background, 3-line logo,
 * menu items right-aligned with yellow TICKETS button at the end.
 *
 * Prop `transparent` (default true) → the nav overlays page content.
 * On scroll, a subtle black fade appears so nav stays readable.
 */
interface Props {
  transparent?: boolean;
}
const { transparent = true } = Astro.props;

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const items = [
  { label: 'Regular Visitors', href: '/regular-visitors' },
  { label: 'Exhibitors & B2B', href: '/exhibitors-b2b' },
  { label: 'Creators',         href: '/creators' },
  { label: 'Program',          href: '/program' },
  { label: 'News',             href: '/news' },
];
---

<header class={`sx-nav fixed top-0 left-0 right-0 z-50 h-[98px] flex items-center ${transparent ? 'bg-transparent' : 'bg-black'}`} data-sx-nav>
  <div class="w-full max-w-[1600px] mx-auto px-8 flex items-center justify-between">
    <a href="/" class="sx-logo" style="color: var(--color-brand-500)">
      <span style="color: var(--color-brand-500)">sxfestival</span>
      <span style="color: var(--color-brand-500)">expo</span>
      <span style="color: var(--color-brand-500)">berlin</span>
    </a>

    <nav class="hidden md:flex items-center gap-10">
      {items.map((item) => {
        const active = current === item.href;
        return (
          <a href={item.href} class={`text-white text-[13px] font-medium uppercase tracking-[0.03em] hover:text-brand-500 transition-colors ${active ? 'text-brand-500' : ''}`}>
            {item.label}
          </a>
        );
      })}
      <a href="/regular-visitors" class="text-brand-500 text-[13px] font-bold uppercase tracking-[0.03em] hover:opacity-80 transition-opacity">TICKETS</a>
    </nav>

    <button id="sx-mobile-toggle" class="md:hidden text-white p-2" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <div id="sx-mobile-menu" class="hidden md:hidden fixed left-0 right-0 top-[98px] bg-black border-t border-white/10 px-6 py-4 space-y-3">
    {items.map((item) => (
      <a href={item.href} class="block text-white text-sm font-medium uppercase tracking-wider py-2">{item.label}</a>
    ))}
    <a href="/regular-visitors" class="sx-btn w-full mt-2">TICKETS</a>
  </div>
</header>

<script>
  const toggle = document.getElementById('sx-mobile-toggle');
  const menu = document.getElementById('sx-mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Fade nav bg on scroll so transparent nav stays readable
  const nav = document.querySelector('[data-sx-nav]');
  function onScroll() {
    if (!nav) return;
    const scrolled = window.scrollY > 40;
    nav.style.backgroundColor = scrolled ? 'rgba(0,0,0,0.88)' : '';
    nav.style.backdropFilter = scrolled ? 'blur(8px)' : '';
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
