---
/**
 * SX Festival — Navigation
 * 1:1 of sxtech.eu header (extracted 19.04.2026 via Playwright).
 *   - 98px fixed header, bg transparent (scroll fade to black/blur)
 *   - Layout: logo | menu (space-between) | TICKETS
 *   - Logo: Arial Nova 30px fw400, lh 26px, letter-spacing -2.1px, yellow, 3-line wrap
 *   - Menu items: Inter 16px fw400 uppercase white, padding 13px 20px
 *   - Active: yellow bg (#ecfd21), black text
 *   - TICKETS: Inter 18px fw700 yellow
 *
 * Prop `variant`:
 *   'transparent' (default) — overlay, fades on scroll
 *   'solid'                 — permanent black bg (for inner pages)
 */
interface Props { variant?: 'transparent' | 'solid' | 'light'; }
const { variant = 'transparent' } = Astro.props;

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const items = [
  { label: 'Regular Visitors', href: '/regular-visitors' },
  { label: 'Exhibitors & B2B', href: '/exhibitors-b2b' },
  { label: 'Creators',         href: '/creators' },
  { label: 'Program',          href: '/program' },
  { label: 'News',             href: '/news' },
];
const isActive = (href: string) => current === href || current.startsWith(href + '/');
---

<header
  class={`sx-nav fixed top-0 left-0 right-0 z-50 h-[98px] ${variant === 'solid' ? 'bg-black' : variant === 'light' ? 'bg-white' : 'bg-transparent'} ${variant === 'light' ? 'sx-nav--light' : ''}`}
  data-sx-nav
  data-variant={variant}
>
  <div class="sx-nav-inner h-full max-w-[1600px] mx-auto flex items-center pl-[50px] pr-[10px]" style="box-sizing:border-box;width:100%">
    <div class="w-full flex items-center justify-between gap-6">
      {/* Logo — sits in a 157px-wide column so the three words wrap one per line */}
      <a href="/" class="sx-nav-logo block" aria-label="SX Festival & Expo 2026 Berlin">
        sxfestival expo berlin
      </a>

      {/* Main menu (horizontal, justify between) */}
      <nav class="hidden md:flex items-center gap-0 flex-1 justify-center" aria-label="Main">
        <ul class="flex items-center gap-0 list-none p-0 m-0">
          {items.map((item) => {
            const active = isActive(item.href);
            return (
              <li class="m-0 p-0">
                <a
                  href={item.href}
                  class={`sx-menu-item ${active ? 'sx-menu-item--active' : ''}`}
                >{item.label}</a>
              </li>
            );
          })}
        </ul>
      </nav>

      {/* Tickets */}
      <a href="/regular-visitors" class="sx-tickets hidden md:inline-block">TICKETS</a>

      {/* Mobile toggle */}
      <button id="sx-mobile-toggle" class="md:hidden text-brand-500 p-2 ml-auto" aria-label="Menu">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile dropdown */}
  <div id="sx-mobile-menu" class="hidden md:hidden fixed inset-x-0 top-[98px] bg-black border-t border-white/10 px-6 py-4 z-40">
    <ul class="space-y-2 list-none p-0 m-0">
      {items.map((item) => {
        const active = isActive(item.href);
        return (
          <li><a href={item.href} class={`sx-menu-item block ${active ? 'sx-menu-item--active' : ''}`}>{item.label}</a></li>
        );
      })}
      <li><a href="/regular-visitors" class="sx-tickets block mt-2">TICKETS</a></li>
    </ul>
  </div>
</header>

<style is:global>
  .sx-nav-logo {
    /* Archivo Narrow (Google Font) is a condensed sans-serif visually
       identical to Arial Nova Condensed (which isn't available in
       browsers by default — Chromium rendered Arial fallback = wider,
       looked shrunk at 30px). Archivo Narrow loads guaranteed on every
       platform and preserves the Arial-Nova-Cond feel. */
    font-family: 'Barlow Condensed', 'Archivo Narrow', 'Arial Narrow', 'Arial Nova', Arial, sans-serif;
    font-size: 30px;
    font-weight: 700;
    line-height: 26px;
    letter-spacing: 0;
    color: var(--color-brand-500);
    width: 157px;
    flex: 0 0 157px;
    text-transform: lowercase;
    /* Three-word wrap happens naturally within 157px width */
    word-spacing: 100vw; /* forces each word to its own line */
  }
  .sx-menu-item {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0;
    color: #ffffff;
    padding: 13px 20px;
    display: inline-block;
    text-decoration: none;
    transition: background-color .15s, color .15s;
  }
  .sx-menu-item:hover {
    background-color: var(--color-brand-500);
    color: #000;
  }
  .sx-menu-item--active {
    background-color: var(--color-brand-500);
    color: #000;
  }
  .sx-tickets {
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
    color: var(--color-brand-500);
    text-decoration: none;
    padding: 0;
    white-space: nowrap;
    transition: opacity .15s;
  }
  .sx-tickets:hover { opacity: .8; }
  @media (max-width: 768px) {
    .sx-nav-inner { padding-left: 30px !important; padding-right: 16px !important; }
  }

  /* Light variant — used on /program: white bg, black logo + black menu items */
  .sx-nav--light .sx-nav-logo { color: #000 !important; }
  .sx-nav--light .sx-menu-item { color: #000 !important; }
  .sx-nav--light .sx-menu-item:hover { background: #000; color: #ecfd21 !important; }
  .sx-nav--light .sx-menu-item--active { background: #000; color: #ecfd21 !important; }
  .sx-nav--light .sx-tickets { color: #000 !important; }

  /* The mobile menu overlay is always black. Force menu items inside it to
     stay white regardless of nav theme — otherwise on the light /program
     nav the black menu items become invisible on the black overlay. */
  #sx-mobile-menu .sx-menu-item { color: #fff !important; }
  #sx-mobile-menu .sx-menu-item--active { background: #ecfd21; color: #000 !important; }
  #sx-mobile-menu .sx-menu-item:hover { background: #ecfd21; color: #000 !important; }
  #sx-mobile-menu .sx-tickets { color: #ecfd21 !important; }
</style>

<script>
  const toggle = document.getElementById('sx-mobile-toggle');
  const menu = document.getElementById('sx-mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  const nav = document.querySelector('[data-sx-nav]') as HTMLElement | null;
  const variant = nav?.dataset.variant || 'transparent';
  function onScroll() {
    if (!nav) return;
    if (variant === 'solid') return; // solid stays solid
    const scrolled = window.scrollY > 40;
    nav.style.backgroundColor = scrolled ? 'rgba(0,0,0,0.88)' : '';
    nav.style.backdropFilter = scrolled ? 'blur(8px)' : '';
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
