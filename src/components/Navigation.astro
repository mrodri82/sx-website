---
/**
 * SX Festival — Navigation
 *
 * Matches sxtech.eu: fixed top nav, black bg,
 * logo left, menu center-right, yellow TICKETS button far right.
 */
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const items = [
  { label: 'Regular Visitors', href: '/regular-visitors' },
  { label: 'Exhibitors & B2B', href: '/exhibitors-b2b' },
  { label: 'Creators',         href: '/creators' },
  { label: 'Program',          href: '/program' },
  { label: 'News',             href: '/news' },
];
---

<header class="sx-nav fixed top-0 left-0 right-0 z-50 bg-black/95 backdrop-blur-sm border-b border-white/5">
  <div class="max-w-[1600px] mx-auto px-6 py-3 flex items-center justify-between">
    <a href="/" class="text-white font-black text-xs uppercase tracking-tight leading-tight flex-shrink-0">
      <span class="block">sxfestival</span>
      <span class="block">expo</span>
      <span class="block text-brand-500">berlin</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {items.map((item) => {
        const active = current === item.href;
        return (
          <a href={item.href} class={`text-white text-xs font-bold uppercase tracking-wider hover:text-brand-500 transition-colors ${active ? 'text-brand-500' : ''}`}>
            {item.label}
          </a>
        );
      })}
    </nav>

    <a href="/regular-visitors" class="sx-btn text-xs">TICKETS</a>

    <button id="sx-mobile-toggle" class="md:hidden text-white p-2" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <div id="sx-mobile-menu" class="hidden md:hidden border-t border-white/5 bg-black px-6 py-4 space-y-3">
    {items.map((item) => (
      <a href={item.href} class="block text-white text-sm font-bold uppercase tracking-wider py-2">{item.label}</a>
    ))}
    <a href="/regular-visitors" class="sx-btn text-xs w-full mt-2">TICKETS</a>
  </div>
</header>

<script>
  const toggle = document.getElementById('sx-mobile-toggle');
  const menu = document.getElementById('sx-mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
