---
/**
 * HeroSimple — inner-page hero (black bg, yellow title, optional subtitle + CTAs).
 * Supports image OR video background. When a media background is present, the
 * hero extends to the very top (under a transparent nav) and the first 98px
 * of inner padding keep the content from colliding with the nav. Plain-black
 * hero pages use a solid nav and sit below it (margin-top: 98px).
 *
 * Fields:
 *   - title:      big yellow Oswald headline
 *   - subtitle:   smaller subtitle line
 *   - cta_text / cta_url:   primary CTA
 *   - cta2_text / cta2_url: optional secondary CTA
 *   - bg_image:   optional hero background image URL
 *   - video_url:  optional hero background video URL (mp4) — wins over bg_image
 *   - poster_url: optional video poster frame
 */
interface Props { content: Record<string, any>; }
const { content = {} } = Astro.props;
const title    = content.title    || '';
const subtitle = content.subtitle || '';
const ctaText  = content.cta_text || '';
const ctaUrl   = content.cta_url  || '#';
const cta2Text = content.cta2_text || '';
const cta2Url  = content.cta2_url  || '#';
const bgImage  = content.bg_image || '';
const videoUrl = content.video_url || '';
const poster   = content.poster_url || '';
/* chips can be strings ('26.6.26') or objects with per-chip style variant:
   { label, href?, variant: 'primary' | 'muted' }. primary = orange bg /
   muted font (first date on sxtech). muted = grey bg / yellow font. */
const chips: Array<{label?: string; href?: string; variant?: string} | string> = Array.isArray(content.chips) ? content.chips : [];
const minHeight = content.min_height || '';
const theme = (content.theme === 'light' ? 'light' : 'dark') as 'light'|'dark';
const align = (content.align === 'center' ? 'center' : 'start') as 'center'|'start';
/* Vertical alignment of the content block inside the hero — 'end' pushes
   title + subtitle + ctas to the bottom edge (blog article cover). */
const valign = (['end','start','center'].includes(content.valign) ? content.valign : 'center') as 'center'|'start'|'end';
/* cta2_variant: 'ghost' (default, yellow border + transparent) | 'solid' (yellow fill)
   | 'white' (white fill + white border). cta2_ghost=false kept as legacy shortcut. */
const cta2Variant = (content.cta2_variant as string)
  || (content.cta2_ghost === false ? 'solid' : 'ghost');
const ctaVariant = (content.cta_variant as string) || 'solid';

const hasMedia = !!(videoUrl || bgImage);
---

<section
  data-nova-el="hero-simple"
  class={`sx-hs sx-hs--${theme} sx-hs--align-${align} sx-hs--valign-${valign} ${hasMedia ? 'sx-hs--overlay' : ''}`}
  style={`${bgImage ? `--hs-bg:url('${bgImage}');` : ''}${minHeight ? `min-height:${minHeight};` : ''}`}
>
  {videoUrl && (
    <video class="sx-hs-video" autoplay muted loop playsinline preload="metadata" poster={poster || undefined}>
      <source src={videoUrl} type="video/mp4" />
    </video>
  )}
  {bgImage && !videoUrl && <div class="sx-hs-bg" aria-hidden="true"></div>}
  {hasMedia && <div class="sx-hs-gradient" aria-hidden="true"></div>}

  <div class="sx-hs-inner">
    {title && <h1 class="sx-hs-title">{title}</h1>}
    {chips.length > 0 && (
      <div class="sx-hs-chips">
        {chips.map((c: any) => {
          const label = typeof c === 'string' ? c : (c?.label || '');
          const href = typeof c === 'string' ? undefined : c?.href;
          const v = (typeof c === 'object' && c?.variant) ? c.variant : 'default';
          const cls = `sx-hs-chip sx-hs-chip--${v}`;
          return href ? <a class={cls} href={href}>{label}</a> : <span class={cls}>{label}</span>;
        })}
      </div>
    )}
    {subtitle && <p class="sx-hs-sub">{subtitle}</p>}
    {(ctaText || cta2Text) && (
      <div class="sx-hs-ctas">
        {ctaText  && <a href={ctaUrl}  class={`sx-hs-cta${ctaVariant !== 'solid' ? ' sx-hs-cta--' + ctaVariant : ''}`} set:html={ctaText} />}
        {cta2Text && <a href={cta2Url} class={`sx-hs-cta${cta2Variant !== 'solid' ? ' sx-hs-cta--' + cta2Variant : ''}`} set:html={cta2Text} />}
      </div>
    )}
  </div>
</section>

<style>
  /* Values from sxtech.eu post-17.css / post-19.css / post-23.css. */
  .sx-hs {
    background: #000; color: #ecfd21;
    padding: 50px; margin-top: 98px;
    min-height: 88vh;
    display: flex; flex-direction: column; justify-content: center; align-items: flex-start;
    position: relative; isolation: isolate; overflow: hidden;
  }
  /* Light theme (program page) — white bg, black text, centered defaults */
  .sx-hs--light { background: #FFFFFF; color: #000; }
  .sx-hs--light .sx-hs-title { color: #000; }
  .sx-hs--light .sx-hs-sub   { color: #000; }
  .sx-hs--align-center { align-items: center; text-align: center; }
  .sx-hs--align-center .sx-hs-inner { text-align: center; }
  .sx-hs--align-center .sx-hs-ctas,
  .sx-hs--align-center .sx-hs-chips { justify-content: center; }
  /* Vertical placement of the content block. Default = center (see base rule). */
  .sx-hs--valign-start  { justify-content: flex-start; }
  .sx-hs--valign-end    { justify-content: flex-end; }
  /* With media BG: hero extends to top (transparent nav overlays it). */
  .sx-hs--overlay { margin-top: 0; padding: 140px 50px 50px; min-height: 100vh; }

  .sx-hs-video {
    position: absolute; inset: 0; z-index: 0;
    width: 100%; height: 100%; object-fit: cover;
    pointer-events: none;
  }
  .sx-hs-bg {
    position: absolute; inset: 0; z-index: 0;
    background-image: var(--hs-bg); background-size: cover; background-position: center;
    pointer-events: none;
  }
  .sx-hs-gradient {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0) 40%);
    pointer-events: none;
  }
  /* Blog-hero style (valign=end): full-height multiply overlay matching
     sxtech's Elementor "background-overlay" — top #000 → bottom #585858
     blended via multiply so the photo underneath still reads but sits
     behind a uniform dimming. Opacity halved so the image keeps its
     natural contrast; full multiply was far too dark. */
  .sx-hs--overlay.sx-hs--valign-end .sx-hs-gradient {
    background: linear-gradient(180deg, #000000 0%, #585858 100%);
    mix-blend-mode: multiply;
    opacity: 0.5;
  }
  .sx-hs-inner { position: relative; z-index: 2; max-width: 1440px; width: 100%; margin: 0 auto; text-align: start; }

  .sx-hs-title {
    font-family: 'Oswald', sans-serif; font-weight: 800;
    font-size: 156px; line-height: 1;
    letter-spacing: -6px; text-transform: uppercase;
    color: #ecfd21; margin: 0 0 24px;
    white-space: pre-line;
  }
  /* Blog-style hero — smaller headline than the big landing-page heroes.
     sxtech renders blog post titles at 81 px on a 1920 viewport, and the
     title sits right at the bottom edge (~10px gap), so we zero the
     title margin AND cut the overlay's bottom padding down. */
  .sx-hs--overlay.sx-hs--valign-end { padding-bottom: 10px; }
  .sx-hs--overlay.sx-hs--valign-end .sx-hs-title {
    font-size: 81px; letter-spacing: -3px; margin-bottom: 0;
  }
  .sx-hs-sub {
    font-family: 'Inter', sans-serif; font-size: 21px; font-weight: 500;
    line-height: 21px;
    color: #ecfd21; text-transform: uppercase;
    margin: 0 0 40px;
    white-space: pre-line;
  }
  .sx-hs-chips {
    display: flex; flex-wrap: wrap; gap: 12px;
    margin: 0 0 32px;
  }
  .sx-hs-chip {
    display: inline-block;
    background: #ecfd21; color: #000; text-decoration: none;
    padding: 8px 24px;
    font-family: 'Oswald', sans-serif; font-size: 20px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 1px;
    border-radius: 999px;
    /* sxtech measured pill width (desktop) — keeps all 3 date pills the
       same physical size regardless of the text they carry. */
    min-width: 268.325px;
    text-align: center;
  }
  .sx-hs-chip--primary { background: #FF6600; color: #555; }
  .sx-hs-chip--muted   { background: #D1D1D1; color: #ecfd21; }
  .sx-hs-ctas { display: flex; flex-wrap: wrap; gap: 12px; }
  .sx-hs-cta {
    display: inline-block;
    background: #ecfd21; color: #000; text-decoration: none;
    padding: 18px 36px;
    font-family: 'Inter', sans-serif; font-size: 19px; font-weight: 500;
    text-transform: uppercase;
    border: 1px solid #ecfd21;
    white-space: pre-line; text-align: center; line-height: 1.2;
    transition: background .15s, color .15s, border-color .15s;
  }
  .sx-hs-cta:hover { background: transparent; color: #ecfd21; border-color: #FFFFFF; }
  .sx-hs-cta--ghost { background: transparent; color: #ecfd21; }
  .sx-hs-cta--ghost:hover { background: #ecfd21; color: #000; border-color: #ecfd21; }
  .sx-hs-cta--white { background: #FFFFFF; color: #000; border-color: #FFFFFF; }
  .sx-hs-cta--white:hover { background: transparent; color: #FFFFFF; border-color: #FFFFFF; }
  /* black: black bg, white text (program page "BUY TICKET") */
  .sx-hs-cta--black { background: #000; color: #FFFFFF; border-color: #000; }
  .sx-hs-cta--black:hover { background: transparent; color: #000; border-color: #000; }

  @media (max-width: 1440px) {
    .sx-hs-title { font-size: 138px; letter-spacing: -5px; }
  }
  @media (max-width: 1024px) {
    .sx-hs-title { font-size: 131px; letter-spacing: -4px; }
  }
  @media (max-width: 768px) {
    .sx-hs { padding: 40px 24px 60px; min-height: 0; display: block; }
    .sx-hs--overlay { padding: 120px 24px 60px; min-height: 80vh; display: flex; }
    .sx-hs-inner { display: block; }
    .sx-hs-title { font-size: 65px; letter-spacing: -2px; margin-bottom: 24px; }
    .sx-hs-sub { font-size: 16px; line-height: 16px; margin-bottom: 32px; }
    .sx-hs-cta { font-size: 16px; padding: 16px 28px; }
    .sx-hs-ctas { flex-direction: column; gap: 14px; align-items: stretch; }
    .sx-hs-chip { min-width: 0; padding: 6px 18px; font-size: 16px; }
  }
</style>
