---
/**
 * HeroSimple — inner-page hero (black bg, yellow title, optional subtitle + CTA).
 * Used on regular-visitors / exhibitors-b2b / creators / program / news.
 *
 * Fields:
 *   - title:    big yellow Oswald headline
 *   - subtitle: smaller grey subtitle (#D1D1D1)
 *   - cta_text: optional CTA button label
 *   - cta_url:  CTA href
 *   - bg_image: optional hero background image URL
 */
interface Props { content: Record<string, any>; }
const { content = {} } = Astro.props;
const title    = content.title    || '';
const subtitle = content.subtitle || '';
const ctaText  = content.cta_text || '';
const ctaUrl   = content.cta_url  || '#';
const bgImage  = content.bg_image || '';
---

<section data-nova-el="hero-simple" class="sx-hs" style={bgImage ? `--hs-bg:url('${bgImage}')` : ''}>
  {bgImage && <div class="sx-hs-bg" aria-hidden="true"></div>}
  <div class="sx-hs-inner">
    {title && <h1 class="sx-hs-title">{title}</h1>}
    {subtitle && <p class="sx-hs-sub">{subtitle}</p>}
    {ctaText && <a href={ctaUrl} class="sx-hs-cta">{ctaText}</a>}
  </div>
</section>

<style>
  /* Values extracted 1:1 from sxtech.eu post-17.css — keep in sync with scraped CSS. */
  /* HeroSimple is only used on inner pages (solid 98px nav).
     margin-top: 98px pushes the hero below the fixed nav (no overlap).
     min-height/flex matches sxtech post-17 container 5621734 (88vh, centered). */
  .sx-hs {
    background: #000; color: #ecfd21;
    padding: 50px; margin-top: 98px;
    min-height: 88vh;
    display: flex; flex-direction: column; justify-content: center; align-items: flex-start;
    position: relative; isolation: isolate;
  }
  .sx-hs-bg {
    position: absolute; inset: 0; z-index: 0;
    background-image: var(--hs-bg); background-size: cover; background-position: center;
    pointer-events: none;
  }
  .sx-hs-inner { position: relative; z-index: 1; max-width: 1366px; width: 100%; margin: 0 auto; text-align: start; }
  .sx-hs-title {
    font-family: 'Oswald', sans-serif; font-weight: 800;
    font-size: 156px; line-height: 1;
    letter-spacing: -6px; text-transform: uppercase;
    color: #ecfd21; margin: 0 0 24px;
    white-space: pre-line;
  }
  /* Subtitle values = computed style on sxtech.eu (not naive grep — the 23px
     value in the CSS was overridden by a later @media cascade to 16px). */
  .sx-hs-sub {
    font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 500;
    line-height: 16px; height: 48px;
    color: #ecfd21; text-transform: uppercase;
    margin: 0 0 40px;
    white-space: pre-line;
  }
  .sx-hs-cta {
    display: inline-block;
    background: #ecfd21; color: #000; text-decoration: none;
    padding: 25px 50px;
    font-family: 'Inter', sans-serif; font-size: 28px; font-weight: 500;
    border: 1px solid #ecfd21;
    transition: background .15s, color .15s, border-color .15s;
  }
  .sx-hs-cta:hover { background: transparent; color: #ecfd21; border-color: #FFFFFF; }

  @media (max-width: 1366px) {
    .sx-hs-title { font-size: 138px; letter-spacing: -5px; }
  }
  @media (max-width: 1024px) {
    .sx-hs-title { font-size: 131px; letter-spacing: -4px; }
  }
  @media (max-width: 768px) {
    .sx-hs { padding: 40px 24px; min-height: 70vh; }
    .sx-hs-title { font-size: 65px; letter-spacing: -2px; }
    .sx-hs-cta { font-size: 18px; padding: 20px 40px; }
  }
</style>
