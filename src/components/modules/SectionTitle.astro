---
/**
 * SectionTitle — simple heading block, optionally with subtitle underneath.
 * Two size variants (via content.size):
 *   - 'sm' (default): Oswald 42px 600 uppercase yellow (e.g. "All the Things You Can't Skip")
 *   - 'lg': Oswald ~180px 900 uppercase white (e.g. "PROGRAM", "TOP VOICES")
 * Optional subtitle color override via content.subtitle_color.
 */
interface Props { content: Record<string, any>; }
const { content = {} } = Astro.props;
const title    = content.title    || '';
const subtitle = content.subtitle || '';
const size     = (['sm','md','lg'].includes(content.size) ? content.size : 'sm') as 'sm'|'md'|'lg';
const align    = (content.align === 'center' ? 'center' : 'start') as 'center'|'start';
/* subtitle_style:
   - default (size=sm): Oswald 42px 600 grey
   - default (size=lg): Inter 28px 500 white
   - 'event':           Oswald 72px 600 yellow (e.g. "june 27-28 berlin") */
const subStyle = content.subtitle_style || 'default';
const subColor = content.subtitle_color || '';
const layout   = (content.layout === 'row' ? 'row' : 'stack') as 'row' | 'stack';
const theme    = (content.theme === 'light' ? 'light' : 'dark') as 'light'|'dark';
---

<section data-nova-el="section-title" class={`sx-st sx-st--${size} sx-st--${layout} sx-st--sub-${subStyle} sx-st--align-${align} sx-st--${theme}`}>
  <div class="sx-st-inner">
    {title && <h2 class="sx-st-title">{title}</h2>}
    {subtitle && <p class="sx-st-sub" style={subColor ? `color:${subColor}` : undefined}>{subtitle}</p>}
  </div>
</section>

<style>
  /* Values from sxtech.eu post-19.css: 0140824/d7f9bc6 (sm) + 6481459/def8cbe (lg). */
  .sx-st { background: #000; padding: 40px 50px; }
  .sx-st--light { background: #FFFFFF; }
  .sx-st--light .sx-st-title,
  .sx-st--light .sx-st-sub { color: #000 !important; }
  .sx-st-inner { max-width: 1366px; margin: 0 auto; }
  .sx-st-title {
    font-family: 'Oswald', sans-serif; margin: 0;
    text-transform: uppercase; line-height: 1;
    white-space: pre-line;
  }
  .sx-st-sub {
    font-family: 'Oswald', sans-serif; margin: 8px 0 0;
    text-transform: uppercase; line-height: 1; font-weight: 600;
  }

  .sx-st--sm .sx-st-title { font-size: 42px; font-weight: 600; color: #ecfd21; }
  .sx-st--sm .sx-st-sub   { font-size: 42px; color: #A6A6A6; }

  /* md — used above sliders / tables (TOP VOICES, HOT TOPICS). Smaller + often centered. */
  .sx-st--md { padding: 40px 50px 20px; }
  .sx-st--md .sx-st-title { font-size: 80px; font-weight: 900; color: #FFFFFF; letter-spacing: -2px; line-height: 1; }
  .sx-st--md .sx-st-sub   { font-size: 20px; font-family: 'Inter', sans-serif; font-weight: 500; color: #FFFFFF; }

  /* lg — full-section headings (THE B2B, PROGRAM). 140px matches sxtech visual scale at 1440px. */
  .sx-st--lg { padding: 60px 50px; }
  .sx-st--lg .sx-st-title { font-size: 140px; font-weight: 900; color: #FFFFFF; letter-spacing: -4px; line-height: 1; }
  .sx-st--lg .sx-st-sub   { font-size: 28px; font-family: 'Inter', sans-serif; font-weight: 500; color: #FFFFFF; }

  .sx-st--align-center .sx-st-inner,
  .sx-st--align-center .sx-st-title,
  .sx-st--align-center .sx-st-sub { text-align: center; }

  /* layout='row': title col1 + subtitle col2, top-aligned, natural gap (no space-between).
     Example: "THE B2B\nPROGRAM" left, "JUNE 27-28\nBERLIN" right, columns sit next to each other. */
  .sx-st--row .sx-st-inner {
    display: flex; flex-direction: row; align-items: flex-start;
    gap: 60px; flex-wrap: wrap;
  }
  .sx-st--row .sx-st-title { flex: 0 0 auto; margin-bottom: 0; }
  .sx-st--row .sx-st-sub   { flex: 0 0 auto; margin-top: 0; }

  /* Event-style subtitle: Oswald 72px 600 yellow, stacked (e.g. "june 27-28\nberlin"). */
  .sx-st--sub-event .sx-st-sub {
    font-family: 'Oswald', sans-serif; font-size: 72px; font-weight: 600;
    color: #ecfd21; text-transform: uppercase;
    white-space: pre-line; line-height: .95; margin-top: 16px;
  }

  @media (max-width: 1200px) {
    .sx-st--lg .sx-st-title { font-size: 110px; letter-spacing: -3px; }
  }
  @media (max-width: 1024px) {
    .sx-st--lg .sx-st-title { font-size: 88px; letter-spacing: -3px; }
    .sx-st--md .sx-st-title { font-size: 56px; letter-spacing: -1px; }
    .sx-st--sub-event .sx-st-sub { font-size: 56px; }
    .sx-st--row .sx-st-inner { flex-direction: column; align-items: flex-start; gap: 12px; }
  }
  @media (max-width: 768px) {
    .sx-st { padding: 30px 24px; }
    .sx-st--sm .sx-st-title, .sx-st--sm .sx-st-sub { font-size: 32px; }
    .sx-st--md .sx-st-title { font-size: 44px; letter-spacing: -1px; }
    .sx-st--lg .sx-st-title { font-size: 56px; letter-spacing: -2px; }
    .sx-st--lg .sx-st-sub   { font-size: 16px; }
    .sx-st--sub-event .sx-st-sub { font-size: 40px; }
  }
</style>
