---
import { t, tItems } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  content: Record<string, unknown>;
  style: Record<string, string>;
  overrides?: Record<string, string>;
  locale?: Locale;
}

const { content, style, overrides, locale = 'es' } = Astro.props;

const label = t(content, 'label', locale);
const headline = t(content, 'headline', locale);
const members = tItems((content.members as Record<string, unknown>[]) || [], locale);
---

<section data-nova-el="team-grid-section" class="py-24 relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-2xl mb-16">
      {label && (
        <p data-animate="fade-up" class="text-xs font-mono text-brand-400 uppercase tracking-widest mb-4">{label}</p>
      )}
      {headline && (
        <h2 data-nova-el="team-grid-title" data-animate="fade-up" data-delay="0.1" class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white mb-6">
          {headline}
        </h2>
      )}
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-8" data-stagger="0.08">
      {members.map((member) => (
        <div data-animate="fade-up" class="group text-center">
          <div class="relative mb-4 mx-auto w-32 h-32 sm:w-40 sm:h-40">
            <div class="w-full h-full rounded-full overflow-hidden border-2 border-navy-700/50 group-hover:border-brand-500/50 transition-colors">
              {member.photo ? (
                <img src={member.photo} alt={member.name || ''} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" style={`object-position: ${(member as any).photo_position || 'center 25%'};`} loading="lazy" />
              ) : (
                <div class="w-full h-full bg-navy-800 flex items-center justify-center text-2xl font-display font-bold text-navy-300">
                  {(member.name || '?').charAt(0).toUpperCase()}
                </div>
              )}
            </div>
            {member.linkedin && (
              <a href={member.linkedin} target="_blank" rel="noopener noreferrer"
                 class="absolute bottom-0 right-0 w-8 h-8 bg-navy-800 border border-navy-700/50 rounded-full flex items-center justify-center text-navy-400 hover:text-brand-400 hover:border-brand-500/50 transition-colors opacity-0 group-hover:opacity-100">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            )}
          </div>
          <p data-nova-el="team-member-name" class="font-display font-semibold text-white text-sm sm:text-base">{member.name}</p>
          <p data-nova-el="team-member-role" class="text-xs sm:text-sm text-navy-400 mt-1">{member.role}</p>
        </div>
      ))}
    </div>
  </div>
</section>
