---
import { t } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface LocationItem {
  flag: string;
  city: string;
}

interface Props {
  content: Record<string, unknown>;
  style: Record<string, string>;
  overrides?: Record<string, string>;
  locale?: Locale;
}

const { content, style, overrides, locale = 'es' } = Astro.props;

const label = t(content, 'label', locale);
const quote = t(content, 'quote', locale);
const founderName = (content.founder_name as string) || '';
const founderRole = t(content, 'founder_role', locale);
const founderPhoto = (content.founder_photo as string) || '';
const teamPhoto = (content.team_photo as string) || '';
const locations = (content.locations as LocationItem[]) || [];
---

<section data-nova-el="team-section" class="py-24 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Quote side -->
      <div>
        <p data-nova-el="team-label" data-animate="fade-up" class="text-xs font-mono text-brand-400 uppercase tracking-widest mb-6">{label}</p>
        <blockquote data-animate="fade-up" data-delay="0.1">
          <p data-nova-el="team-quote" class="text-2xl sm:text-3xl font-display font-bold text-white leading-snug mb-6">
            &ldquo;{quote}&rdquo;
          </p>
        </blockquote>
        <div data-animate="fade-up" data-delay="0.2" class="flex items-center gap-4">
          {founderPhoto && (
            <div class="w-14 h-14 rounded-full overflow-hidden border-2 border-brand-500/30">
              <img src={founderPhoto} alt={founderName} class="w-full h-full object-cover" />
            </div>
          )}
          <div>
            <p data-nova-el="team-name" class="font-display font-bold text-white">{founderName}</p>
            <p class="text-sm text-navy-400">{founderRole}</p>
          </div>
        </div>
      </div>

      <!-- Photo side -->
      <div data-animate="fade-left" data-delay="0.2" class="relative">
        {teamPhoto && (
          <div class="photo-frame aspect-[4/3]">
            <img src={teamPhoto} alt="Equipo ZDS" loading="lazy" />
          </div>
        )}
        {locations.length > 0 && (
          <div class="absolute -bottom-4 -left-4 bg-navy-900 border border-navy-700/50 rounded-xl px-5 py-3 shadow-xl">
            <div class="flex items-center gap-3">
              {locations.map((loc, i) => (
                <>
                  {i > 0 && <div class="w-px h-4 bg-navy-700"></div>}
                  <div class="flex items-center gap-1.5">
                    <span class="text-lg">{loc.flag}</span>
                    <span class="text-sm text-navy-300 font-medium">{loc.city}</span>
                  </div>
                </>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
