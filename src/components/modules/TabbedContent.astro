---
/**
 * TabbedContent — Rich tabs with image, body text, features list, and link.
 * CSS-only tabs via radio :checked. No JavaScript. SEO-friendly: all content in DOM.
 * Supports up to 9 tabs with images, descriptions, bullet points and CTAs.
 */
import { t, tItems } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  content: Record<string, unknown>;
  style: Record<string, string>;
  overrides?: Record<string, string>;
  locale?: Locale;
}

const { content, style, overrides, locale = 'es' } = Astro.props;
const label = t(content, 'label', locale);
const headline = t(content, 'headline', locale);
const subtitle = t(content, 'subtitle', locale);
const items = tItems((content.items as Record<string, unknown>[]) || [], locale);
const uid = `tabs-${Math.random().toString(36).slice(2, 8)}`;
---

<section data-nova-el="tabbed-section" class="py-24 relative">
  <div class="max-w-5xl mx-auto px-6">
    {label && <p data-nova-el="tabbed-label" data-animate="fade-up" class="text-xs font-mono text-brand-400 uppercase tracking-widest mb-4">{label}</p>}
    {headline && <h2 data-nova-el="tabbed-title" data-animate="fade-up" data-delay="0.1" class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold mb-4">{headline}</h2>}
    {subtitle && <p data-nova-el="tabbed-subtitle" data-animate="fade-up" data-delay="0.2" class="text-navy-400 text-lg mb-10 max-w-2xl">{subtitle}</p>}

    {/* Radio inputs (hidden, up to 9) */}
    {items.map((_: any, i: number) => (
      <input type="radio" name={uid} id={`${uid}-${i}`} class="tc-radio hidden peer" checked={i === 0} />
    ))}

    <div data-animate="fade-up" data-delay="0.3">
      {/* Tab navigation — scrollable on mobile */}
      <div class="tc-nav flex gap-0 border-b-2 border-navy-700/20 mb-0 overflow-x-auto scrollbar-none" role="tablist" aria-label={headline || 'Tabs'}>
        {items.map((item: any, i: number) => (
          <label for={`${uid}-${i}`}
                 role="tab"
                 tabindex="0"
                 aria-selected={i === 0 ? 'true' : 'false'}
                 aria-controls={`${uid}-panel-${i}`}
                 id={`${uid}-tab-${i}`}
                 class="tc-label px-4 sm:px-5 py-3 text-sm font-semibold text-navy-400 cursor-pointer whitespace-nowrap border-b-2 border-transparent transition-all hover:text-white flex items-center gap-2">
            {item.icon && <i class={`${item.icon} text-xs`} aria-hidden="true"></i>}
            {item.title || `Tab ${i + 1}`}
          </label>
        ))}
      </div>

      {/* Tab panels — rich content with image */}
      {items.map((item: any, i: number) => (
        <div class="tc-panel" data-tab={i} role="tabpanel" id={`${uid}-panel-${i}`} aria-labelledby={`${uid}-tab-${i}`}>
          <div class={`p-6 sm:p-8 ${item.image ? 'grid grid-cols-1 md:grid-cols-2 gap-8 items-start' : ''}`}>
            {/* Image (optional, left side on desktop) */}
            {item.image && (
              <div class="order-1 md:order-none">
                <img src={item.image} alt={item.title || ''} class="w-full rounded-xl object-cover aspect-[4/3]" loading="lazy" />
              </div>
            )}
            {/* Text content */}
            <div>
              <h3 class="text-xl sm:text-2xl font-display font-bold text-white mb-3">{item.title}</h3>
              {item.description && (
                <div class="text-navy-300 text-sm leading-relaxed mb-4" set:html={item.description} />
              )}
              {item.body && (
                <div class="text-navy-300 text-sm leading-relaxed mb-4" set:html={item.body} />
              )}
              {item.body_html && (
                <div class="text-navy-300 text-sm leading-relaxed mb-4" set:html={item.body_html} />
              )}
              {item.features && Array.isArray(item.features) && (
                <ul class="space-y-2 mb-4">
                  {item.features.map((f: any) => (
                    <li class="flex items-start gap-2 text-sm text-navy-400">
                      <span class="text-brand-400 mt-0.5 flex-shrink-0">✓</span>
                      <span>{typeof f === 'string' ? f : <Fragment set:html={`<strong class="text-white">${f.title || f.name || ''}</strong> ${f.desc || f.description || ''}`} />}</span>
                    </li>
                  ))}
                </ul>
              )}
              {item.url && (
                <a href={item.url} class="inline-flex items-center gap-1 text-brand-400 text-sm font-semibold hover:text-brand-300 transition-colors">
                  Más información <span class="text-xs">→</span>
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-none { scrollbar-width: none; }
  .scrollbar-none::-webkit-scrollbar { display: none; }

  /* Active tab label — supports up to 9 tabs */
  .tc-radio:nth-of-type(1):checked ~ div .tc-label:nth-of-type(1),
  .tc-radio:nth-of-type(2):checked ~ div .tc-label:nth-of-type(2),
  .tc-radio:nth-of-type(3):checked ~ div .tc-label:nth-of-type(3),
  .tc-radio:nth-of-type(4):checked ~ div .tc-label:nth-of-type(4),
  .tc-radio:nth-of-type(5):checked ~ div .tc-label:nth-of-type(5),
  .tc-radio:nth-of-type(6):checked ~ div .tc-label:nth-of-type(6),
  .tc-radio:nth-of-type(7):checked ~ div .tc-label:nth-of-type(7),
  .tc-radio:nth-of-type(8):checked ~ div .tc-label:nth-of-type(8),
  .tc-radio:nth-of-type(9):checked ~ div .tc-label:nth-of-type(9) {
    color: white;
    border-bottom-color: var(--color-brand-400);
  }

  /* Show active panel */
  .tc-panel { display: none; background: color-mix(in srgb, var(--color-navy-800) 30%, transparent); border: 1px solid color-mix(in srgb, var(--color-navy-700) 30%, transparent); border-top: none; border-radius: 0 0 16px 16px; animation: tcFade 0.3s ease; }

  .tc-radio:nth-of-type(1):checked ~ div .tc-panel[data-tab="0"],
  .tc-radio:nth-of-type(2):checked ~ div .tc-panel[data-tab="1"],
  .tc-radio:nth-of-type(3):checked ~ div .tc-panel[data-tab="2"],
  .tc-radio:nth-of-type(4):checked ~ div .tc-panel[data-tab="3"],
  .tc-radio:nth-of-type(5):checked ~ div .tc-panel[data-tab="4"],
  .tc-radio:nth-of-type(6):checked ~ div .tc-panel[data-tab="5"],
  .tc-radio:nth-of-type(7):checked ~ div .tc-panel[data-tab="6"],
  .tc-radio:nth-of-type(8):checked ~ div .tc-panel[data-tab="7"],
  .tc-radio:nth-of-type(9):checked ~ div .tc-panel[data-tab="8"] {
    display: block;
  }

  @keyframes tcFade {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  // Keyboard navigation for tabs (WCAG 2.1.1 + APG tablist pattern)
  document.querySelectorAll('[role="tablist"]').forEach(tablist => {
    const tabs = Array.from(tablist.querySelectorAll('[role="tab"]'));
    tabs.forEach((tab, idx) => {
      tab.addEventListener('keydown', (e) => {
        let target = null;
        if (e.key === 'ArrowRight') target = tabs[(idx + 1) % tabs.length];
        else if (e.key === 'ArrowLeft') target = tabs[(idx - 1 + tabs.length) % tabs.length];
        else if (e.key === 'Home') target = tabs[0];
        else if (e.key === 'End') target = tabs[tabs.length - 1];
        else if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const radio = document.getElementById(tab.getAttribute('for'));
          if (radio) { radio.checked = true; tabs.forEach(t => t.setAttribute('aria-selected', 'false')); tab.setAttribute('aria-selected', 'true'); }
          return;
        }
        if (target) {
          e.preventDefault();
          target.focus();
          const radio = document.getElementById(target.getAttribute('for'));
          if (radio) {
            radio.checked = true;
            tabs.forEach(t => t.setAttribute('aria-selected', 'false'));
            target.setAttribute('aria-selected', 'true');
          }
        }
      });
      // Click also updates aria-selected
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.setAttribute('aria-selected', 'false'));
        tab.setAttribute('aria-selected', 'true');
      });
    });
  });
</script>
