---
import { t, tItems } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  content: Record<string, unknown>;
  style: Record<string, string>;
  overrides?: Record<string, string>;
  locale?: Locale;
}

const { content, style, overrides, locale = 'es' } = Astro.props;

const label = t(content, 'label', locale);
const headline = t(content, 'headline', locale);
const items = tItems((content.items as Record<string, unknown>[]) || [], locale);
---

<section data-nova-el="pricing-section" class="py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-brand-500/[0.02] to-transparent"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="max-w-2xl mb-16">
      {label && (
        <p data-animate="fade-up" class="text-xs font-mono text-brand-400 uppercase tracking-widest mb-4">{label}</p>
      )}
      {headline && (
        <h2 data-nova-el="pricing-title" data-animate="fade-up" data-delay="0.1" class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white mb-6">
          {headline}
        </h2>
      )}
    </div>

    <div class={`grid grid-cols-1 ${items.length === 2 ? 'md:grid-cols-2 max-w-4xl' : 'lg:grid-cols-3'} gap-6 mx-auto`} data-stagger="0.08">
      {items.map((item) => {
        const featured = item.featured === true || item.featured === 'true';
        const features = (item.features as string[]) || [];
        return (
          <div
            data-nova-el="pricing-card"
            data-animate="fade-up"
            class={`relative rounded-2xl p-8 flex flex-col ${
              featured
                ? 'bg-navy-800/50 border-2 border-brand-500/50 shadow-xl shadow-brand-500/10'
                : 'bg-navy-800/30 border border-navy-700/30'
            }`}
          >
            {featured && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 text-[10px] font-mono font-bold uppercase tracking-wider bg-brand-500 text-white px-4 py-1 rounded-full">
                {item.badge || 'Popular'}
              </span>
            )}

            <h3 class="font-display font-bold text-white text-xl mb-2">{item.name}</h3>

            <div data-nova-el="pricing-price" class="mb-6">
              <span class="font-display text-4xl sm:text-5xl font-bold text-white">{item.price}</span>
              {item.period && (
                <span class="text-navy-500 text-sm ml-1">/ {item.period}</span>
              )}
            </div>

            <ul class="space-y-3 mb-8 flex-1">
              {features.map((feat: string) => (
                <li class="flex items-start gap-3 text-sm text-navy-400">
                  <svg class="w-5 h-5 text-brand-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{feat}</span>
                </li>
              ))}
            </ul>

            {item.cta_text && (
              <a
                data-nova-el="pricing-cta"
                href={item.cta_url || '#'}
                class={`inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl text-base font-medium transition-all hover:shadow-xl hover:-translate-y-0.5 ${
                  featured
                    ? 'bg-brand-500 hover:bg-brand-600 text-white hover:shadow-brand-500/25'
                    : 'border border-navy-600 hover:border-navy-400 text-navy-300 hover:text-white'
                }`}
              >
                {item.cta_text}
              </a>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
