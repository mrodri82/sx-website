  { src: '/media/sponsors/15-1024x1024.png',              href: 'https://www.canalplus.com/pl/',            alt: 'Canal+', filter: 'brightness(200%) contrast(65%) saturate(0%)' },
  { src: '/media/sponsors/14-1024x1024.png',              href: 'https://www.typastudios.com/',             alt: 'Typa Studios' },
  { src: '/media/sponsors/13-1024x153.png',               href: 'https://sextechguide.com/',                alt: 'SexTech Guide' },
];
const logos: Logo[] = (content.logos as Logo[]) || defaultLogos;
---

<section data-nova-el="sponsors-grid" class="sx-sponsors bg-black">
  <div class="sx-sponsors-inner">
    <h2 class="sx-sponsors-title" data-atom="heading">{heading}</h2>
    <div class="sx-sponsors-wall" data-nova-el="wall" data-atom="logos">
      {logos.map((l) => {
        const imgStyle = l.filter ? `filter:${l.filter}` : undefined;
        const body = <img data-atom="image" src={l.src} alt={l.alt || ''} loading="lazy" decoding="async" style={imgStyle} />;
        return l.href ? (
          <a href={l.href} target="_blank" rel="noopener" class="sx-sponsor-cell" aria-label={l.alt}>{body}</a>
        ) : (
          <div class="sx-sponsor-cell" aria-label={l.alt}>{body}</div>
        );
      })}
    </div>
  </div>
</section>

<style is:global>
  /* Container convention: outer section owns the side padding (50/50),
     inner caps at 1440 and centers — same as HeroSimple, NewsGrid,
     ButtonRow etc. Content x-axis at (viewport-1440)/2 across all
     modules so the site never looks "shifted" between sections. */
  .sx-sponsors { padding: 80px 50px; }
  .sx-sponsors-inner { max-width:1440px; margin:0 auto; box-sizing:border-box; width:100%; }
  .sx-sponsors-title {
    font-family:'Oswald','Inter',sans-serif;
    font-size:clamp(36px, 3.5vw, 48px);
    font-weight:800; line-height:1;
    letter-spacing:-0.02em;
    color:#ecfd21; text-transform:uppercase;
    margin:0 0 40px 0;
  }
  /* Logo wall — Kunde-Feedback 28.04.2026: Logos waren disproportional
     groß, deutlich kleiner als auf sxtech.eu. 7 Spalten + 60px Höhe +
     140px max-Breite + engerer Gap geben den dezenten "Featured Brands"-
     Look (sxtech rendert die Logos auf ähnlicher Größe). */
  .sx-sponsors-wall {
    display:flex; flex-wrap:wrap;
    justify-content:center; align-items:center;
    gap:28px 24px;
    min-width:0;
  }
  .sx-sponsor-cell {
    display:flex; align-items:center; justify-content:center;
    flex: 0 0 calc((100% - 6 * 24px) / 7);
    max-width:140px; height:60px;
    transition: transform .2s ease, opacity .2s ease;
  }
  @media (max-width:1024px) {
    .sx-sponsor-cell { flex: 0 0 calc((100% - 4 * 24px) / 5); max-width:140px; }
  }
  @media (max-width:768px) {
    .sx-sponsor-cell { flex: 0 0 calc((100% - 3 * 20px) / 4); height:50px; }
  }
  @media (max-width:480px) {
    .sx-sponsor-cell { flex: 0 0 calc((100% - 16px) / 3); height:44px; }
  }
  .sx-sponsor-cell:hover { transform: scale(1.05); }
  .sx-sponsor-cell img {
    max-width:100%; max-height:100%;
    object-fit:contain;
    /* White silhouette on the black section. */
    filter: brightness(0) invert(1);
    opacity: .85;
    transition: opacity .2s ease;
  }
  .sx-sponsor-cell:hover img { opacity: 1; }

  @media (max-width:640px) {
    .sx-sponsors { padding: 60px 24px; }
  }
</style>
