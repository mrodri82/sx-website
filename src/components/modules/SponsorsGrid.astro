  { src: '/media/sponsors/19-1024x228.png',               href: 'https://www.satisfyer.com/pl',             alt: 'Satisfyer' },
  { src: '/media/sponsors/18-1024x356.png',               href: 'https://fetischbarbie.com/',               alt: 'Fetischbarbie' },
  { src: '/media/sponsors/17-1024x237.png',               href: 'https://www.orion-wholesale.com/home',     alt: 'Orion Wholesale' },
