  { src: '/media/sponsors/19-1024x228.png',               href: 'https://www.satisfyer.com/pl',             alt: 'Satisfyer' },
  { src: '/media/sponsors/18-1024x356.png',               href: 'https://fetischbarbie.com/',               alt: 'Fetischbarbie' },
  { src: '/media/sponsors/17-1024x237.png',               href: 'https://www.orion-wholesale.com/home',     alt: 'Orion Wholesale' },
  { src: '/media/sponsors/16-1024x1024.png',              href: 'https://www.therubpr.com/',                alt: 'The Rub PR' },
  { src: '/media/sponsors/5-scaled-1-1024x768.png',       href: 'https://nsfwpr.com',                       alt: 'NSFW PR' },
  { src: '/media/sponsors/15-scaled-1-1024x138.png',      href: 'https://www.sextpanther.com/',             alt: 'SextPanther' },
  { src: '/media/sponsors/14-scaled-1-810x1024.png',      href: 'http://thecode.shop',                      alt: 'The Code' },
