  { src: '/media/sponsors/10-scaled-1-1024x461.jpg',      href: 'https://moonlightsociety-berlin.com',      alt: 'Moonlight Society', filter: 'brightness(129%) contrast(200%) saturate(0%)' },
  { src: '/media/sponsors/3-scaled-1-1024x516.png',       href: 'https://www.thehandy.com/',                alt: 'The Handy' },
  { src: '/media/sponsors/Projekt-bez-nazwy-21.png',      href: 'https://www.surr3al.fun/',                 alt: 'Surr3al' },
  { src: '/media/sponsors/Projekt-bez-nazwy-22.png',      href: 'https://www.passport2pleasure.com/',       alt: 'Passport2Pleasure' },
