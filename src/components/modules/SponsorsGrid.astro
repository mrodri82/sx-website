  { src: '/media/sponsors/6-3-1024x1024.png',             href: 'https://www.banksietv.com/',               alt: 'Banksie TV' },
  { src: '/media/sponsors/15-1024x1024.png',              href: 'https://www.canalplus.com/pl/',            alt: 'Canal+' },
  { src: '/media/sponsors/14-1024x1024.png',              href: 'https://www.typastudios.com/',             alt: 'Typa Studios' },
  { src: '/media/sponsors/13-1024x153.png',               href: 'https://sextechguide.com/',                alt: 'SexTech Guide' },
];
const logos: Logo[] = (content.logos as Logo[]) || defaultLogos;
---

<section data-nova-el="sponsors-grid" class="sx-sponsors bg-black py-20">
  <div class="sx-sponsors-inner">
    <h2 class="sx-sponsors-title">{heading}</h2>
    <div class="sx-sponsors-wall">
      {logos.map((l) => {
        const body = <img src={l.src} alt={l.alt || ''} loading="lazy" decoding="async" />;
        return l.href ? (
          <a href={l.href} target="_blank" rel="noopener" class="sx-sponsor-cell" aria-label={l.alt}>{body}</a>
        ) : (
          <div class="sx-sponsor-cell" aria-label={l.alt}>{body}</div>
        );
      })}
    </div>
  </div>
</section>

<style is:global>
  .sx-sponsors-inner { max-width:1600px; margin:0 auto; padding:0 10px 0 50px; box-sizing:border-box; width:100%; }
  .sx-sponsors-title {
    font-family:'Oswald','Inter',sans-serif;
    font-size:clamp(36px, 3.5vw, 48px);
    font-weight:800; line-height:1;
    letter-spacing:-0.02em;
    color:#ecfd21; text-transform:uppercase;
    margin:0 0 40px 0;
  }
  .sx-sponsors-wall {
    display:grid;
    grid-template-columns:repeat(5, minmax(0, 1fr));
    gap:48px 40px;
    align-items:center; justify-items:center;
    min-width:0;
  }
  .sx-sponsor-cell {
    display:flex; align-items:center; justify-content:center;
    width:100%; max-width:220px; height:100px;
    background:#fff; border-radius:6px; padding:14px 18px;
    box-sizing:border-box;
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .sx-sponsor-cell:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(236,253,33,0.25);
  }
  .sx-sponsor-cell img {
    max-width:100%; max-height:100%;
    object-fit:contain;
  }

  @media (max-width:1024px) {
    .sx-sponsors-wall { grid-template-columns:repeat(3, minmax(0, 1fr)); gap:32px 24px; }
  }
  @media (max-width:640px) {
    .sx-sponsors-wall { grid-template-columns:repeat(2, minmax(0, 1fr)); gap:24px; }
    .sx-sponsors-inner { padding:0 24px; }
  }
</style>
