  { src: '/media/sponsors/12-scaled-1-1024x1024.png',     href: 'https://sensez.com.ua/',                   alt: 'Sensez', filter: 'brightness(87%) contrast(53%) saturate(0%)' },
  { src: '/media/sponsors/6-2.png',                       href: 'https://sexystreamers.com/dashboard',      alt: 'Sexy Streamers', filter: 'brightness(87%) contrast(53%) saturate(0%)' },
  { src: '/media/sponsors/11-1.png',                      href: 'https://www.instagram.com/marinavalmont',  alt: 'Marina Valmont', filter: 'brightness(87%) contrast(53%) saturate(0%)' },
  { src: '/media/sponsors/9-1.jpeg',                      href: 'https://rubbermissy.com',                  alt: 'Rubber Missy', filter: 'brightness(200%) contrast(96%) saturate(0%)' },
  { src: '/media/sponsors/leaf-1024x408.webp',            href: 'https://littleleaf.agency/',               alt: 'Leaf' },
