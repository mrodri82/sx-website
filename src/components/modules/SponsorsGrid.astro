  { src: '/media/sponsors/12-scaled-1-1024x1024.png',     href: 'https://sensez.com.ua/',                   alt: 'Sensez' },
  { src: '/media/sponsors/6-2.png',                       href: 'https://sexystreamers.com/dashboard',      alt: 'Sexy Streamers' },
  { src: '/media/sponsors/11-1.png',                      href: 'https://www.instagram.com/marinavalmont',  alt: 'Marina Valmont' },
  { src: '/media/sponsors/9-1.jpeg',                      href: 'https://rubbermissy.com',                  alt: 'Rubber Missy' },
  { src: '/media/sponsors/leaf-1024x408.webp',            href: 'https://littleleaf.agency/',               alt: 'Leaf' },
  { src: '/media/sponsors/8-scaled-1-1024x280.png',       href: 'https://playfulmag.com',                   alt: 'Playful Mag' },
  { src: '/media/sponsors/10-scaled-1-1024x461.jpg',      href: 'https://moonlightsociety-berlin.com',      alt: 'Moonlight Society' },
  { src: '/media/sponsors/3-scaled-1-1024x516.png',       href: 'https://www.thehandy.com/',                alt: 'The Handy' },
  { src: '/media/sponsors/Projekt-bez-nazwy-21.png',      href: 'https://www.surr3al.fun/',                 alt: 'Surr3al' },
  { src: '/media/sponsors/Projekt-bez-nazwy-22.png',      href: 'https://www.passport2pleasure.com/',       alt: 'Passport2Pleasure' },
  { src: '/media/sponsors/Projekt-bez-nazwy-23.png',      href: 'https://getrude.co/',                      alt: 'Get Rude' },
  { src: '/media/sponsors/11-1024x1024.png',              href: 'https://fetischbarbie.com/',               alt: 'Fetischbarbie' },
  { src: '/media/sponsors/23-1024x428.png',               href: 'https://www.fet-app.com/',                 alt: 'Fet-App' },
