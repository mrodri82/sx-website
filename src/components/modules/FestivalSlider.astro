---
/**
 * FestivalSlider — 1:1 port of sxtech.eu's custom HTML-widget slider.
 * Active slide expands (225→790px), inactive slides dim to 0.6 opacity.
 * Each slide has two overlaid images: thumb (small view) + large (active).
 * Progress bar advances per cycle.
 *
 * Fields:
 *   - items: Array<{ thumb, large }>
 *   - autoplay_ms: default 4000
 */
interface Item { thumb: string; large: string; }
interface Props { content: Record<string, any>; }
const { content = {} } = Astro.props;
const items: Item[] = Array.isArray(content.items) ? content.items : [];
const autoplayMs = Number(content.autoplay_ms) || 4000;
const theme = (content.theme === 'light' ? 'light' : 'dark') as 'light'|'dark';

/* Infinite loop: render items tripled so there's always fillers on both sides
   of the active slide, no matter where we are in the cycle. Script starts at
   index=items.length (middle copy) and jumps back to the middle when it
   reaches either edge. */
const tripled = items.length > 0 ? [...items, ...items, ...items] : [];
---

<section data-nova-el="festival-slider" class={`sx-fs sx-fs--${theme}`}>
  <div class="sx-fs-outer" data-real-count={items.length}>
    <div class="sx-fs-window">
      <div class="sx-fs-track" data-autoplay={autoplayMs}>
        {tripled.map((it, i) => (
          <div class={`sx-fs-slide${i === items.length ? ' is-active' : ''}`}>
            <img class="sx-fs-thumb" src={it.thumb} alt="" loading="lazy" />
            <img class="sx-fs-large" src={it.large} alt="" loading="lazy" />
          </div>
        ))}
      </div>
      <button class="sx-fs-nav sx-fs-prev" type="button" aria-label="Previous">&#10094;</button>
      <button class="sx-fs-nav sx-fs-next" type="button" aria-label="Next">&#10095;</button>
    </div>
    <div class="sx-fs-progress"><div class="sx-fs-progress-fill"></div></div>
  </div>
</section>

<style>
  /* Layout law: 2 thumbs left + active center + 2 thumbs right at every
     viewport. Widths are computed by the script so the 2-1-2 structure
     holds. CSS values below are only the initial paint hint. */
  .sx-fs { background: #000; padding: 40px 50px 60px; }
  .sx-fs--light { background: #FFFFFF; }
  .sx-fs--light .sx-fs-progress { background: #ddd; }
  .sx-fs--light .sx-fs-progress-fill { background: #000; }
  .sx-fs-outer { max-width: 1440px; margin: 0 auto; }

  .sx-fs-window { overflow: hidden; height: 490px; position: relative; }
  .sx-fs-track {
    display: flex; align-items: center;
    transition: transform .5s ease;
    will-change: transform;
  }
  .sx-fs-track.is-jumping { transition: none; }

  .sx-fs-slide {
    flex: 0 0 134px; height: 490px; margin: 0 6px;
    position: relative; overflow: hidden;
    opacity: 0.6; transition: flex-basis .5s ease, opacity .4s ease;
  }
  .sx-fs-slide.is-active { flex: 0 0 740px; opacity: 1; }

  .sx-fs-slide img {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%; object-fit: cover;
    transition: opacity .4s ease;
  }
  .sx-fs-large { opacity: 0; }
  .sx-fs-slide.is-active { background: #000; }
  .sx-fs-slide.is-active .sx-fs-large {
    opacity: 1;
    /* Active asset has the yellow info bar baked into the bottom — use
       contain so the bar is never cropped. */
    object-fit: contain; object-position: center;
  }
  .sx-fs-slide.is-active .sx-fs-thumb { opacity: 0; }

  .sx-fs-nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: #000; color: #fff; border: none;
    padding: 10px 14px; cursor: pointer; z-index: 10;
    font-size: 20px;
  }
  .sx-fs-prev { left: 0; }
  .sx-fs-next { right: 0; }

  .sx-fs-progress { height: 4px; background: #222; margin-top: 20px; }
  .sx-fs-progress-fill { height: 100%; width: 0%; background: #ECFD21; transition: width .4s linear; }

  @media (max-width: 900px) {
    .sx-fs { padding: 30px 24px 50px; }
    .sx-fs-slide { height: 380px; margin: 0 4px; }
  }
</style>

<script>
  (function () {
    const roots = document.querySelectorAll<HTMLElement>('.sx-fs-outer');
    roots.forEach(setup);

    function setup(root: HTMLElement) {
      const track = root.querySelector<HTMLElement>('.sx-fs-track');
      const slides = Array.from(root.querySelectorAll<HTMLElement>('.sx-fs-slide'));
      const prev = root.querySelector<HTMLButtonElement>('.sx-fs-prev');
      const next = root.querySelector<HTMLButtonElement>('.sx-fs-next');
      const progress = root.querySelector<HTMLElement>('.sx-fs-progress-fill');
      if (!track || slides.length === 0) return;

      const intervalMs = Number(track.dataset.autoplay) || 4000;
      /* Items are rendered tripled (3× real). Start idx in the middle copy so
         we can scroll left AND right before hitting an edge. When we reach
         either edge, silently jump back to the equivalent index in the middle. */
      const real = Number(root.dataset.realCount) || Math.floor(slides.length / 3);
      let idx = real;
      let tickerStart = performance.now();

      function sizes() {
        const winW = (track!.parentElement as HTMLElement).offsetWidth;
        const mobile = window.innerWidth <= 900;
        const MARGIN = mobile ? 8 : 12;
        // Active capped at 740 on wide screens, scales on narrow.
        const WIDE = mobile ? Math.round(winW * 0.78)
                            : Math.min(740, Math.round(winW * 0.55));
        // 2 thumbs each side; thumb width is the leftover space split 4 ways.
        const NARROW = Math.max(mobile ? 40 : 80,
                                Math.round((winW - WIDE - 5 * MARGIN) / 4));
        return { WIDE, NARROW, MARGIN, winW };
      }

      function applySizes() {
        const { WIDE, NARROW, MARGIN } = sizes();
        slides.forEach((s, i) => {
          const w = i === idx ? WIDE : NARROW;
          s.style.flex = `0 0 ${w}px`;
          s.style.margin = `0 ${MARGIN / 2}px`;
        });
      }

      function apply() {
        slides.forEach((s, i) => s.classList.toggle('is-active', i === idx));
        applySizes();
        const container = track!.parentElement!;
        const active = slides[idx];
        const cRect = container.getBoundingClientRect();
        const offset = (active.offsetLeft + active.offsetWidth / 2) - cRect.width / 2;
        track!.style.transform = `translateX(${-offset}px)`;
      }
      function jumpTo(i: number) {
        track!.classList.add('is-jumping');
        idx = i;
        apply();
        track!.getBoundingClientRect();
        track!.classList.remove('is-jumping');
      }
      function step(d: 1 | -1) {
        idx += d;
        tickerStart = performance.now();
        apply();
      }
      track.addEventListener('transitionend', () => {
        if (idx >= real * 2)      jumpTo(idx - real);
        else if (idx < real)      jumpTo(idx + real);
      });

      prev?.addEventListener('click', () => step(-1));
      next?.addEventListener('click', () => step(1));
      let timer = window.setInterval(() => step(1), intervalMs);
      root.addEventListener('mouseenter', () => clearInterval(timer));
      root.addEventListener('mouseleave', () => { timer = window.setInterval(() => step(1), intervalMs); });
      window.addEventListener('resize', () => requestAnimationFrame(apply));

      function tick() {
        const elapsed = performance.now() - tickerStart;
        const pct = Math.min(100, (elapsed / intervalMs) * 100);
        if (progress) progress.style.width = `${pct}%`;
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(apply);
      requestAnimationFrame(tick);
    }
  })();
</script>
