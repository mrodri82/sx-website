---
import { t, tItems } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  content: Record<string, unknown>;
  style: Record<string, string>;
  overrides?: Record<string, string>;
  locale?: Locale;
}

const { content, style, overrides, locale = 'es' } = Astro.props;

const label = t(content, 'label', locale);
const headline = t(content, 'headline', locale);
const items = tItems((content.items as Record<string, unknown>[]) || [], locale);
---

<section data-nova-el="timeline-section" class="py-24 relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-2xl mb-16">
      {label && (
        <p data-animate="fade-up" class="text-xs font-mono text-brand-400 uppercase tracking-widest mb-4">{label}</p>
      )}
      {headline && (
        <h2 data-nova-el="timeline-title" data-animate="fade-up" data-delay="0.1" class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white mb-6">
          {headline}
        </h2>
      )}
    </div>

    <div class="relative max-w-4xl mx-auto">
      {/* Vertical line */}
      <div class="absolute left-4 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-0.5 bg-navy-700/50"></div>

      <div class="space-y-12">
        {items.map((item, i) => {
          const isLeft = i % 2 === 0;
          return (
            <div data-animate="fade-up" data-delay={String(i * 0.08)} class="relative flex items-start">
              {/* Dot on the line */}
              <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-brand-400 border-2 border-navy-900 z-10 mt-1.5"></div>

              {/* Content — single column on mobile, alternating on desktop */}
              <div class={`ml-12 md:ml-0 md:w-[calc(50%-2rem)] ${isLeft ? 'md:mr-auto md:pr-8 md:text-right' : 'md:ml-auto md:pl-8'}`}>
                <span data-nova-el="timeline-year" class="inline-block text-xs font-mono text-brand-400 uppercase tracking-widest mb-2">
                  {item.year}
                </span>
                <h3 data-nova-el="timeline-item-title" class="font-display font-bold text-white text-lg mb-2">
                  {item.title}
                </h3>
                <p class="text-sm text-navy-400 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
