---
/**
 * TopVoices — horizontal photo carousel, 1:1 of sxtech.eu "TOP VOICES" section.
 *
 * Each voice has two images: a narrow `thumb` shown in the sliver state, and a
 * wide `large` shown when active (the large image has name + role + date already
 * baked into a yellow info bar). The carousel cycles, expanding the active
 * slide to 740px and compressing the rest to 134px.
 */
import { t } from '@/lib/i18n';
import { getLocaleFromPath } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Voice { large: string; thumb: string; alt?: string; }
interface Props { content: Record<string, unknown>; }

const { content } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname) as Locale;

const heading = t(content, 'heading', locale) || 'TOP VOICES';

// Per-pair naming inconsistency: most use `<name>1` for the wide
// caption image and `<name>2` for the narrow portrait, but kylie/kyli2
// is reversed (kylie = narrow portrait, kyli2 = wide caption).
// Only kylie pair was wrong — the other 8 were already correct.
const defaultVoices: Voice[] = [
  { large: '/media/voices/cath1.webp',  thumb: '/media/voices/cath2.webp',  alt: 'Catherine' },
  { large: '/media/voices/charl1.webp', thumb: '/media/voices/charl2.webp', alt: 'Charlotte' },
  { large: '/media/voices/susan1.webp', thumb: '/media/voices/susan2.webp', alt: 'Susan' },
  { large: '/media/voices/kyli2.webp',  thumb: '/media/voices/kylie.webp',  alt: 'Kylie Darling' },
  { large: '/media/voices/bp2.webp',    thumb: '/media/voices/bp.webp',     alt: 'BP' },
  { large: '/media/voices/kris3.webp',  thumb: '/media/voices/kris2.webp',  alt: 'Kris' },
  { large: '/media/voices/mik4.webp',   thumb: '/media/voices/mik3.webp',   alt: 'Mik' },
  { large: '/media/voices/moon2.webp',  thumb: '/media/voices/moon1.webp',  alt: 'Moon' },
  { large: '/media/voices/muse2.webp',  thumb: '/media/voices/muse1.webp',  alt: 'Muse' },
];
const voices: Voice[] = (content.voices as Voice[]) || defaultVoices;
const theme = (content.theme === 'light' ? 'light' : 'dark') as 'light'|'dark';
/* Triple the list so the active slide always has filler thumbs on both
   sides. The script starts at real-length and silently jumps back to the
   middle copy when we reach either edge — seamless infinite loop. */
const real = voices.length;
const startActive = real + Math.floor(real / 2);
const tripled: Voice[] = real > 0 ? [...voices, ...voices, ...voices] : [];
---

<section data-nova-el="top-voices" class={`sx-voices sx-voices--${theme}`}>
  <div class="sx-voices-head">
    <h2 class="sx-voices-title">{heading}</h2>
  </div>

  <div class="festival-slider" data-real-count={real}>
    <div class="slider-window">
      <div class="slider-track">
        {tripled.map((v, i) => (
          <div class={`slide ${i === startActive ? 'active' : ''}`} data-idx={i}>
            <img class="thumb" src={v.thumb} alt={v.alt || ''} loading="lazy" />
            <img class="large" src={v.large} alt={v.alt || ''} loading="lazy" />
          </div>
        ))}
      </div>
      <button class="nav prev" aria-label="Previous">❮</button>
      <button class="nav next" aria-label="Next">❯</button>
    </div>
    <div class="progress-bar"><div class="progress"></div></div>
  </div>
</section>

<style is:global>
  /* Outer section owns side padding (50/50). Inner head + festival
     slider both cap at 1440 and center — no inner padding. Same
     convention as every other module. */
  .sx-voices { background:#000; padding:64px 50px; }
  .sx-voices--light { background:#FFFFFF; }
  .sx-voices--light .sx-voices-title { color:#000; }
  .sx-voices--light .progress-bar { background:#ddd; }
  .sx-voices--light .progress { background:#000; }
  .sx-voices--light .nav { background:#000; color:#fff; }
  .sx-voices-head { max-width:1440px; margin:0 auto 24px; text-align:center; box-sizing:border-box; width:100%; }
  .sx-voices-title {
    font-family:'Oswald','Inter',sans-serif;
    font-size:clamp(64px, 8vw, 120px);
    font-weight:800; line-height:1;
    letter-spacing:-0.03em;
    color:#ecfd21; text-transform:uppercase;
    margin:0;
  }

  /* Layout law: ALWAYS 2 thumbs left + 1 active (with yellow info bar)
     center + 2 thumbs right. Slot widths are calculated from the window
     width so the 2-1-2 structure is preserved at every viewport, not
     just when 740 + 4×134 happens to fit. JS reads the same vars. */
  .festival-slider { max-width:1440px; margin:0 auto; box-sizing:border-box; width:100%; }
  .slider-window { position:relative; overflow:hidden; height:530px; }
  .slider-track { display:flex; align-items:center; transition:transform .6s ease; will-change:transform; }
  .slider-track.is-jumping { transition:none; }
  .slide {
    /* flex-basis is set inline by the JS sizing pass; this is only the
       initial paint hint before the script runs. */
    flex:0 0 134px; height:490px; margin:0 6px;
    overflow:hidden; position:relative;
    transition:flex-basis .5s ease;
    cursor:pointer;
  }
  .slide img {
    position:absolute; width:100%; height:100%; object-fit:cover;
    top:0; left:0;
    transition:opacity .4s ease;
  }
  .slide .large { opacity:0; }
  .slide.active { flex:0 0 740px; background:#000; }
  .slide.active .large { opacity:1; }
  .slide.active .thumb { opacity:0; }
  /* The active large image carries the yellow info bar baked into the
     bottom of the asset. object-fit:cover crops the bottom edge — use
     contain on the active so the whole image (incl. the yellow box) is
     always visible inside the 490px slot. */
  .slide.active .large { object-fit:contain; object-position:center; }

  .nav {
    position:absolute; top:50%; transform:translateY(-50%);
    background:#000; color:#ecfd21; border:none;
    padding:14px 18px; cursor:pointer; z-index:10;
    font-size:20px; line-height:1;
  }
  .nav:hover { color:#fff; }
  .prev { left:0; }
  .next { right:0; }

  .progress-bar { height:3px; background:#222; margin-top:20px; }
  .progress { height:100%; width:0%; background:#ecfd21; transition:width .4s ease; }

  @media (max-width:900px) {
    .sx-voices { padding:48px 24px; }
    .sx-voices-title { font-size:clamp(44px, 12vw, 72px); }
    .slider-window { height:420px; }
    .slide { height:380px; margin:0 4px; }
  }
</style>

<script>
  (function() {
    const slider = document.currentScript?.previousElementSibling?.querySelector('.festival-slider') as HTMLElement | null;
    // Use a generic selector since `currentScript.previousElementSibling` is unreliable across Astro hydration
    const sliders = document.querySelectorAll<HTMLElement>('.festival-slider');
    sliders.forEach(setupSlider);

    function setupSlider(root: HTMLElement) {
      const track = root.querySelector<HTMLElement>('.slider-track');
      const slides = Array.from(root.querySelectorAll<HTMLElement>('.slide'));
      const prevBtn = root.querySelector<HTMLButtonElement>('.prev');
      const nextBtn = root.querySelector<HTMLButtonElement>('.next');
      const progress = root.querySelector<HTMLElement>('.progress');
      if (!track || !slides.length || !prevBtn || !nextBtn) return;

      const real = Number(root.dataset.realCount) || Math.max(1, Math.floor(slides.length / 3));
      let index = slides.findIndex(s => s.classList.contains('active'));
      if (index < 0) index = real;

      function sizes() {
        // Always 2 thumbs left + active + 2 thumbs right inside the
        // window. THUMB width is computed from the remaining space so
        // the 2-1-2 layout holds at every viewport. Margin matches CSS.
        const mobile = window.innerWidth <= 900;
        const MARGIN = mobile ? 8 : 12;
        const winW = root.querySelector<HTMLElement>('.slider-window')!.offsetWidth;
        // Active slide: large image + yellow info bar. Cap at 740px on
        // wide screens; on narrow ones scale to ~50% of the window so
        // there's still room for 2 thumbs each side.
        const WIDE = mobile ? Math.round(winW * 0.78)
                            : Math.min(740, Math.round(winW * 0.55));
        // 5 slots visible (2+1+2) with 5 inter-slot gaps of MARGIN.
        // Available for thumbs: winW − active − 5 × MARGIN, split across 4 thumbs.
        const NARROW = mobile
          ? Math.max(40, Math.round((winW - WIDE - 5 * MARGIN) / 4))
          : Math.max(80, Math.round((winW - WIDE - 5 * MARGIN) / 4));
        return { NARROW, WIDE, MARGIN, winW };
      }

      function applySizes() {
        const { NARROW, WIDE, MARGIN } = sizes();
        slides.forEach((s, i) => {
          const w = i === index ? WIDE : NARROW;
          s.style.flex = `0 0 ${w}px`;
          s.style.margin = `0 ${MARGIN / 2}px`;
        });
      }

      function update() {
        slides.forEach((s, i) => s.classList.toggle('active', i === index));
        applySizes();
        const { NARROW, WIDE, MARGIN, winW } = sizes();
        // Offset from track origin to the CENTER of the active slide.
        // Each slot consumes (slotWidth + MARGIN) — slotWidth is NARROW
        // for inactive, WIDE for the active one we land on.
        let offset = MARGIN / 2; // first slide's leading margin
        for (let i = 0; i < index; i++) offset += NARROW + MARGIN;
        offset += WIDE / 2; // reach center of active
        const translateX = winW / 2 - offset;
        track!.style.transform = `translateX(${translateX}px)`;
        if (progress) {
          /* progress reflects the logical position inside the real cycle,
             so it doesn't reset when the carousel silently wraps */
          const logical = ((index - real) % real + real) % real;
          progress.style.width = `${((logical + 1) / real) * 100}%`;
        }
      }

      function jumpTo(i: number) {
        track!.classList.add('is-jumping');
        index = i;
        update();
        track!.getBoundingClientRect();
        track!.classList.remove('is-jumping');
      }
      track.addEventListener('transitionend', () => {
        /* once the transition finishes in the "edge" copies, silently jump
           back to the equivalent index in the middle copy so the user
           never sees the wraparound */
        if (index >= real * 2)      jumpTo(index - real);
        else if (index < real)      jumpTo(index + real);
      });

      prevBtn.addEventListener('click', () => { index -= 1; update(); });
      nextBtn.addEventListener('click', () => { index += 1; update(); });
      slides.forEach((s, i) => s.addEventListener('click', () => { index = i; update(); }));

      // Auto-advance every 5s
      let timer = setInterval(() => nextBtn!.click(), 5000);
      root.addEventListener('mouseenter', () => clearInterval(timer));
      root.addEventListener('mouseleave', () => { timer = setInterval(() => nextBtn!.click(), 5000); });

      // Initial centering after layout settles
      requestAnimationFrame(() => requestAnimationFrame(update));
      window.addEventListener('resize', () => requestAnimationFrame(update));
    }
  })();
</script>
