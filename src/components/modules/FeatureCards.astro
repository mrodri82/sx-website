---
/**
 * FeatureCards — grid of cards (default 2 columns). Each card has title,
 * rich-text description, and N buttons (label + href). Used on
 * exhibitors-b2b for "EXPO BOOKING / SPONSORSHIP / BUSINESS / VENUE".
 *
 * Fields:
 *   - items: Array<{ title, description (html), buttons: [{label, href}] }>
 *   - columns: default 2
 *   - card_bg: default #1a1a1a
 */
interface Button { label: string; href: string; }
interface Item { title: string; description?: string; buttons?: Button[]; bg_image?: string; }
interface Props { content: Record<string, any>; }
const { content = {} } = Astro.props;
const items: Item[] = Array.isArray(content.items) ? content.items : [];
const columns = Number(content.columns) || 2;
const cardBg  = content.card_bg || '#1a1a1a';
/* layout:
   - 'standard' (default): title top, description body, buttons bottom
   - 'overlay': apply-link top-left, yellow title bottom-left (on image),
     description on white strip under image (sxtech creators "Choose Your Path") */
const layout = (content.layout === 'overlay' ? 'overlay' : 'standard') as 'overlay'|'standard';
const theme = (content.theme === 'light' ? 'light' : 'dark') as 'light'|'dark';
---

<section data-nova-el="feature-cards" class={`sx-fcards sx-fcards--${layout} sx-fcards--${theme}`} style={`--card-bg:${cardBg};--cols:${columns}`}>
  <div class="sx-fcards-inner">
    <div class="sx-fcards-grid">
      {items.map((it) => {
        const hasBg = !!it.bg_image;
        const primary = (it.buttons && it.buttons[0]) || null;
        if (layout === 'overlay') {
          return (
            <article class={`sx-fcard sx-fcard--overlay${hasBg ? ' sx-fcard--bg' : ''}`} style={hasBg ? `--card-img:url('${it.bg_image}')` : ''}>
              <div class="sx-fcard-media">
                <div class="sx-fcard-ov-text">
                  {primary && (
                    <a class="sx-fcard-apply" data-atom="button" href={primary.href} target={primary.href?.startsWith('http') ? '_blank' : undefined} rel="noopener">
                      {primary.label}
                      <svg class="sx-fcard-apply-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                    </a>
                  )}
                  <h3 class="sx-fcard-title" data-atom="heading">{it.title}</h3>
                </div>
                {it.description && <div class="sx-fcard-desc" data-atom="text" set:html={it.description} />}
              </div>
            </article>
          );
        }
        return (
          <article class={`sx-fcard${hasBg ? ' sx-fcard--bg' : ''}`} style={hasBg ? `--card-img:url('${it.bg_image}')` : ''}>
            <h3 class="sx-fcard-title">{it.title}</h3>
            {it.description && <div class="sx-fcard-desc" set:html={it.description} />}
            {Array.isArray(it.buttons) && it.buttons.length > 0 && (
              <div class="sx-fcard-btns">
                {it.buttons.map((b) => (
                  <a class="sx-fcard-btn" data-atom="button" href={b.href} target={b.href?.startsWith('http') ? '_blank' : undefined} rel="noopener">
                    <span class="sx-fcard-btn-label">{b.label}</span>
                    <span class="sx-fcard-btn-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                    </span>
                  </a>
                ))}
              </div>
            )}
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* Card title values from sxtech.eu post-19.css: Oswald 48px 600 #FFFFFF. */
  .sx-fcards { background: #000; padding: 40px 50px; }
  .sx-fcards--light { background: #FFFFFF; }
  .sx-fcards-inner { max-width: 1440px; margin: 0 auto; }
  .sx-fcards-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 2), 1fr);
    gap: 20px;
  }
  .sx-fcard {
    background: var(--card-bg, #1a1a1a);
    padding: 40px;
    display: flex; flex-direction: column;
    gap: 20px;
    min-height: 320px;
    position: relative; overflow: hidden; isolation: isolate;
  }
  .sx-fcard--bg {
    background-image: var(--card-img);
    background-size: cover; background-position: center;
    min-height: 420px;
  }
  /* Readability scrim over bg-image cards */
  .sx-fcard--bg::before {
    content: ""; position: absolute; inset: 0; z-index: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.2) 60%);
  }
  .sx-fcard--bg > * { position: relative; z-index: 1; }
  .sx-fcard-title {
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 48px; line-height: 1;
    color: #FFFFFF; margin: 0;
    text-transform: uppercase;
    white-space: pre-line;
  }
  .sx-fcard-desc {
    font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 400;
    line-height: 1.4; color: #FFFFFF;
    text-transform: uppercase;
  }
  .sx-fcard-desc p { margin: 0 0 4px; }
  .sx-fcard-btns {
    display: flex; flex-wrap: wrap; gap: 12px; margin-top: auto;
  }
  .sx-fcard-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 20px;
    border: 1px solid #ecfd21;
    background: transparent; color: #ecfd21;
    font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500;
    text-transform: uppercase; text-decoration: none;
    transition: background .15s, color .15s;
  }
  .sx-fcard-btn:hover { background: #ecfd21; color: #000; }
  .sx-fcard-btn-icon { display: inline-flex; align-items: center; }

  /* layout='overlay' — sxtech creators "Choose Your Path":
     image with apply-link top-left and big yellow title bottom-left,
     description below the image on a white strip. */
  .sx-fcard--overlay {
    padding: 0; background: transparent;
    display: flex; flex-direction: column;
    min-height: 0;
  }
  .sx-fcard--overlay::before { content: none; }

  .sx-fcard-media {
    position: relative;
    aspect-ratio: 4 / 3; /* taller than 16:9, matches sxtech card proportion */
    overflow: hidden;
    background-image: var(--card-img);
    background-size: cover;
    background-position: center top; /* keep the face / top of subject visible */
  }
  .sx-fcard-media::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.1) 40%, rgba(0,0,0,0) 70%);
    pointer-events: none;
  }

  /* Apply-link + title stacked, sitting just above the thin white desc band */
  .sx-fcard-ov-text {
    position: absolute; left: 28px; right: 28px; bottom: 92px; z-index: 2;
    display: flex; flex-direction: column; align-items: flex-start; gap: 6px;
  }
  .sx-fcard-apply {
    display: inline-flex; align-items: center; gap: 6px;
    color: #ecfd21; text-decoration: none;
    font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 500;
    text-transform: uppercase; letter-spacing: 0.5px;
    transition: opacity .15s;
  }
  .sx-fcard-apply:hover { opacity: .8; }
  .sx-fcard-apply-icon { display: inline-flex; align-items: center; }

  .sx-fcard--overlay .sx-fcard-title {
    color: #ecfd21 !important;
    font-family: 'Oswald', sans-serif; font-weight: 900;
    font-size: 56px; line-height: 1;
    text-transform: uppercase;
    margin: 0;
  }

  /* Thin white band overlay, 30px from card bottom, padded 20px L/R */
  .sx-fcard--overlay .sx-fcard-desc {
    position: absolute; left: 20px; right: 20px; bottom: 30px; z-index: 2;
    background: #FFFFFF; color: #000;
    padding: 8px 20px;
    font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 500;
    line-height: 1.3; text-transform: uppercase;
  }
  .sx-fcard--overlay .sx-fcard-desc p { margin: 0; }

  @media (max-width: 900px) {
    .sx-fcards-grid { grid-template-columns: 1fr; }
    .sx-fcards { padding: 30px 24px; }
    .sx-fcard { padding: 28px; min-height: 0; }
    .sx-fcard-title { font-size: 36px; }
    .sx-fcard--overlay .sx-fcard-title { font-size: 36px; }
    .sx-fcard-ov-text { left: 20px; right: 20px; bottom: 80px; }
    .sx-fcard--overlay .sx-fcard-desc { bottom: 20px; padding: 8px 16px; font-size: 12px; }
    .sx-fcard--overlay { padding: 0; }
  }
</style>
