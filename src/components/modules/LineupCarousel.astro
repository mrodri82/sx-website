---
/**
 * LineupCarousel — 5-card autoplay carousel (speaker/conversation style).
 * Each card = big portrait image + yellow info-bar with name + role beneath.
 *
 * Fields:
 *   - heading:  "LINEUP", "FEATURED CONVERSATIONS", etc.
 *   - subtitle: small grey subtitle above heading area
 *   - items:    Array<{ image, name, role, href? }>
 *   - slides_visible: default 5 (desktop), 2 (mobile)
 *   - autoplay_ms:    default 4000
 */
interface Item { image: string; name: string; role?: string; href?: string; }
interface Props { content: Record<string, any>; }
const { content = {} } = Astro.props;
const heading  = content.heading  || 'LINEUP';
const subtitle = content.subtitle || '';
const items: Item[] = Array.isArray(content.items) ? content.items : [];
const autoplayMs = Number(content.autoplay_ms) || 4000;
---

<section data-nova-el="lineup-carousel" class="sx-lc">
  <div class="sx-lc-inner">
    <header class="sx-lc-head">
      <h2 class="sx-lc-title">{heading}</h2>
      {subtitle && <p class="sx-lc-sub">{subtitle}</p>}
    </header>

    <div class="sx-lc-viewport">
      <button class="sx-lc-nav sx-lc-prev" type="button" aria-label="Previous">←</button>
      <div class="sx-lc-track" data-autoplay={autoplayMs}>
        {items.map((it) => (
          <article class="sx-lc-card">
            {it.href ? (
              <a class="sx-lc-imgwrap" href={it.href} target={it.href.startsWith('http') ? '_blank' : undefined} rel="noopener">
                <img src={it.image} alt={it.name} loading="lazy" />
              </a>
            ) : (
              <div class="sx-lc-imgwrap">
                <img src={it.image} alt={it.name} loading="lazy" />
              </div>
            )}
            <div class="sx-lc-info">
              <div class="sx-lc-name">{it.name}</div>
              {it.role && <div class="sx-lc-role">{it.role}</div>}
            </div>
          </article>
        ))}
      </div>
      <button class="sx-lc-nav sx-lc-next" type="button" aria-label="Next">→</button>
    </div>
  </div>
</section>

<style>
  /* Values extracted 1:1 from sxtech.eu post-17.css (elements d7018bb/f15ce6a/f499128/dad1b47) */
  .sx-lc { background: #000; padding: 60px 50px 80px; color: #ecfd21; }
  .sx-lc-inner { max-width: 1600px; margin: 0 auto; }
  .sx-lc-head { margin-bottom: 32px; }
  .sx-lc-title {
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 42px; line-height: 1;
    text-transform: uppercase;
    color: #ecfd21; margin: 0 0 4px;
  }
  .sx-lc-sub {
    font-family: 'Inter', sans-serif; font-size: 19px; font-weight: 400;
    color: #D1D1D1;
    margin: 0;
  }
  .sx-lc-viewport { position: relative; }
  .sx-lc-track {
    display: flex; gap: 33px;
    transition: transform .6s cubic-bezier(.4,0,.2,1);
    will-change: transform;
  }
  .sx-lc-card {
    flex: 0 0 calc((100% - 3 * 33px) / 4);
    min-width: 0;
    display: flex; flex-direction: column;
    transition: transform .3s ease;
  }
  .sx-lc-imgwrap {
    display: block; aspect-ratio: 3 / 4;
    overflow: hidden; background: #1a1a1a;
  }
  .sx-lc-imgwrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .sx-lc-info {
    background: transparent; padding: 0;
    transition: background .3s ease;
  }
  .sx-lc-card.is-active .sx-lc-info { background: #ecfd21; }
  .sx-lc-name {
    font-family: 'Oswald', sans-serif; font-weight: 700;
    font-size: 27px; line-height: 1.1;
    text-transform: uppercase;
    color: #ecfd21;
    padding: 5px 20px 0;
  }
  .sx-lc-role {
    font-family: 'Inter', sans-serif; font-size: 19px; font-weight: 400;
    color: #D1D1D1;
    padding: 0 20px 5px;
  }
  .sx-lc-card.is-active .sx-lc-name,
  .sx-lc-card.is-active .sx-lc-role { color: #000; }

  .sx-lc-nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 44px; height: 44px; z-index: 5;
    background: transparent; border: 0; color: #ecfd21;
    font-size: 28px; font-weight: 700; cursor: pointer; line-height: 1;
    display: flex; align-items: center; justify-content: center;
    transition: opacity .15s, color .15s;
  }
  .sx-lc-nav:hover { color: #fff; }
  .sx-lc-prev { left: -44px; }
  .sx-lc-next { right: -44px; }

  @media (max-width: 1200px) {
    .sx-lc-card { flex: 0 0 calc((100% - 2 * 33px) / 3); }
  }
  @media (max-width: 900px) {
    .sx-lc-card { flex: 0 0 calc((100% - 14px) / 2); }
    .sx-lc-track { gap: 14px; }
    .sx-lc-prev { left: 0; }
    .sx-lc-next { right: 0; }
    .sx-lc { padding: 40px 24px 60px; }
    .sx-lc-name { font-size: 23px; padding: 5px 14px 0; }
    .sx-lc-role { font-size: 16px; padding: 0 14px 5px; }
  }
</style>

<script>
  (function () {
    const els = document.querySelectorAll<HTMLElement>('.sx-lc-viewport');
    els.forEach(setup);

    function setup(root: HTMLElement) {
      const track = root.querySelector<HTMLElement>('.sx-lc-track');
      const cards = Array.from(root.querySelectorAll<HTMLElement>('.sx-lc-card'));
      const prev = root.querySelector<HTMLButtonElement>('.sx-lc-prev');
      const next = root.querySelector<HTMLButtonElement>('.sx-lc-next');
      if (!track || cards.length === 0) return;

      let index = 0;
      const total = cards.length;
      const intervalMs = Number(track.dataset.autoplay) || 4000;

      function visible() {
        const w = window.innerWidth;
        if (w <= 900) return 2;
        if (w <= 1200) return 3;
        return 4;
      }

      function update() {
        const v = visible();
        const maxIdx = Math.max(0, total - v);
        if (index > maxIdx) index = 0;
        if (index < 0) index = maxIdx;
        const gap = window.innerWidth <= 900 ? 14 : 33;
        const cardW = cards[0].getBoundingClientRect().width + gap;
        track!.style.transform = `translateX(${-index * cardW}px)`;
        // "active" = the middle card of the visible window (index + floor(v/2))
        cards.forEach(c => c.classList.remove('is-active'));
        const activeIdx = index + Math.floor(v / 2);
        if (cards[activeIdx]) cards[activeIdx].classList.add('is-active');
      }

      let timer = window.setInterval(() => { index++; update(); }, intervalMs);
      function reset() { clearInterval(timer); timer = window.setInterval(() => { index++; update(); }, intervalMs); }

      prev?.addEventListener('click', () => { index--; update(); reset(); });
      next?.addEventListener('click', () => { index++; update(); reset(); });
      root.addEventListener('mouseenter', () => clearInterval(timer));
      root.addEventListener('mouseleave', () => { reset(); });
      window.addEventListener('resize', () => requestAnimationFrame(update));

      requestAnimationFrame(update);
    }
  })();
</script>
