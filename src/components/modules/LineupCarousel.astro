---
/**
 * LineupCarousel — infinite autoplay carousel (tall portrait cards, overlaid info).
 *
 * Fields:
 *   - heading:  "LINEUP"
 *   - subtitle: "WATCH WHAT UNFOLDS"
 *   - items:    Array<{ image, name, role, href? }>
 *   - autoplay_ms: default 4000
 */
interface Item { image: string; name: string; role?: string; href?: string; }
interface Props { content: Record<string, any>; }
const { content = {} } = Astro.props;
const heading  = content.heading  || 'LINEUP';
const subtitle = content.subtitle || '';
const items: Item[] = Array.isArray(content.items) ? content.items : [];
const autoplayMs = Number(content.autoplay_ms) || 4000;

/* Infinite loop: prepend last CLONE_COUNT items, append first CLONE_COUNT items.
   Start index = CLONE_COUNT so the first *real* card is the left-most on load. */
const CLONE = Math.min(4, items.length);
const loopItems: Array<Item & { isClone?: boolean }> = [
  ...items.slice(-CLONE).map(i => ({ ...i, isClone: true })),
  ...items,
  ...items.slice(0, CLONE).map(i => ({ ...i, isClone: true })),
];
---

<section data-nova-el="lineup-carousel" class="sx-lc">
  <div class="sx-lc-inner">
    <header class="sx-lc-head">
      <h2 class="sx-lc-title">{heading}</h2>
      {subtitle && <p class="sx-lc-sub">{subtitle}</p>}
    </header>

    <div class="sx-lc-outer">
      <button class="sx-lc-nav sx-lc-prev" type="button" aria-label="Previous slide">
        <svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg"><path d="M257.5 445.1l-22.2 22.2c-9.4 9.4-24.6 9.4-33.9 0L7 273c-9.4-9.4-9.4-24.6 0-33.9L201.4 44.7c9.4-9.4 24.6-9.4 33.9 0l22.2 22.2c9.5 9.5 9.3 25-.4 34.3L136.6 216H424c13.3 0 24 10.7 24 24v32c0 13.3-10.7 24-24 24H136.6l120.5 114.8c9.8 9.3 10 24.8.4 34.3z"/></svg>
      </button>
      <div class="sx-lc-viewport" data-clone-count={CLONE} data-real-count={items.length}>
      <div class="sx-lc-track" data-autoplay={autoplayMs}>
        {loopItems.map((it) => (
          <article class={`sx-lc-card${it.isClone ? ' sx-lc-card--clone' : ''}`}>
            {it.href ? (
              <a class="sx-lc-imgwrap" href={it.href} target={it.href.startsWith('http') ? '_blank' : undefined} rel="noopener">
                <img src={it.image} alt={it.name} loading="lazy" />
                <div class="sx-lc-info">
                  <div class="sx-lc-name">{it.name}</div>
                  {it.role && <div class="sx-lc-role">{it.role}</div>}
                </div>
              </a>
            ) : (
              <div class="sx-lc-imgwrap">
                <img src={it.image} alt={it.name} loading="lazy" />
                <div class="sx-lc-info">
                  <div class="sx-lc-name">{it.name}</div>
                  {it.role && <div class="sx-lc-role">{it.role}</div>}
                </div>
              </div>
            )}
          </article>
        ))}
      </div>
      </div>
      <button class="sx-lc-nav sx-lc-next" type="button" aria-label="Next slide">
        <svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
  /* Values extracted 1:1 from sxtech.eu post-17.css (d7018bb/f15ce6a/f499128/dad1b47) */
  .sx-lc { background: #000; padding: 60px 50px 80px; color: #ecfd21; }
  .sx-lc-inner { max-width: 1366px; margin: 0 auto; }
  .sx-lc-head { margin-bottom: 32px; }
  .sx-lc-title {
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 42px; line-height: 1;
    text-transform: uppercase;
    color: #ecfd21; margin: 0 0 4px;
  }
  .sx-lc-sub {
    font-family: 'Inter', sans-serif; font-size: 19px; font-weight: 400;
    color: #D1D1D1; margin: 0;
  }

  /* Viewport is full-width; arrows float absolutely OUTSIDE its box,
     overhanging into the section's 50px side-padding (sxtech layout). */
  .sx-lc-outer { position: relative; }
  .sx-lc-viewport { width: 100%; overflow: hidden; }
  .sx-lc-track {
    display: flex; gap: 14px;
    transition: transform .6s cubic-bezier(.4,0,.2,1);
    will-change: transform;
  }
  .sx-lc-track.is-jumping { transition: none; }

  .sx-lc-card {
    flex: 0 0 calc((100% - 3 * 14px) / 4);
    min-width: 0;
    display: block;
  }
  /* Taller, narrower portrait (2:3 instead of 3:4) */
  .sx-lc-imgwrap {
    position: relative; display: block;
    aspect-ratio: 2 / 3; overflow: hidden;
    background: #1a1a1a; text-decoration: none; color: inherit;
  }
  .sx-lc-imgwrap img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .4s ease; }
  .sx-lc-imgwrap:hover img { transform: scale(1.03); }

  /* Info bar sits ON the image, 80px from bottom (sxtech layout) */
  .sx-lc-info {
    position: absolute; left: 0; right: 0; bottom: 80px;
    background: #ecfd21; color: #000;
    padding: 5px 20px;
  }
  .sx-lc-name {
    font-family: 'Oswald', sans-serif; font-weight: 700;
    font-size: 27px; line-height: 1.1;
    text-transform: uppercase; color: #000;
  }
  .sx-lc-role {
    font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 500;
    color: #000; margin-top: 2px;
  }

  /* Thick, bold arrow buttons (sxtech fa-arrow svg path).
     Absolute-positioned, offset outside the viewport by ~50px. */
  .sx-lc-nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 44px; height: 44px; z-index: 5;
    background: transparent; border: 0; color: #ecfd21;
    cursor: pointer; padding: 0;
    display: flex; align-items: center; justify-content: center;
    transition: color .15s;
  }
  .sx-lc-nav svg { width: 28px; height: 32px; fill: currentColor; }
  .sx-lc-nav:hover { color: #fff; }
  .sx-lc-prev { left: -50px; }
  .sx-lc-next { right: -50px; }

  @media (max-width: 1200px) {
    .sx-lc-card { flex: 0 0 calc((100% - 2 * 14px) / 3); }
  }
  @media (max-width: 900px) {
    .sx-lc-card { flex: 0 0 calc((100% - 14px) / 2); }
    .sx-lc { padding: 40px 24px 60px; }
    .sx-lc-name { font-size: 22px; padding: 5px 14px 0; }
    .sx-lc-role { font-size: 14px; padding: 0 14px 5px; }
    .sx-lc-info { bottom: 40px; padding: 5px 14px; }
    /* Mobile: pull arrows in so they don't clip outside the 24px section pad */
    .sx-lc-prev { left: -22px; }
    .sx-lc-next { right: -22px; }
    .sx-lc-nav svg { width: 20px; height: 24px; }
  }
</style>

<script>
  (function () {
    const els = document.querySelectorAll<HTMLElement>('.sx-lc-viewport');
    els.forEach(setup);

    function setup(root: HTMLElement) {
      const track = root.querySelector<HTMLElement>('.sx-lc-track');
      const cards = Array.from(root.querySelectorAll<HTMLElement>('.sx-lc-card'));
      const prev = root.querySelector<HTMLButtonElement>('.sx-lc-prev');
      const next = root.querySelector<HTMLButtonElement>('.sx-lc-next');
      if (!track || cards.length === 0) return;

      const clone = Number(root.dataset.cloneCount) || 0;
      const real  = Number(root.dataset.realCount)  || cards.length;
      const intervalMs = Number(track.dataset.autoplay) || 4000;

      /* Virtual index in the [clone .. clone+real-1] range. The track has
         (clone + real + clone) items. When we hit a clone boundary we jump
         back into the real window after the transition ends. */
      let index = clone;

      function gapPx() { return 14; }
      function cardWidth() { return cards[0].getBoundingClientRect().width + gapPx(); }

      function apply() {
        track!.style.transform = `translateX(${-index * cardWidth()}px)`;
      }
      function jumpTo(i: number) {
        track!.classList.add('is-jumping');
        index = i;
        apply();
        /* Force reflow then drop the instant-class so the next move animates */
        track!.getBoundingClientRect();
        track!.classList.remove('is-jumping');
      }

      track.addEventListener('transitionend', () => {
        if (index >= clone + real) jumpTo(index - real);
        else if (index < clone)     jumpTo(index + real);
      });

      function step(dir: 1 | -1) { index += dir; apply(); }

      let timer = window.setInterval(() => step(1), intervalMs);
      function reset() { clearInterval(timer); timer = window.setInterval(() => step(1), intervalMs); }

      prev?.addEventListener('click', () => { step(-1); reset(); });
      next?.addEventListener('click', () => { step(1);  reset(); });
      root.addEventListener('mouseenter', () => clearInterval(timer));
      root.addEventListener('mouseleave', () => reset());
      window.addEventListener('resize', () => requestAnimationFrame(apply));

      requestAnimationFrame(apply);
    }
  })();
</script>
