---
/**
 * FeaturedConversations — 3 static interview cards (NO carousel).
 * Layout per card: portrait image, label top-left (INTERVIEW),
 * status top-right (READ / COMING SOON), big name bottom-left overlaid.
 *
 * Fields:
 *   - heading:  "FEATURED CONVERSATIONS"
 *   - subtitle: "VOICES OF SX FESTIVAL & SX EXPO"
 *   - items:    Array<{ image, label, status?, name, href? }>
 */
interface Item { image: string; label: string; status?: string; name: string; href?: string; }
interface Props { content: Record<string, any>; }
const { content = {} } = Astro.props;
const heading  = content.heading  || 'FEATURED CONVERSATIONS';
const subtitle = content.subtitle || '';
const items: Item[] = Array.isArray(content.items) ? content.items : [];
---

<section data-nova-el="featured-conversations" class="sx-fc">
  <div class="sx-fc-inner">
    <header class="sx-fc-head">
      <h2 class="sx-fc-title">{heading}</h2>
      {subtitle && <p class="sx-fc-sub">{subtitle}</p>}
    </header>

    <div class="sx-fc-grid">
      {items.map((it) => {
        const Inner = (
          <>
            <img src={it.image} alt={it.name} loading="lazy" />
            <span class="sx-fc-label">{it.label}</span>
            {it.status && <span class="sx-fc-status">{it.status}</span>}
            <div class="sx-fc-name">{it.name}</div>
          </>
        );
        return it.href ? (
          <a class="sx-fc-card" href={it.href} target={it.href.startsWith('http') ? '_blank' : undefined} rel="noopener">{Inner}</a>
        ) : (
          <div class="sx-fc-card">{Inner}</div>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* Values extracted 1:1 from sxtech.eu post-17.css (b646e6a/6dd4495/a87da93/702a734/8f98669) */
  .sx-fc { background: #000; padding: 60px 50px 80px; color: #ecfd21; }
  .sx-fc-inner { max-width: 1366px; margin: 0 auto; }
  .sx-fc-head { margin-bottom: 32px; }
  .sx-fc-title {
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 42px; line-height: 1;
    text-transform: uppercase;
    color: #ecfd21; margin: 0 0 4px;
  }
  .sx-fc-sub {
    font-family: 'Inter', sans-serif; font-size: 19px; font-weight: 400;
    color: #D1D1D1; text-transform: uppercase;
    margin: 0;
  }

  .sx-fc-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .sx-fc-card {
    position: relative; display: block;
    aspect-ratio: 2 / 3;
    background: #1a1a1a; overflow: hidden;
    text-decoration: none; color: inherit;
  }
  .sx-fc-card img {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
    transition: transform .4s ease;
  }
  a.sx-fc-card:hover img { transform: scale(1.03); }

  /* Force white over the parent yellow cascade (.sx-fc has color: #ecfd21). */
  .sx-fc-label, .sx-fc-status {
    position: absolute; top: 20px; z-index: 2;
    font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 400;
    text-transform: uppercase; color: #fff !important;
  }
  .sx-fc-label  { left: 20px; }
  .sx-fc-status { right: 20px; }

  .sx-fc-name {
    position: absolute; left: 20px; right: 20px; bottom: 24px; z-index: 2;
    font-family: 'Oswald', sans-serif; font-weight: 900;
    font-size: 40px; line-height: 1;
    text-transform: uppercase; color: #fff !important;
  }

  @media (max-width: 900px) {
    .sx-fc { padding: 40px 24px 60px; }
    .sx-fc-grid { grid-template-columns: 1fr; }
    .sx-fc-name { font-size: 32px; }
    .sx-fc-label, .sx-fc-status { font-size: 14px; }
  }
</style>
