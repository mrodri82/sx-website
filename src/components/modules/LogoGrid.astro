---
import { t, tItems } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  content: Record<string, unknown>;
  style: Record<string, string>;
  overrides?: Record<string, string>;
  locale?: Locale;
}

const { content, style, overrides, locale = 'es' } = Astro.props;

const label = t(content, 'label', locale);
const headline = t(content, 'headline', locale);
const logos = tItems((content.logos as Record<string, unknown>[]) || [], locale);
---

<section data-nova-el="logogrid-section" class="py-24 relative">
  <div class="max-w-7xl mx-auto px-6">
    {(label || headline) && (
      <div class="max-w-2xl mb-16">
        {label && (
          <p data-animate="fade-up" class="text-xs font-mono text-brand-400 uppercase tracking-widest mb-4">{label}</p>
        )}
        {headline && (
          <h2 data-nova-el="logogrid-title" data-animate="fade-up" data-delay="0.1" class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white mb-6">
            {headline}
          </h2>
        )}
      </div>
    )}

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-8 items-center" data-stagger="0.05">
      {logos.map((logo) => (
        <div data-animate="fade-up" class="flex items-center justify-center p-4">
          <img
            src={logo.image}
            alt={logo.name || ''}
            class="max-h-12 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
