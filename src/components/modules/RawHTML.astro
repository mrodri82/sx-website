---
/**
 * RawHTML — pastes arbitrary HTML + CSS into the page.
 *
 * Use case: clones migrated from an external page builder (e.g. Elementor).
 * Scraped HTML + the page's generated CSS are stored verbatim; Nova renders
 * the block unchanged so visual output matches source pixel-for-pixel.
 *
 * Fields (inside `content`):
 *   - html             — full HTML fragment (non-localized)
 *   - html_es/en/de    — localized HTML fragments
 *   - css              — optional CSS injected before the block
 */
const { content = {}, locale = 'es' } = Astro.props as {
  content?: Record<string, unknown>;
  locale?: 'es' | 'en' | 'de';
};

const c: any = content || {};
const html: string = c[`html_${locale}`] || c.html || c.html_en || c.html_es || '';
const css: string = c.css || '';
---

{css && <style set:html={css} />}
<section data-nova-el="rawhtml-section" set:html={html}></section>
