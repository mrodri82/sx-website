---
/**
 * MabelWheel — SSR-renders the Mabel Wheel-of-Fortune shortcode live from WP.
 *
 * The plugin signs each render with a time-limited encrypted sequence + WP nonce
 * (expires after ~20 min / 24 h respectively). Baking the HTML once into
 * sections_json breaks the spinner with "Not allowed". This module refetches
 * on every request so the seq/nonce are always fresh.
 *
 * Fields (content):
 *   - wheel_id: WP post ID of the wheel (default 228)
 *   - title: heading shown above (default "SPIN & WIN")
 *   - background: hero-style background image URL (optional)
 */
import { site } from '@/config/site';

const { content = {} } = Astro.props as { content?: Record<string, any> };
const wheelId = content.wheel_id || 228;
const bg = content.background || '/media/wheel-tlo.png';

let wheelHtml = '<div style="padding:40px;text-align:center;color:#888">Wheel temporarily unavailable.</div>';

try {
  const res = await fetch(`${site.cmsUrl}/index.php/?rest_route=/sx/v1/wheel/${wheelId}`, {
    headers: { Host: site.cmsHost },
  });
  if (res.ok) {
    const data = await res.json();
    if (data?.html) wheelHtml = data.html;
  }
} catch (err) {
  console.error('[MabelWheel] failed to fetch wheel', err);
}
---

<section data-nova-el="mabel-wheel" class="sx-wof-section" style={bg ? `--wof-bg:url('${bg}')` : ''}>
  <div class="sx-wof-holder" set:html={wheelHtml} />
</section>

<link rel="stylesheet" href="/wp-content/plugins/mabel-wheel-of-fortune/public/css/public.min.css?ver=4.0" />
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" is:inline></script>
<script src="/wp-content/plugins/mabel-wheel-of-fortune/public/js/public.min.js?ver=4.0" is:inline></script>

<style is:global>
  /* Cancel any body-lock the plugin JS might set — keep page scrollable */
  body.wof-is-open { overflow: auto !important; height: auto !important; width: auto !important; }

  .sx-wof-section {
    background-color: #000;
    background-image: var(--wof-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 0; scroll-margin-top: 100px;
    position: relative; isolation: isolate;
  }
  .sx-wof-holder { position: relative; z-index: 1; }

  /* Scale the standalone wheel up to match sxtech.eu sizing (originally
     500px wheel-bg, we bump inner wheel width on desktop via CSS override). */
  .sx-wof-section .wof-wheel-standalone { max-width: 1200px; margin: 0 auto; padding: 60px 40px; }
  .sx-wof-section .wof-wheel-standalone .wof-wheel-bg { width: 520px !important; height: 520px !important; }
  /* Keep wheel + form side-by-side on desktop — prevent flex-wrap */
  .sx-wof-section .wof-wheel-standalone .wof-wheel .wof-inner-wrapper {
    flex-wrap: nowrap !important;
    gap: 60px;
    justify-content: center;
  }
  .sx-wof-section .wof-wheel-standalone .wof-left { flex: 0 0 auto; }
  .sx-wof-section .wof-wheel-standalone .wof-right { flex: 1 1 380px; min-width: 320px; }
  @media (max-width: 900px) {
    .sx-wof-section .wof-wheel-standalone { padding: 40px 20px; }
    .sx-wof-section .wof-wheel-standalone .wof-wheel-bg { width: 90vw !important; height: 90vw !important; max-width: 500px; max-height: 500px; }
    .sx-wof-section .wof-wheel-standalone .wof-wheel .wof-inner-wrapper { gap: 36px; }
    .sx-wof-section .wof-wheel-standalone .wof-right { padding-left: 0; margin-top: 20px; }
  }
</style>
