---
import { tItems } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  content: Record<string, unknown>;
  style: Record<string, string>;
  overrides?: Record<string, string>;
  locale?: Locale;
}

const { content, style, overrides, locale = 'es' } = Astro.props;
const items = tItems((content.items as Record<string, unknown>[]) || [], locale);
---

<section data-nova-el="numbers-section" class="py-12 border-y border-navy-800/50">
  <div class="max-w-7xl mx-auto px-6">
    <div class={`grid grid-cols-2 ${items.length <= 3 ? 'lg:grid-cols-3' : 'lg:grid-cols-4'} gap-6`} data-stagger="0.1">
      {items.map((item) => (
        <div data-animate="fade-up" class="text-center">
          <div data-nova-el="numbers-value" class="font-display text-2xl sm:text-3xl font-bold text-white mb-1"
               data-count-to={item.value} data-count-suffix={item.suffix}>
            {item.value}{item.suffix}
          </div>
          <p data-nova-el="numbers-label" class="text-xs text-navy-400 font-mono uppercase tracking-wider">
            {item.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
