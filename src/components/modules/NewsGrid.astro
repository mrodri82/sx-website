---
/**
 * NewsGrid — 3-column news/recap post grid. Each item: square image,
 * category tag (NEWS/RECAP), title (link), optional excerpt, date.
 *
 * Fields:
 *   - items: Array<{ image, category, title, href, description?, date }>
 *   - columns: default 3
 */
interface Item {
  image: string; category?: string; title: string; href?: string;
  description?: string; date?: string;
}
interface Props { content: Record<string, any>; }
const { content = {} } = Astro.props;
const items: Item[] = Array.isArray(content.items) ? content.items : [];
const columns = Number(content.columns) || 3;
---

<section data-nova-el="news-grid" class="sx-ng" style={`--cols:${columns}`}>
  <div class="sx-ng-inner">
    <div class="sx-ng-grid">
      {items.map((it) => (
        <article class="sx-ng-card">
          {it.href ? (
            <a class="sx-ng-imgwrap" href={it.href} target={it.href?.startsWith('http') ? '_blank' : undefined} rel="noopener">
              <img src={it.image} alt={it.title} loading="lazy" />
            </a>
          ) : (
            <div class="sx-ng-imgwrap"><img src={it.image} alt={it.title} loading="lazy" /></div>
          )}
          {it.category && <div class="sx-ng-cat">{it.category}</div>}
          <h3 class="sx-ng-title">
            {it.href ? <a href={it.href} target="_blank" rel="noopener">{it.title}</a> : it.title}
          </h3>
          {it.description && <p class="sx-ng-desc">{it.description}</p>}
          {it.date && <time class="sx-ng-date">{it.date}</time>}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .sx-ng { background: #000; padding: 40px 50px 80px; }
  .sx-ng-inner { max-width: 1366px; margin: 0 auto; }
  .sx-ng-grid {
    display: grid; grid-template-columns: repeat(var(--cols, 3), 1fr); gap: 40px;
  }
  .sx-ng-card { display: flex; flex-direction: column; gap: 12px; }
  .sx-ng-imgwrap {
    display: block; aspect-ratio: 1; overflow: hidden;
    background: #1a1a1a;
  }
  .sx-ng-imgwrap img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform .4s ease;
  }
  .sx-ng-imgwrap:hover img { transform: scale(1.03); }

  .sx-ng-cat {
    font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600;
    text-transform: uppercase; color: #ecfd21;
    letter-spacing: 0.5px;
  }
  .sx-ng-title {
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 30px; line-height: 1.1;
    text-transform: uppercase; color: #FFFFFF; margin: 0;
  }
  .sx-ng-title a { color: inherit; text-decoration: none; }
  .sx-ng-title a:hover { color: #ecfd21; }
  .sx-ng-desc {
    font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 400;
    line-height: 1.4; color: #FFFFFF; margin: 0;
  }
  .sx-ng-date {
    font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 400;
    text-transform: uppercase; color: #A6A6A6; letter-spacing: 0.5px;
  }

  @media (max-width: 1200px) {
    .sx-ng-grid { grid-template-columns: repeat(2, 1fr); gap: 30px; }
    .sx-ng-title { font-size: 24px; }
  }
  @media (max-width: 768px) {
    .sx-ng { padding: 30px 24px 60px; }
    .sx-ng-grid { grid-template-columns: 1fr; gap: 24px; }
  }
</style>
