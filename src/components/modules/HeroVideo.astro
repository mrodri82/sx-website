---
/**
 * HeroVideo — SX style, matches sxtech.eu exact layout
 *
 * Layout:
 *   [label small yellow]
 *   SX FESTIVAL            <- huge yellow Oswald line 1
 *   EXPO  JUNE 26-28       <- huge yellow + inline date block
 *         BERLIN
 *         2026
 *   [tagline_label yellow small]
 *   [tagline_body yellow body]
 *   [Primary Button (yellow fill)]  [Ghost Button (outlined white)]
 */
import { t } from '@/lib/i18n';
import { getLocaleFromPath } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  content: Record<string, unknown>;
  style?: Record<string, Record<string, string>>;
}

const { content } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname) as Locale;

const badge    = t(content, 'badge', locale);
const title1   = t(content, 'title1', locale);
const title2   = t(content, 'title2', locale);
const date1    = t(content, 'date1', locale);
const date2    = t(content, 'date2', locale);
const date3    = t(content, 'date3', locale);
const taglineLabel = t(content, 'tagline_label', locale);
const taglineBody  = t(content, 'tagline_body', locale);
const cta1Text = t(content, 'cta1_text', locale);
const cta1Url  = (content.cta1_url as string) || '#';
const cta2Text = t(content, 'cta2_text', locale);
const cta2Url  = (content.cta2_url as string) || '#';
const videoUrl = (content.video_url as string) || '';
const posterUrl = (content.poster_url as string) || '';
---

<section data-nova-el="hero-video-section" class="sx-hero relative w-full min-h-screen overflow-hidden bg-black">
  {videoUrl && (
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay muted loop playsinline preload="metadata"
      poster={posterUrl || undefined}
    >
      <source src={videoUrl} type="video/mp4" />
    </video>
  )}
  {/* No overlay — sxtech hero shows video full-color, only fade at bottom */}
  <div class="absolute inset-x-0 bottom-0 h-[30%] bg-gradient-to-t from-black/70 to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 w-full min-h-screen pt-[140px] pb-[50px] pl-[60px] pr-[60px] flex flex-col justify-between">
    <div>
      {badge && (
        <p data-nova-el="hero-video-badge" class="sx-hero-badge">{badge}</p>
      )}
    </div>

    <div class="flex-1 flex flex-col justify-center">
      <h1 data-nova-el="hero-video-title" class="sx-hero-title m-0">
        {title1 && <span class="sx-hero-word">{title1}</span>}
        <span class="sx-hero-row">
          {title2 && <span class="sx-hero-word">{title2}</span>}
          {(date1 || date2 || date3) && (
            <span class="sx-hero-dates">
              {date1 && <span class="block">{date1}</span>}
              {date2 && <span class="block">{date2}</span>}
              {date3 && <span class="block">{date3}</span>}
            </span>
          )}
        </span>
      </h1>
    </div>

    <div class="sx-hero-bottom">
      {taglineLabel && (
        <p data-nova-el="hero-video-tagline-label" class="sx-hero-tagline-label">
          <b>{taglineLabel}</b>
        </p>
      )}
      {taglineBody && (
        <p data-nova-el="hero-video-tagline-body" class="sx-hero-tagline-body"
           set:html={taglineBody.replace(/\n/g, '<br>')} />
      )}

      <div class="sx-hero-ctas mt-6">
        {cta1Text && <a data-nova-el="hero-video-cta1" href={cta1Url} class="sx-hero-btn">{cta1Text}</a>}
        {cta2Text && <a data-nova-el="hero-video-cta2" href={cta2Url} class="sx-hero-btn">{cta2Text}</a>}
      </div>
    </div>
  </div>
</section>

<style is:global>
  .sx-hero-badge {
    font-family:'Inter', sans-serif;
    font-size:23px; font-weight:500; line-height:1;
    color:#ecfd21; text-transform:uppercase; letter-spacing:0;
    margin:0 0 24px 0;
  }
  .sx-hero-title { display:block; }
  .sx-hero-word {
    font-family:'Oswald','Inter',sans-serif;
    font-weight:800;
    font-size:clamp(72px, 11vw, 156px);
    line-height:.95;
    letter-spacing:-0.04em;
    text-transform:uppercase;
    color:#ecfd21;
    display:block;
  }
  .sx-hero-row { display:flex; flex-wrap:wrap; align-items:flex-start; gap:0 36px; }
  .sx-hero-row .sx-hero-word { display:inline-block; }
  .sx-hero-dates {
    font-family:'Inter',sans-serif;
    font-size:16px; font-weight:500; line-height:1.2;
    color:#ecfd21; text-transform:uppercase;
    align-self:flex-end;
    padding-bottom:18px;
  }
  .sx-hero-tagline-label {
    font-family:'Inter',sans-serif;
    font-size:16px; font-weight:700;
    color:#ecfd21; text-transform:uppercase; letter-spacing:0;
    line-height:1.2;
    margin:0 0 4px 0;
  }
  .sx-hero-tagline-label b { font-weight:700; }
  .sx-hero-tagline-body {
    font-family:'Inter',sans-serif;
    font-size:16px; font-weight:500; line-height:1.25;
    color:#ecfd21; text-transform:uppercase;
    max-width:720px;
    margin:0;
  }
  .sx-hero-ctas { display:flex; flex-wrap:wrap; gap:12px; }
  .sx-hero-btn {
    background:#ecfd21 !important; color:#000 !important;
    font-family:'Inter',sans-serif;
    font-size:15px; font-weight:500; line-height:1;
    padding:25px 50px;
    border:0; border-radius:0; outline:0;
    text-decoration:none; display:inline-flex; align-items:center;
    transition:opacity .15s;
  }
  .sx-hero-btn:hover { opacity:.85; }
  @media (max-width: 768px) {
    .sx-hero-word { font-size:clamp(48px, 14vw, 96px); }
    .sx-hero-dates { padding-bottom:0; font-size:14px; }
  }
</style>
