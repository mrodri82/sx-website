---
/**
 * HeroVideo — SX style
 * Full-viewport video background + huge bold uppercase title.
 * Matches sxtech.eu homepage hero pattern.
 */
import { t } from '@/lib/i18n';
import { getLocaleFromPath } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  content: Record<string, unknown>;
  style?: Record<string, Record<string, string>>;
}

const { content, style = {} } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname) as Locale;

const badge    = t(content, 'badge', locale);
const headline = t(content, 'headline', locale);
const subtitle = t(content, 'subtitle', locale);
const ctaText  = t(content, 'cta_primary_text', locale);
const ctaUrl   = (content.cta_primary_url as string) || '/regular-visitors';
const videoUrl = (content.video_url as string) || '';
const posterUrl = (content.poster_url as string) || '';

const sectionStyle = Object.entries(style['hero-video-section'] || {}).map(([k, v]) => `${k}: ${v}`).join('; ');
---

<section data-nova-el="hero-video-section" class="relative w-full min-h-[100vh] overflow-hidden flex items-end bg-black" style={sectionStyle}>
  {videoUrl && (
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay muted loop playsinline preload="metadata"
      poster={posterUrl || undefined}
    >
      <source src={videoUrl} type="video/mp4" />
    </video>
  )}
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/30" aria-hidden="true"></div>

  <div class="relative z-10 w-full max-w-[1600px] mx-auto px-8 pb-16 md:pb-24">
    {badge && (
      <p data-nova-el="hero-video-badge" class="text-[13px] font-medium uppercase tracking-[0.03em] text-brand-500 mb-4">{badge}</p>
    )}
    {headline && (
      <h1 data-nova-el="hero-video-title"
          class="sx-heading text-white mb-8"
          style="font-size: clamp(72px, 10vw, 156px); letter-spacing: -0.04em; line-height: 0.9;"
          set:html={headline} />
    )}
    {subtitle && (
      <p data-nova-el="hero-video-subtitle" class="text-white/80 text-base max-w-xl mb-10 leading-relaxed uppercase font-medium tracking-wide">{subtitle}</p>
    )}
    {ctaText && (
      <a data-nova-el="hero-video-cta" href={ctaUrl} class="sx-btn sx-btn--large">{ctaText}</a>
    )}
  </div>
</section>
