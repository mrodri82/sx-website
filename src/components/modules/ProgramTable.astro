---
/**
 * ProgramTable — header row + N data rows for the B2B programme.
 * Columns: (icon), Theme, Voices, Track, Stage & Date.
 *
 * Fields:
 *   - items: Array<{ icon, theme, voices, track, stage }>
 *   - heading: row labels (optional overrides)
 */
interface Row { icon?: string; theme: string; voices: string; track: string; stage: string; }
interface Props { content: Record<string, any>; }
const { content = {} } = Astro.props;
const rows: Row[] = Array.isArray(content.items) ? content.items : [];
const theme = (content.theme === 'light' ? 'light' : 'dark') as 'light'|'dark';
const labels = Object.assign(
  { theme: 'Theme', voices: 'Voices', track: 'Track', stage: 'Stage & Date' },
  content.labels || {}
);
---

<section data-nova-el="program-table" class={`sx-tb sx-tb--${theme}`}>
  <div class="sx-tb-inner">
    <div class="sx-tb-row sx-tb-head">
      <div class="sx-tb-cell sx-tb-icon"></div>
      <div class="sx-tb-cell sx-tb-theme"><span>{labels.theme}</span></div>
      <div class="sx-tb-cell sx-tb-voices"><span>{labels.voices}</span></div>
      <div class="sx-tb-cell sx-tb-track"><span>{labels.track}</span></div>
      <div class="sx-tb-cell sx-tb-stage"><span>{labels.stage}</span></div>
    </div>
    {rows.map((r) => (
      <div class="sx-tb-row">
        <div class="sx-tb-cell sx-tb-icon">
          {r.icon && <img src={r.icon} alt="" loading="lazy" />}
        </div>
        <div class="sx-tb-cell sx-tb-theme"><span>{r.theme}</span></div>
        <div class="sx-tb-cell sx-tb-voices"><span>{r.voices}</span></div>
        <div class="sx-tb-cell sx-tb-track"><span>{r.track}</span></div>
        <div class="sx-tb-cell sx-tb-stage" set:html={r.stage.replace(/\n/g, '<br>')} />
      </div>
    ))}
  </div>
</section>

<style>
  /* Table cells Inter 20px 400 white (headers 20px 600-700 center). */
  .sx-tb { background: #000; padding: 20px 50px 60px; }
  .sx-tb--light { background: #FFFFFF; }
  .sx-tb--light .sx-tb-cell { color: #000; }
  .sx-tb--light .sx-tb-row { border-bottom-color: rgba(0,0,0,0.12); }
  .sx-tb--light .sx-tb-head { border-bottom-color: rgba(0,0,0,0.3); }
  .sx-tb-inner { max-width: 1440px; margin: 0 auto; }

  .sx-tb-row {
    display: grid;
    grid-template-columns: 80px 2fr 1.3fr 1.1fr 1.1fr;
    gap: 16px; align-items: center;
    padding: 20px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .sx-tb-head {
    border-bottom: 1px solid rgba(255,255,255,0.25);
  }
  .sx-tb-head .sx-tb-cell { font-weight: 600; }

  .sx-tb-cell {
    font-family: 'Inter', sans-serif; font-size: 20px; font-weight: 400;
    line-height: 1.3; color: #fff;
  }
  .sx-tb-theme  { text-align: start; font-weight: 600; }
  .sx-tb-voices { text-align: start; }
  .sx-tb-track  { text-align: start; }
  .sx-tb-stage  { text-align: center; }
  .sx-tb-head .sx-tb-theme, .sx-tb-head .sx-tb-voices { font-weight: 700; }

  .sx-tb-icon {
    display: flex; align-items: center; justify-content: center;
  }
  .sx-tb-icon img { width: 40px; height: 40px; object-fit: contain; }
  .sx-tb-head .sx-tb-icon { min-height: 1px; }

  @media (max-width: 900px) {
    .sx-tb { padding: 20px 24px 40px; }
    .sx-tb-row {
      grid-template-columns: 60px 1fr;
      grid-auto-rows: auto; gap: 8px 14px;
      padding: 18px 0;
    }
    .sx-tb-head { display: none; }
    .sx-tb-icon { grid-row: span 4; }
    .sx-tb-cell { font-size: 15px; }
    .sx-tb-theme { font-size: 17px; }
  }
</style>
