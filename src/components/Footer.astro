---
/**
 * SX Festival — Footer
 * 1:1 of sxtech.eu footer (extracted 19.04.2026 via Playwright).
 *
 * Structure (desktop):
 *   Row 1: Logo (left)  |  CONTACT US form (right, ~x=730)
 *   Row 2: Giant "SX FESTIVAL EXPO 2026 BERLIN" Oswald 89px fw800
 *          ("SX FESTIVAL EXPO" yellow, "2026 BERLIN" white)
 *   Row 3: Socials + rights (left) | Media links (middle) | Imprint (right)
 */
import { site } from '@/config/site';
---

<footer class="sx-footer bg-black text-[#ecfd21] pt-[60px] pb-10">
  <div class="sx-footer-container max-w-[1600px] mx-auto">

    {/* Row 1: Logo + Brand headline (left) | Contact form (right) */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-8">
      <div>
        <a href="/" class="sx-footer-logo" aria-label="SX Festival & Expo 2026 Berlin">
          sxfestival expo berlin
        </a>
        <h2 class="sx-footer-brand">
          <span class="text-[#ecfd21]">SX FESTIVAL EXPO</span>
          <span class="text-white"> 2026 BERLIN</span>
        </h2>
      </div>

      <div class="md:pl-0 md:max-w-[440px]">
        <div class="sx-footer-h">contact us</div>
        <form action={`mailto:${site.contactEmail}`} method="post" enctype="text/plain" class="space-y-3 mt-4">
          <textarea name="message" placeholder="TEXT" rows={6}
            class="w-full bg-white text-black px-4 py-3 text-[15px] font-medium placeholder-[#7a7a7a] outline-none resize-none"
            style="border-radius:0" required></textarea>
          <input type="email" name="email" placeholder="ADD YOUR EMAIL"
            class="w-full bg-white text-black px-4 py-4 text-[15px] font-medium uppercase placeholder-[#7a7a7a] outline-none"
            style="border-radius:0" required />
          <button type="submit" class="sx-footer-cta">SEND TO US</button>
        </form>
      </div>
    </div>

    {/* Row 3: three columns — social/rights | media links | imprint */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mt-10">

      {/* Socials + rights */}
      <div>
        <div class="flex items-center gap-3 mb-6">
          <a href={site.instagramUrl} target="_blank" rel="noopener" aria-label="Instagram"
            class="sx-social inline-flex items-center justify-center w-[37px] h-[37px]">
            <svg viewBox="0 0 24 24" class="w-[30px] h-[30px]" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a href={site.linkedinUrl} target="_blank" rel="noopener" aria-label="LinkedIn"
            class="sx-social inline-flex items-center h-[34px]">
            <svg viewBox="0 0 120 34" class="h-[34px] w-[120px]">
              <text x="0" y="27" font-family="Inter, Arial, sans-serif" font-size="26" font-weight="700" letter-spacing="-1" fill="#ecfd21">Linked</text>
              <rect x="84" y="2" width="30" height="30" rx="4" fill="#ecfd21"/>
              <text x="90" y="25" font-family="Inter, Arial, sans-serif" font-size="20" font-weight="900" fill="#000000">in</text>
            </svg>
          </a>
        </div>
        <p class="sx-footer-line">ALL RIGHTS RESERVED</p>
        <p class="sx-footer-line">COPY BY SXTECHU</p>
      </div>

      {/* Media links — external targets taken 1:1 from sxtech.eu */}
      <ul class="sx-footer-list space-y-1">
        <li><a href="https://wkf.ms/3Lk6OcG" target="_blank" rel="noopener">MEDIA APPLY</a></li>
        <li><a href="https://www.canva.com/design/DAHCUNFA0W0/D4lV1-fzKOdl21vKCBXEOw/view" target="_blank" rel="noopener">MEDIA KIT 2026</a></li>
        <li><a href="/cfp-form">SPEAKERS CFP</a></li>
        <li><a href="https://wkf.ms/49zQjCt" target="_blank" rel="noopener">BRAND AMBASSADORS</a></li>
        <li><a href="https://www.canva.com/design/DAHD1Gv1Mpw/qmpRj-p7yoJu9CjTqw3lkQ/view" target="_blank" rel="noopener">JOBS</a></li>
      </ul>

      {/* Imprint */}
      <div class="sx-footer-imprint">
        <p class="sx-footer-line font-bold">IMPRINT</p>
        <p class="sx-footer-line">{site.legalName} HRB 2584 19 B6</p>
        <p class="sx-footer-line">{site.streetAddress},</p>
        <p class="sx-footer-line">Potsdamer Platz, {site.city} {site.postalCode}</p>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  .sx-footer { background:#000; color:#ecfd21; font-family:'Inter', -apple-system, sans-serif; }
  .sx-footer-container {
    box-sizing:border-box; width:100%;
    padding-left:60px; padding-right:60px;
  }
  @media (max-width:640px) {
    .sx-footer-container { padding-left:20px; padding-right:20px; }
    .sx-footer { padding-top:40px !important; }
    .sx-footer-brand {
      margin-top:40px !important;
      max-width:none !important;
    }
    .sx-footer-cta {
      padding:16px 24px !important; font-size:16px !important;
      width:100%; display:block;
    }
  }
  .sx-footer-logo {
    display:inline-block;
    font-family:'Arial Nova', Arial, sans-serif;
    font-size:28px; font-weight:400; line-height:22px; letter-spacing:-1.9px;
    color:#ecfd21; text-decoration:none; text-transform:lowercase;
    word-spacing:100vw; /* one word per line */
    width:130px;
  }
  .sx-footer-h {
    font-family:'Arial Nova', Arial, sans-serif;
    font-size:20px; font-weight:400; color:#ecfd21;
    text-transform:uppercase; letter-spacing:-1px;
  }
  .sx-footer-cta {
    background:#ecfd21 !important; color:#000 !important;
    font-family:'Inter', sans-serif;
    font-size:18px; font-weight:700; letter-spacing:.5px; text-transform:uppercase;
    padding:20px 36px;
    border:0 !important; border-radius:0 !important; outline:0;
    cursor:pointer;
    transition:opacity .15s;
    appearance:none; -webkit-appearance:none;
  }
  .sx-footer-cta:hover { opacity:.85; }
  .sx-footer-brand {
    font-family:'Oswald', 'Inter', sans-serif;
    font-size:clamp(40px, 6vw, 80px);
    font-weight:800; line-height:.95;
    letter-spacing:-0.035em;
    text-transform:uppercase;
    margin:24px 0 0 0;
    max-width:720px;
    overflow-wrap:anywhere;
  }
  .sx-footer-line {
    font-family:'Inter', sans-serif;
    font-size:13px; font-weight:700; color:#ecfd21;
    text-transform:uppercase; letter-spacing:.05em;
    margin:0; line-height:1.55;
  }
  .sx-footer-list { list-style:none; padding:0; margin:0; }
  .sx-footer-list a {
    font-family:'Inter', sans-serif;
    font-size:13px; font-weight:700; color:#ecfd21;
    text-transform:uppercase; letter-spacing:.05em;
    text-decoration:none; display:inline-block; line-height:1.9;
  }
  .sx-footer-list a:hover { color:#fff; }
  .sx-social { color:#ecfd21; }
  .sx-social:hover { opacity:.8; }
</style>
