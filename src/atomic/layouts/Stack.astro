---
/* Stack — flex container. direction=vertical → column, horizontal → row.
   All spacing values must be tokens (gap='md', padding='lg'). */
interface Props {
  direction?: 'vertical'|'horizontal';
  gap?: '0'|'xs'|'sm'|'md'|'lg'|'xl'|'2xl'|'3xl'|'4xl';
  align?: 'start'|'center'|'end'|'stretch';
  justify?: 'start'|'center'|'end'|'between';
  padding?: '0'|'xs'|'sm'|'md'|'lg'|'xl'|'2xl'|'3xl'|'4xl';
  paddingX?: string;
  paddingY?: string;
  wrap?: boolean;
}
const {
  direction = 'vertical',
  gap = 'md',
  align = 'start',
  justify = 'start',
  padding,
  paddingX,
  paddingY,
  wrap = false,
} = Astro.props as Props;

const justifyMap: Record<string,string> = {
  start: 'flex-start', center: 'center', end: 'flex-end', between: 'space-between',
};
const alignMap: Record<string,string> = {
  start: 'flex-start', center: 'center', end: 'flex-end', stretch: 'stretch',
};

const style = [
  'display: flex;',
  `flex-direction: ${direction === 'vertical' ? 'column' : 'row'};`,
  `gap: var(--t-space-${gap});`,
  `align-items: ${alignMap[align]};`,
  `justify-content: ${justifyMap[justify]};`,
  wrap ? 'flex-wrap: wrap;' : '',
  padding    ? `padding: var(--t-space-${padding});` : '',
  paddingX   ? `padding-left: var(--t-space-${paddingX}); padding-right: var(--t-space-${paddingX});` : '',
  paddingY   ? `padding-top: var(--t-space-${paddingY}); padding-bottom: var(--t-space-${paddingY});` : '',
].filter(Boolean).join(' ');
---

<div style={style}>
  <slot />
</div>
